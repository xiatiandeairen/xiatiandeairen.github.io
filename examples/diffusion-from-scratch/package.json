{
  "name": "diffusion-from-scratch",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "从零用 TypeScript 在 2D toy 数据上手写 DDPM 与采样器：前向加噪、score 网络、训练、DDPM/DDIM 采样、CFG、latent。纯算法、离线 CPU 可跑、确定性可复现。配套书库《扩散与生成模型从零》。",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "stage01": "tsx src/stage01-forward.ts",
    "stage02": "tsx src/stage02-reverse.ts",
    "stage03": "tsx src/stage03-score.ts",
    "stage04": "tsx src/stage04-ddpm-train.ts",
    "stage05": "tsx src/stage05-samplers.ts",
    "stage06": "tsx src/stage06-cfg.ts",
    "stage07": "tsx src/stage07-latent.ts"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.0"
  }
}

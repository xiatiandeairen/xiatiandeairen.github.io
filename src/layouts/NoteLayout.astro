---
import BaseLayout from './BaseLayout.astro';
import type { SEOData } from '../utils/seo';

interface Props {
  note: any;
  seo?: SEOData;
  mode?: 'public' | 'audit';
  jsonLd?: Record<string, any>;
}

const { note, seo, mode = 'public', jsonLd } = Astro.props;
---

<BaseLayout seo={seo} jsonLd={jsonLd}>
  <article>
    <slot />
  </article>
</BaseLayout>

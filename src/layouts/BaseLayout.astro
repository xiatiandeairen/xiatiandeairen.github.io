---
import '../styles/global.css';
import type { SEOData } from '../utils/seo';
import { SITE_CONFIG } from '../utils/constants';

interface Props {
  title: string;
  description?: string;
  seo?: SEOData;
}

const { title, description, seo } = Astro.props;
const seoData = seo || {
  title: `${title} — ${SITE_CONFIG.title}`,
  description: description || SITE_CONFIG.description,
  url: Astro.url.href
};

const today = new Date().toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
  weekday: 'long',
});
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={seoData.description} />
    <title>{seoData.title}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400&family=Noto+Serif+SC:wght@400;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

    {seoData.ogTitle && <meta property="og:title" content={seoData.ogTitle} />}
    {seoData.ogDescription && <meta property="og:description" content={seoData.ogDescription} />}
    {seoData.ogType && <meta property="og:type" content={seoData.ogType} />}
    {seoData.url && <meta property="og:url" content={seoData.url} />}

    {seoData.canonical && <link rel="canonical" href={seoData.canonical} />}
  </head>
  <body>
    <a href="#main-content" class="skip-link">跳到主内容</a>
    <div class="min-h-screen flex flex-col">
      <header class="site-header">
        <a href="/" class="site-title">{SITE_CONFIG.title}</a>
        <div class="site-tagline">{SITE_CONFIG.tagline}</div>
      </header>
      <div class="site-dateline">
        <nav class="site-nav-links">
          <a href="/">首页</a>
          <a href="/tags">标签</a>
          <a href="/topics">主题</a>
          <a href="/search">搜索</a>
        </nav>
        <span>{today}</span>
      </div>
      <main id="main-content" class="site-main">
        <slot />
      </main>
      <footer class="site-footer">
        <span>© {new Date().getFullYear()} {SITE_CONFIG.title}</span>
        <span>基于 Astro 构建</span>
      </footer>
    </div>
  </body>
</html>

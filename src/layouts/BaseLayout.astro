---
import '../styles/global.css';
import type { SEOData } from '../utils/seo';

interface Props {
  title: string;
  description?: string;
  seo?: SEOData;
}

const { title, description, seo } = Astro.props;
const seoData = seo || {
  title,
  description: description || '技术笔记集合',
  url: Astro.url.href
};
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={seoData.description} />
    <title>{seoData.title}</title>
    
    {seoData.ogTitle && <meta property="og:title" content={seoData.ogTitle} />}
    {seoData.ogDescription && <meta property="og:description" content={seoData.ogDescription} />}
    {seoData.ogType && <meta property="og:type" content={seoData.ogType} />}
    {seoData.url && <meta property="og:url" content={seoData.url} />}
    
    {seoData.canonical && <link rel="canonical" href={seoData.canonical} />}
  </head>
  <body>
    <div class="min-h-screen flex flex-col">
      <header class="border-b border-border-light bg-bg-page/95 backdrop-blur-sm sticky top-0 z-10">
        <div class="mx-auto max-w-content px-6 py-6 md:px-8">
          <nav class="flex items-center justify-between">
            <a href="/" class="text-lg font-semibold text-text-primary hover:text-link transition-colors">
              技术笔记
            </a>
            <div class="flex items-center gap-6 text-small text-text-secondary">
              <a href="/tags" class="hover:text-link transition-colors">标签</a>
              <a href="/topics" class="hover:text-link transition-colors">主题</a>
              <a href="/search" class="hover:text-link transition-colors">搜索</a>
            </div>
          </nav>
        </div>
      </header>
      <main class="flex-1 mx-auto max-w-content w-full px-6 py-16 md:px-8">
        <slot />
      </main>
      <footer class="border-t border-border-light bg-bg-page mt-24">
        <div class="mx-auto max-w-content px-6 py-12 md:px-8 text-center text-small text-text-muted">
          <p>技术笔记集合 · 基于 Astro 构建</p>
        </div>
      </footer>
    </div>
  </body>
</html>

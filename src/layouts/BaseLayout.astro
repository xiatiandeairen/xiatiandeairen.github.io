---
import '../styles/global.css';
import type { SEOData } from '../utils/seo';
import { SITE_CONFIG } from '../utils/constants';
import { getLang, useT, switchLangPath, localePath, type Lang } from '../i18n';

interface Props {
  title: string;
  description?: string;
  seo?: SEOData;
  lang?: Lang;
}

const { title, description, seo, lang: propLang } = Astro.props;
const currentPath = Astro.url.pathname;
const lang = propLang || getLang(currentPath);
const t = useT(lang);
const htmlLang = lang === 'zh' ? 'zh-CN' : 'en';
const year = String(new Date().getFullYear());

const seoData = seo || {
  title: `${title} — ${t('site.title')}`,
  description: description || SITE_CONFIG.description,
  url: Astro.url.href
};

const switchPath = switchLangPath(currentPath, lang);
const switchLabel = lang === 'zh' ? 'English' : '中文';
const matchPath = currentPath.replace(/^\/en/, '') || '/';
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={seoData.description} />
    <title>{seoData.title}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400&family=Noto+Serif+SC:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <link rel="alternate" type="application/rss+xml" title={t('site.title')} href="/rss.xml" />

    {seoData.ogTitle && <meta property="og:title" content={seoData.ogTitle} />}
    {seoData.ogDescription && <meta property="og:description" content={seoData.ogDescription} />}
    {seoData.ogType && <meta property="og:type" content={seoData.ogType} />}
    {seoData.url && <meta property="og:url" content={seoData.url} />}
    {seoData.canonical && <link rel="canonical" href={seoData.canonical} />}

    <script is:inline>
      (function() {
        var saved = localStorage.getItem('theme');
        if (saved === 'dark' || (!saved && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
  </head>
  <body>
    <a href="#main-content" class="skip-link">{lang === 'zh' ? '跳到主内容' : 'Skip to content'}</a>
    <div class="min-h-screen flex flex-col">

      {/* ── Masthead: 杂志式对称 ── */}
      <header class="masthead">
        <nav class="masthead-row" aria-label={lang === 'zh' ? '主导航' : 'Main navigation'}>
          <a href={localePath('/archive', lang)} class:list={['masthead-nav-link', matchPath.startsWith('/archive') && 'active']}>
            {t('nav.blog')}
          </a>
          <a href={localePath('/', lang)} class="masthead-brand">
            {t('site.title')}
          </a>
          <a href={localePath('/about', lang)} class:list={['masthead-nav-link', matchPath.startsWith('/about') && 'active']}>
            {t('nav.about')}
          </a>
        </nav>
        <div class="masthead-tagline">{t('site.tagline')}</div>
      </header>

      <main id="main-content" class="site-main">
        <slot />
      </main>

      {/* ── Footer: 功能键移到这里 ── */}
      <footer class="site-footer">
        <div class="footer-left">
          <span>{t('site.copyright', { year })}</span>
        </div>
        <div class="footer-center">
          <a href={switchPath} class="footer-link">{switchLabel}</a>
          <span class="footer-dot">{'·'}</span>
          <button id="theme-toggle" class="footer-btn" aria-label={lang === 'zh' ? '切换主题' : 'Toggle theme'}>
            <span class="theme-icon-light">{'☀'}</span>
            <span class="theme-icon-dark">{'🌙'}</span>
          </button>
          <span class="footer-dot">{'·'}</span>
          <button id="search-trigger" class="footer-btn" aria-label={lang === 'zh' ? '搜索' : 'Search'}>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
            <span class="search-shortcut">{'⌘K'}</span>
          </button>
        </div>
        <div class="footer-right">
          <a href="/rss.xml" class="footer-link">RSS</a>
        </div>
      </footer>
    </div>

    {/* ── Search overlay ── */}
    <div id="search-overlay" class="search-overlay" style="display:none;">
      <div class="search-backdrop" id="search-backdrop"></div>
      <div class="search-dialog">
        <div class="search-input-row">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="search-icon"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
          <input type="text" id="search-input" class="search-input" placeholder={t('search.placeholder')} autocomplete="off" />
          <kbd class="search-esc">ESC</kbd>
        </div>
        <div id="search-results" class="search-results"></div>
      </div>
    </div>

    <script is:inline>
      (function() {
        // Theme toggle
        document.getElementById('theme-toggle').addEventListener('click', function() {
          var html = document.documentElement;
          var isDark = html.classList.toggle('dark');
          localStorage.setItem('theme', isDark ? 'dark' : 'light');
        });

        // Search overlay
        var overlay = document.getElementById('search-overlay');
        var input = document.getElementById('search-input');
        var results = document.getElementById('search-results');
        var searchIndex = null;
        var debounceTimer = null;

        function openSearch() {
          overlay.style.display = '';
          input.focus();
          input.value = '';
          results.innerHTML = '';
          document.body.style.overflow = 'hidden';
        }

        function closeSearch() {
          overlay.style.display = 'none';
          document.body.style.overflow = '';
        }

        document.getElementById('search-trigger').addEventListener('click', openSearch);
        document.getElementById('search-backdrop').addEventListener('click', closeSearch);

        document.addEventListener('keydown', function(e) {
          if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
            e.preventDefault();
            overlay.style.display === 'none' ? openSearch() : closeSearch();
          }
          if (e.key === 'Escape' && overlay.style.display !== 'none') {
            closeSearch();
          }
        });

        input.addEventListener('input', function() {
          clearTimeout(debounceTimer);
          debounceTimer = setTimeout(doSearch, 200);
        });

        async function doSearch() {
          var q = input.value.trim().toLowerCase();
          if (!q) { results.innerHTML = ''; return; }
          if (!searchIndex) {
            try {
              var r = await fetch('/search-index.json');
              searchIndex = await r.json();
            } catch(e) { results.innerHTML = '<div class="search-empty">Error</div>'; return; }
          }
          var matches = searchIndex.notes.filter(function(n) {
            return n.title.toLowerCase().includes(q) || n.content.toLowerCase().includes(q) || n.tags.some(function(t){return t.toLowerCase().includes(q)});
          }).slice(0, 8);

          if (matches.length === 0) {
            results.innerHTML = '<div class="search-empty">No results</div>';
            return;
          }
          results.innerHTML = matches.map(function(n) {
            return '<a href="/notes/' + n.slug + '" class="search-result-item"><span class="search-result-title">' + n.title.replace(/</g,'&lt;') + '</span><span class="search-result-date">' + new Date(n.date).toLocaleDateString() + '</span></a>';
          }).join('');

          results.querySelectorAll('.search-result-item').forEach(function(el) {
            el.addEventListener('click', closeSearch);
          });
        }
      })();
    </script>
  </body>
</html>

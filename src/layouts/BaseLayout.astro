---
import '../styles/global.css';
import type { SEOData } from '../utils/seo';
import { SITE_CONFIG } from '../utils/constants';
import { getLang, useT, switchLangPath, localePath, type Lang } from '../i18n';
import Sidebar from '../components/Sidebar.astro';
import ShortcutsHelp from '../components/ShortcutsHelp.astro';

interface Props {
  title: string;
  description?: string;
  seo?: SEOData;
  lang?: Lang;
  jsonLd?: Record<string, any>;
}

const { title, description, seo, lang: propLang, jsonLd } = Astro.props;
const currentPath = Astro.url.pathname;
const lang = propLang || getLang(currentPath);
const t = useT(lang);
const htmlLang = lang === 'zh' ? 'zh-CN' : 'en';
const year = String(new Date().getFullYear());

const seoData = seo || {
  title: `${title} — ${t('site.title')}`,
  description: description || SITE_CONFIG.description,
  url: Astro.url.href
};

const switchPath = switchLangPath(currentPath, lang);
const matchPath = currentPath.replace(/^\/en/, '') || '/';
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={seoData.description} />
    <title>{seoData.title}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    {/* Critical fonts: preload display + body serif */}
    <link rel="preload" href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Noto+Serif+SC:wght@500;700&display=swap" as="style" />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400&family=Noto+Serif+SC:wght@400;500;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
    <link rel="alternate" type="application/rss+xml" title={t('site.title')} href="/rss.xml" />

    {seoData.ogTitle && <meta property="og:title" content={seoData.ogTitle} />}
    {seoData.ogDescription && <meta property="og:description" content={seoData.ogDescription} />}
    {seoData.ogType && <meta property="og:type" content={seoData.ogType} />}
    {seoData.url && <meta property="og:url" content={seoData.url} />}
    {seoData.ogImage && <meta property="og:image" content={seoData.ogImage} />}
    {seoData.ogImage && <meta name="twitter:card" content="summary_large_image" />}
    {seoData.ogTitle && <meta name="twitter:title" content={seoData.ogTitle} />}
    {seoData.ogDescription && <meta name="twitter:description" content={seoData.ogDescription} />}
    {seoData.ogImage && <meta name="twitter:image" content={seoData.ogImage} />}
    {seoData.canonical && <link rel="canonical" href={seoData.canonical} />}
    {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}

    <script is:inline>
      (function() {
        var saved = localStorage.getItem('theme');
        if (saved === 'dark' || (!saved && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
  </head>
  <body>
    <a href="#main-content" class="skip-link">{lang === 'zh' ? '跳到主内容' : 'Skip to content'}</a>
    <div class="min-h-screen flex flex-col">

      <div class="masthead-outer">
        <header class="masthead">
          <div class="masthead-title-row">
            <a href={localePath('/', lang)} class="masthead-brand">{t('site.title')}</a>
          </div>
          <div class="masthead-meta">
            <div class="masthead-spacer"></div>
            <div class="masthead-center">
              <span class="masthead-tagline">{t('site.tagline')}</span>
              <span class="masthead-sep"></span>
              <nav class="masthead-nav" aria-label={lang === 'zh' ? '主导航' : 'Main navigation'}>
                <a href={localePath('/topics', lang)} class:list={[matchPath.startsWith('/topics') && 'active']}>
                  {t('nav.topics')}
                </a>
                <a href={localePath('/series', lang)} class:list={[matchPath.startsWith('/series') && 'active']}>
                  {t('nav.series')}
                </a>
                <a href={localePath('/archive', lang)} class:list={[matchPath.startsWith('/archive') && 'active']}>
                  {t('nav.archive')}
                </a>
                <a href={localePath('/about', lang)} class:list={[matchPath.startsWith('/about') && 'active']}>
                  {t('nav.about')}
                </a>
              </nav>
            </div>
            <div class="masthead-tools">
              <button id="search-trigger" class="icon-button expandable" aria-label={lang === 'zh' ? '搜索' : 'Search'}>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/></svg>
                <kbd class="icon-label">{'⌘K'}</kbd>
              </button>
              <div class="has-dropdown">
                <a href={switchPath} class="icon-button" aria-label={lang === 'zh' ? 'English' : '中文'} title={lang === 'zh' ? 'English' : '中文'}>
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                </a>
                <div class="dropdown">
                  <a href={lang === 'zh' ? currentPath : currentPath.replace(/^\/en/, '') || '/'} class:list={['dropdown-item', lang === 'zh' && 'active']}>中文</a>
                  <a href={lang === 'en' ? currentPath : `/en${currentPath}`} class:list={['dropdown-item', lang === 'en' && 'active']}>English</a>
                </div>
              </div>
              <div class="has-dropdown">
                <button id="theme-toggle" class="icon-button" aria-label={lang === 'zh' ? '切换主题' : 'Toggle theme'}>
                  <span class="theme-icon-light"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></svg></span>
                  <span class="theme-icon-dark"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg></span>
                </button>
                <div class="dropdown" id="theme-dropdown">
                  <button class="dropdown-item theme-option" data-theme="light">{lang === 'zh' ? '浅色' : 'Light'}</button>
                  <button class="dropdown-item theme-option" data-theme="sepia">{lang === 'zh' ? '羊皮' : 'Sepia'}</button>
                  <button class="dropdown-item theme-option" data-theme="dark">{lang === 'zh' ? '深色' : 'Dark'}</button>
                </div>
              </div>
              <ShortcutsHelp lang={lang} />
            </div>
          </div><!-- masthead-meta -->
        </header>
      </div>

      <main id="main-content" class="site-main">
        <slot />
      </main>

      <footer class="site-footer">
        <span>{t('site.copyright', { year })}</span>
        <span><a href="/subscribe" class="footer-link">{lang === 'zh' ? '订阅' : 'Subscribe'}</a> {'·'} <a href="/rss.xml" class="footer-link">RSS</a> {'·'} {t('site.builtWith')}</span>
      </footer>
    </div>

    {/* Sidebar drawer: hover to reveal */}
    <div class="sidebar-drawer" role="complementary" aria-label={lang === 'zh' ? '侧边栏' : 'Sidebar'}>
      <div class="sidebar-indicator">
        <svg width="8" height="12" viewBox="0 0 8 12" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 1L1 6l5 5"/></svg>
      </div>
      <div class="sidebar-panel">
        <Sidebar lang={lang} />
      </div>
    </div>

    {/* Search overlay */}
    <div id="search-overlay" class="search-overlay" style="display:none;">
      <div class="search-backdrop" id="search-backdrop"></div>
      <div class="search-dialog">
        <div class="search-input-row">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="search-icon"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
          <input type="text" id="search-input" class="search-input" placeholder={t('search.placeholder')} autocomplete="off" />
          <kbd class="search-esc">ESC</kbd>
        </div>
        <div class="search-date-row">
          <button type="button" class="search-date-chip" data-date="">{lang === 'zh' ? '全部' : 'All'}</button>
          <button type="button" class="search-date-chip" data-date="30d">{lang === 'zh' ? '近30天' : 'Last 30d'}</button>
          <button type="button" class="search-date-chip" data-date="90d">{lang === 'zh' ? '近90天' : 'Last 90d'}</button>
          <button type="button" class="search-date-chip" data-date="1y">{lang === 'zh' ? '近1年' : 'Last 1y'}</button>
        </div>
        <div id="search-results" class="search-results"></div>
      </div>
    </div>

    <script is:inline>
      (function() {
        // Theme system: 3 themes — light / sepia / dark.
        // dark uses html.dark (existing); sepia uses html[data-theme="sepia"]; light = no class no attr.
        function applyTheme(theme) {
          var html = document.documentElement;
          html.classList.toggle('dark', theme === 'dark');
          if (theme === 'sepia') html.setAttribute('data-theme', 'sepia');
          else html.removeAttribute('data-theme');
          try { localStorage.setItem('theme', theme); } catch (e) {}
          updateThemeDropdown();
        }
        function currentTheme() {
          var html = document.documentElement;
          if (html.classList.contains('dark')) return 'dark';
          if (html.getAttribute('data-theme') === 'sepia') return 'sepia';
          return 'light';
        }
        // Initialize from saved preference (overrides initial inline-script's dark default).
        try {
          var saved = localStorage.getItem('theme');
          if (saved === 'sepia' || saved === 'light' || saved === 'dark') applyTheme(saved);
        } catch (e) {}

        // Theme button: cycle light → sepia → dark → light
        document.getElementById('theme-toggle').addEventListener('click', function() {
          var order = ['light', 'sepia', 'dark'];
          var next = order[(order.indexOf(currentTheme()) + 1) % order.length];
          applyTheme(next);
        });

        // Theme dropdown: option click
        document.querySelectorAll('.theme-option').forEach(function(btn) {
          btn.addEventListener('click', function(e) {
            e.stopPropagation();
            applyTheme(this.getAttribute('data-theme'));
          });
        });

        function updateThemeDropdown() {
          var t = currentTheme();
          document.querySelectorAll('.theme-option').forEach(function(btn) {
            btn.classList.toggle('active', btn.getAttribute('data-theme') === t);
          });
        }
        updateThemeDropdown();

        var overlay = document.getElementById('search-overlay');
        var input = document.getElementById('search-input');
        var results = document.getElementById('search-results');
        var searchIndex = null, timer = null;
        var selectedIdx = -1;
        var RECENT_KEY = 'search.recentQueries';
        var RECENT_MAX = 5;

        function escapeHtml(s) { return String(s).replace(/[&<>"']/g, function(c){ return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]; }); }
        function escapeRe(s) { return s.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'); }
        function highlight(text, term) {
          if (!term) return escapeHtml(text);
          var esc = escapeHtml(text);
          return esc.replace(new RegExp(escapeRe(escapeHtml(term)), 'gi'), '<mark>$&</mark>');
        }
        function getRecent() {
          try { return JSON.parse(localStorage.getItem(RECENT_KEY) || '[]'); } catch(e) { return []; }
        }
        function pushRecent(q) {
          if (!q) return;
          var list = getRecent().filter(function(x){ return x !== q; });
          list.unshift(q);
          list = list.slice(0, RECENT_MAX);
          try { localStorage.setItem(RECENT_KEY, JSON.stringify(list)); } catch(e) {}
        }
        function clearRecent(q) {
          var list = getRecent().filter(function(x){ return x !== q; });
          try { localStorage.setItem(RECENT_KEY, JSON.stringify(list)); } catch(e) {}
        }

        // Query parser + scorer (mirror of src/utils/search.ts searchNotes)
        var PREFIX_RE = /\b(tag|topic|type|series|date):([^\s]+)/gi;
        function parseDateSpec(spec) {
          if (!spec) return null;
          var now = new Date(); var m;
          if ((m = spec.match(/^(\d+)d$/))) { var s = new Date(now); s.setDate(s.getDate() - parseInt(m[1])); return { since: s.toISOString(), until: now.toISOString() }; }
          if ((m = spec.match(/^(\d+)y$/))) { var s2 = new Date(now); s2.setFullYear(s2.getFullYear() - parseInt(m[1])); return { since: s2.toISOString(), until: now.toISOString() }; }
          if ((m = spec.match(/^(\d{4})$/))) return { since: m[1] + '-01-01T00:00:00Z', until: m[1] + '-12-31T23:59:59Z' };
          if ((m = spec.match(/^(\d{4})-(\d{2})$/))) {
            var y = parseInt(m[1]), mo = parseInt(m[2]);
            var last = new Date(y, mo, 0).getDate();
            return { since: m[1] + '-' + m[2] + '-01T00:00:00Z', until: m[1] + '-' + m[2] + '-' + String(last).padStart(2,'0') + 'T23:59:59Z' };
          }
          return null;
        }
        function parseQuery(raw) {
          var out = { free: '' };
          var free = raw || '';
          var m;
          PREFIX_RE.lastIndex = 0;
          while ((m = PREFIX_RE.exec(raw || '')) !== null) {
            out[m[1].toLowerCase()] = m[2].toLowerCase();
            free = free.replace(m[0], '');
          }
          out.free = free.trim().toLowerCase();
          return out;
        }
        function snippetOf(content, term) {
          if (!content) return '';
          if (!term) return content.slice(0, 160);
          var idx = content.toLowerCase().indexOf(term);
          if (idx < 0) return content.slice(0, 160);
          var start = Math.max(0, idx - 60);
          var end = Math.min(content.length, idx + term.length + 100);
          return (start > 0 ? '…' : '') + content.slice(start, end) + (end < content.length ? '…' : '');
        }
        function searchNotes(rawQuery, index, limit) {
          var q = parseQuery(rawQuery);
          if (!q.free && !q.tag && !q.topic && !q.type && !q.series && !q.date) return [];
          var dateRange = q.date ? parseDateSpec(q.date) : null;
          var hits = [];
          for (var i = 0; i < index.notes.length; i++) {
            var n = index.notes[i];
            if (q.tag) {
              var tHit = n.tags.some(function(t){ return t.toLowerCase().includes(q.tag); });
              var taHit = (n.tagAliases || []).some(function(a){ return a.toLowerCase().includes(q.tag); });
              if (!tHit && !taHit) continue;
            }
            if (q.topic) {
              var tpHit = n.topics.some(function(t){ return t.toLowerCase().includes(q.topic); });
              var tpaHit = (n.topicAliases || []).some(function(a){ return a.toLowerCase().includes(q.topic); });
              if (!tpHit && !tpaHit) continue;
            }
            if (q.type && !(n.questionType || '').toLowerCase().includes(q.type)) continue;
            if (q.series && !((n.series || '').toLowerCase().includes(q.series))) continue;
            if (dateRange && (n.date < dateRange.since || n.date > dateRange.until)) continue;

            var score = 0, matched = 'content', free = q.free;
            if (!free) {
              score = 50;
              matched = q.tag ? 'tag' : q.topic ? 'topic' : q.series ? 'series' : q.type ? 'type' : 'content';
            } else {
              var title = n.title.toLowerCase();
              var content = (n.content || '').toLowerCase();
              var tagsLow = n.tags.map(function(t){return t.toLowerCase();});
              var topicsLow = n.topics.map(function(t){return t.toLowerCase();});
              var aliasesLow = ((n.tagAliases || []).concat(n.topicAliases || [])).map(function(a){return a.toLowerCase();});
              var sLow = (n.series || '').toLowerCase();

              if (title === free) { score = 100; matched = 'title'; }
              else if (title.includes(free)) { score = 60; matched = 'title'; }
              else if (tagsLow.indexOf(free) >= 0) { score = 55; matched = 'tag'; }
              else if (topicsLow.indexOf(free) >= 0) { score = 55; matched = 'topic'; }
              else if (sLow === free) { score = 50; matched = 'series'; }
              else if (tagsLow.some(function(t){return t.includes(free);})) { score = 35; matched = 'tag'; }
              else if (topicsLow.some(function(t){return t.includes(free);})) { score = 35; matched = 'topic'; }
              else if (sLow.includes(free)) { score = 30; matched = 'series'; }
              else if (aliasesLow.some(function(a){return a.includes(free);})) { score = 25; matched = 'alias'; }
              else if (content.includes(free)) { score = 10; matched = 'content'; }
              else if (q.tag || q.topic || q.type || q.series) { score = 20; }
              else { continue; }
            }
            hits.push({
              note: n,
              score: score,
              matchedField: matched,
              snippet: snippetOf(n.content || '', free || q.tag || q.topic || q.series || q.type || '')
            });
          }
          hits.sort(function(a, b) {
            if (b.score !== a.score) return b.score - a.score;
            return a.note.date < b.note.date ? 1 : a.note.date > b.note.date ? -1 : 0;
          });
          return limit ? hits.slice(0, limit) : hits;
        }

        async function loadIndex() {
          if (searchIndex) return searchIndex;
          try { searchIndex = await (await fetch('/search-index.json')).json(); } catch(e) { searchIndex = null; }
          return searchIndex;
        }

        function renderEmpty() {
          selectedIdx = -1;
          var recent = getRecent();
          var topTags = [];
          var topTopics = [];
          if (searchIndex) {
            var tc = searchIndex.tagCounts || {};
            topTags = Object.keys(tc).sort(function(a,b){return tc[b]-tc[a];}).slice(0, 5);
            var pc = searchIndex.topicCounts || {};
            topTopics = Object.keys(pc).sort(function(a,b){return pc[b]-pc[a];}).slice(0, 3);
          }
          var html = '';
          if (recent.length) {
            html += '<div class="search-section"><div class="search-section-title">最近搜索</div>';
            html += recent.map(function(q){
              return '<div class="search-recent-row"><button class="search-recent-q" data-query="' + escapeHtml(q) + '">' + escapeHtml(q) + '</button><button class="search-recent-x" data-clear="' + escapeHtml(q) + '" aria-label="删除">×</button></div>';
            }).join('');
            html += '</div>';
          }
          if (topTopics.length) {
            html += '<div class="search-section"><div class="search-section-title">热门主题</div><div class="search-chips">';
            html += topTopics.map(function(t){ return '<a class="search-chip search-chip-primary" href="/topics/' + encodeURIComponent(t) + '">' + escapeHtml(t) + '</a>'; }).join('');
            html += '</div></div>';
          }
          if (topTags.length) {
            html += '<div class="search-section"><div class="search-section-title">热门标签</div><div class="search-chips">';
            html += topTags.map(function(t){ return '<a class="search-chip" href="/tags/' + encodeURIComponent(t) + '">' + escapeHtml(t) + '</a>'; }).join('');
            html += '</div></div>';
          }
          // syntax tips section
          html += '<div class="search-section"><div class="search-section-title">搜索技巧 <span class="search-section-hint">点击插入</span></div><div class="search-chips">';
          html += ['tag:', 'topic:', 'type:', 'series:'].map(function(p){
            return '<button type="button" class="search-syntax-chip" data-prefix="' + p + '">' + p + '</button>';
          }).join('');
          html += '</div></div>';
          if (!html) html = '<div class="search-empty">开始输入以搜索（支持 tag:/topic:/type:/series: 前缀）</div>';
          results.innerHTML = html;
          // wire recent
          results.querySelectorAll('[data-query]').forEach(function(b) {
            b.addEventListener('click', function() { input.value = this.getAttribute('data-query'); doSearch(); input.focus(); });
          });
          results.querySelectorAll('[data-clear]').forEach(function(b) {
            b.addEventListener('click', function(e) { e.stopPropagation(); clearRecent(this.getAttribute('data-clear')); renderEmpty(); });
          });
          results.querySelectorAll('.search-chip').forEach(function(a) {
            a.addEventListener('click', closeSearch);
          });
          results.querySelectorAll('[data-prefix]').forEach(function(b) {
            b.addEventListener('click', function() {
              var p = this.getAttribute('data-prefix') || '';
              input.value = p;
              input.focus();
              input.setSelectionRange(p.length, p.length);
            });
          });
        }

        function setSelected(idx) {
          var items = results.querySelectorAll('.search-result-item');
          if (!items.length) return;
          items.forEach(function(el){ el.classList.remove('active'); });
          if (idx < 0) idx = items.length - 1;
          if (idx >= items.length) idx = 0;
          selectedIdx = idx;
          items[idx].classList.add('active');
          items[idx].scrollIntoView({ block: 'nearest' });
        }

        async function doSearch() {
          var raw = input.value.trim();
          if (!raw) { renderEmpty(); return; }
          var idx = await loadIndex();
          if (!idx) { results.innerHTML = '<div class="search-empty">Index unavailable</div>'; return; }
          var hits = searchNotes(raw, idx, 8);
          if (!hits.length) { results.innerHTML = '<div class="search-empty">无结果</div>'; selectedIdx = -1; return; }
          var parsed = parseQuery(raw);
          var highlightTerm = parsed.free || parsed.tag || parsed.topic || parsed.series || parsed.type || '';
          results.innerHTML = hits.map(function(h) {
            var fieldLabel = { title: '标题', tag: '标签', topic: '主题', series: '系列', type: '类型', alias: '同义词', content: '正文' }[h.matchedField] || '';
            return '<a href="/notes/' + h.note.slug + '" class="search-result-item" data-query="' + escapeHtml(raw) + '">' +
              '<div class="search-result-header">' +
                '<span class="search-result-title">' + highlight(h.note.title, highlightTerm) + '</span>' +
                '<span class="search-result-meta">' + (fieldLabel ? '<span class="search-result-field">' + fieldLabel + '</span>' : '') + '<span class="search-result-date">' + new Date(h.note.date).toLocaleDateString() + '</span></span>' +
              '</div>' +
              (h.snippet ? '<div class="search-result-snippet">' + highlight(h.snippet, highlightTerm) + '</div>' : '') +
            '</a>';
          }).join('');
          results.querySelectorAll('.search-result-item').forEach(function(el, i) {
            el.addEventListener('click', function() { pushRecent(el.getAttribute('data-query')); closeSearch(); });
            el.addEventListener('mouseenter', function() { setSelected(i); });
          });
          selectedIdx = 0;
          var first = results.querySelector('.search-result-item');
          if (first) first.classList.add('active');
        }

        async function openSearch() {
          overlay.style.display = '';
          input.focus();
          input.value = '';
          document.body.style.overflow = 'hidden';
          await loadIndex();
          renderEmpty();
        }
        function closeSearch() { overlay.style.display = 'none'; document.body.style.overflow = ''; selectedIdx = -1; }

        document.getElementById('search-trigger').addEventListener('click', openSearch);
        document.getElementById('search-backdrop').addEventListener('click', closeSearch);
        document.addEventListener('keydown', function(e) {
          if ((e.metaKey || e.ctrlKey) && e.key === 'k') { e.preventDefault(); overlay.style.display === 'none' ? openSearch() : closeSearch(); return; }
          if (overlay.style.display === 'none') return;
          if (e.key === 'Escape') { closeSearch(); return; }
          if (e.key === 'ArrowDown') { e.preventDefault(); setSelected(selectedIdx + 1); return; }
          if (e.key === 'ArrowUp') { e.preventDefault(); setSelected(selectedIdx - 1); return; }
          if (e.key === 'Enter') {
            var items = results.querySelectorAll('.search-result-item');
            if (selectedIdx >= 0 && items[selectedIdx]) {
              pushRecent(items[selectedIdx].getAttribute('data-query') || input.value.trim());
              window.location.href = items[selectedIdx].getAttribute('href');
              e.preventDefault();
            }
          }
        });
        input.addEventListener('input', function() { clearTimeout(timer); timer = setTimeout(doSearch, 160); refreshDateChipActive(); });

        // Date chip toggle: rewrite date: prefix in input
        function refreshDateChipActive() {
          var current = (input.value.match(/\bdate:(\S+)/i) || ['',''])[1].toLowerCase();
          document.querySelectorAll('.search-date-chip').forEach(function(c) {
            c.classList.toggle('active', (c.getAttribute('data-date') || '') === current);
          });
        }
        document.querySelectorAll('.search-date-chip').forEach(function(c) {
          c.addEventListener('click', function() {
            var spec = this.getAttribute('data-date') || '';
            var stripped = input.value.replace(/\bdate:\S+\s*/gi, '').trim();
            input.value = spec ? (stripped + (stripped ? ' ' : '') + 'date:' + spec).trim() : stripped;
            input.focus();
            refreshDateChipActive();
            doSearch();
          });
        });
        refreshDateChipActive();
      })();
    </script>
  </body>
</html>

---
import BaseLayout from './BaseLayout.astro';
import type { SEOData } from '../utils/seo';

interface Props {
  title: string;
  description?: string;
  seo?: SEOData;
  showHeader?: boolean;
}

const { title, description, seo, showHeader = true } = Astro.props;
---

<BaseLayout title={title} description={description} seo={seo}>
  {showHeader && (
    <header class="mb-8 pb-6 border-b border-rule-light">
      <h1 class="font-display text-h1 text-ink mb-2">{title}</h1>
      {description && <p class="font-sans text-small text-ink-muted">{description}</p>}
    </header>
  )}
  <slot />
</BaseLayout>

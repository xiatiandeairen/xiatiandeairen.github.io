---
import IndexLayout from '../../layouts/IndexLayout.astro';
import { getAllNotes } from '../../utils/notes';
import { generatePageMeta } from '../../utils/seo';

const allNotes = getAllNotes();
const topicMap = new Map<string, number>();

for (const note of allNotes) {
  for (const topic of note.topics) {
    const count = topicMap.get(topic.name) || 0;
    topicMap.set(topic.name, count + 1);
  }
}

const topics = Array.from(topicMap.entries())
  .map(([name, count]) => ({ name, count }))
  .sort((a, b) => b.count - a.count);

const seo = generatePageMeta({
  title: '主题索引',
  description: '浏览所有主题',
  path: '/topics'
});
---

<IndexLayout title="主题索引" description="按主题浏览笔记。" seo={seo}>
  {topics.length === 0 ? (
    <p class="text-ink-muted text-center py-16 font-sans">暂无主题</p>
  ) : (
    <div>
      {topics.map((topic) => (
        <a href={`/topics/${topic.name}`} class="archive-item">
          <div>
            <div class="archive-item-title">{topic.name}</div>
          </div>
          <div class="archive-item-meta font-sans">
            <span>{topic.count} 篇笔记</span>
          </div>
        </a>
      ))}
    </div>
  )}
</IndexLayout>

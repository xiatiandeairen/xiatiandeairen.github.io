---
import IndexLayout from '../../layouts/IndexLayout.astro';
import NoteCard from '../../components/NoteCard.astro';
import Pagination from '../../components/Pagination.astro';
import { getAllNotes, getNotesByTopic, sortNotes, paginateNotes } from '../../utils/notes';
import { resolveTopicAlias } from '../../utils/tags';
import { getCoTopics, getTopTagsInTopic } from '../../utils/rank';
import { generatePageMeta } from '../../utils/seo';

export async function getStaticPaths() {
  const allNotes = getAllNotes();
  const topicSet = new Set<string>();

  for (const note of allNotes) {
    for (const topic of note.topics) {
      topicSet.add(topic.name);
      if (topic.alias) {
        topic.alias.forEach(alias => topicSet.add(alias));
      }
    }
  }

  const paths = [];
  for (const topicName of topicSet) {
    const resolvedTopic = resolveTopicAlias(topicName, allNotes);
    const notes = getNotesByTopic(resolvedTopic, allNotes);
    const totalPages = Math.ceil(notes.length / 20);

    for (let page = 1; page <= totalPages; page++) {
      paths.push({
        params: { topic: topicName, page: page.toString() }
      });
    }
    if (totalPages === 0) {
      paths.push({ params: { topic: topicName, page: '1' } });
    }
  }

  return paths.map(({ params }) => {
    const topicName = params.topic;
    const page = parseInt(params.page || '1');
    const resolvedTopic = resolveTopicAlias(topicName, allNotes);
    const notes = getNotesByTopic(resolvedTopic, allNotes);
    const sortedNotes = sortNotes(notes, 'date', 'desc');
    const { notes: paginatedNotes, pagination } = paginateNotes(sortedNotes, page);
    
    const seo = generatePageMeta({
      title: `主题: ${topicName}`,
      description: `主题 "${topicName}" 下的笔记`,
      path: `/topics/${topicName}`
    });

    return {
      params,
      props: {
        topicName: resolvedTopic,
        notes: paginatedNotes,
        pagination,
        seo
      }
    };
  });
}

const { topicName, notes, pagination, seo } = Astro.props;
const allNotesForBridge = getAllNotes();
const topTagsInTopic = getTopTagsInTopic(topicName, allNotesForBridge, 5);
const coTopics = getCoTopics(topicName, allNotesForBridge, 5);
---

<IndexLayout title={`主题: ${topicName}`} seo={seo}>
  {(topTagsInTopic.length > 0 || coTopics.length > 0) && (
    <div class="topic-bridge">
      {topTagsInTopic.length > 0 && (
        <div class="topic-bridge-row">
          <span class="topic-bridge-label">包含标签</span>
          <div class="topic-bridge-chips">
            {topTagsInTopic.map(t => (
              <a href={`/tags/${encodeURIComponent(t.name)}`} class="bridge-chip">{t.name} <span class="bridge-chip-count">{t.count}</span></a>
            ))}
          </div>
        </div>
      )}
      {coTopics.length > 0 && (
        <div class="topic-bridge-row">
          <span class="topic-bridge-label">关联主题</span>
          <div class="topic-bridge-chips">
            {coTopics.map(t => (
              <a href={`/topics/${encodeURIComponent(t.name)}`} class="bridge-chip bridge-chip-primary">{t.name}</a>
            ))}
          </div>
        </div>
      )}
    </div>
  )}

  {notes.length === 0 ? (
    <p class="text-text-secondary">该主题下暂无笔记</p>
  ) : (
    <>
      <div class="space-y-4">
        {notes.map((note) => (
          <NoteCard note={note} showQuality={true} />
        ))}
      </div>
      <Pagination
        currentPage={pagination.currentPage}
        totalPages={pagination.totalPages}
        baseUrl={`/topics/${topicName}`}
      />
    </>
  )}
</IndexLayout>

<style>
  .topic-bridge {
    margin-bottom: var(--space-6);
    padding: var(--space-4);
    background: var(--bg-subtle);
    border: 1px solid var(--rule-faint);
    border-radius: var(--radius-md);
    display: grid;
    gap: var(--space-3);
  }
  .topic-bridge-row {
    display: flex;
    align-items: baseline;
    gap: var(--space-3);
    flex-wrap: wrap;
  }
  .topic-bridge-label {
    font-family: Inter, sans-serif;
    font-size: var(--font-label);
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-muted);
    flex-shrink: 0;
  }
  .topic-bridge-chips { display: flex; flex-wrap: wrap; gap: 6px; }
  .bridge-chip {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 2px 10px;
    font-family: Inter, sans-serif;
    font-size: var(--font-caption);
    color: var(--ink-light);
    background: var(--paper);
    border: 1px solid var(--rule-light);
    border-radius: 999px;
    text-decoration: none;
    transition: border-color var(--duration-fast), color var(--duration-fast);
  }
  .bridge-chip:hover { color: var(--ink); border-color: var(--ink-muted); }
  .bridge-chip-primary {
    color: var(--accent);
    border-color: color-mix(in srgb, var(--accent) 30%, transparent);
  }
  .bridge-chip-primary:hover { border-color: var(--accent); }
  .bridge-chip-count { font-size: var(--font-xs); color: var(--ink-ghost); }
</style>

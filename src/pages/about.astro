---
import BaseLayout from '../layouts/BaseLayout.astro';
import { generatePageMeta } from '../utils/seo';
import { getLang, useT } from '../i18n';

const lang = getLang(Astro.url.pathname);
const t = useT(lang);
const seo = generatePageMeta({ title: t('about.title'), description: t('about.subtitle'), path: '/about' });
---

<BaseLayout title={t('about.title')} seo={seo} lang={lang}>
  <div class="layout-dual-wide">
    <main>
      <h1 class="font-display text-h1 mb-5">关于这里</h1>
      <p class="about-intro">
        这是一份个人刊物——记录 AI Native 实践中的思考、技术写作的沉淀、以及工具背后的设计哲学。
      </p>

      <h3 class="about-section-title">关于我</h3>
      <p class="about-body">
        夏天的爱人是绿色。AI Native，相信 AI 不只是工具，而是一种新的工作方式。我构建 AI Agent 的技能系统——给 AI 建立工作纪律，让它从"能写代码"变成"能交付"。
      </p>
      <p class="about-body">
        日常工作是全栈开发，对系统设计、Rust、前端架构和 AI 工程化比较感兴趣。写的代码和写的文字一样多。
      </p>

      <h3 class="about-section-title">为什么写</h3>
      <p class="about-body">
        写作是最好的思考工具。很多时候，我以为自己理解了一个概念，直到试图把它写下来——然后发现理解里全是漏洞。
      </p>
      <p class="about-body">
        这个网站没有 KPI、没有更新频率、没有流量目标。它只是一个地方，用来放那些值得被认真写下来的东西。
      </p>

      <div class="values-grid">
        <div class="value-card"><h4>精确</h4><p>宁可少写，也不含糊。</p></div>
        <div class="value-card"><h4>诚实</h4><p>不懂就说不懂。</p></div>
        <div class="value-card"><h4>留白</h4><p>给读者留思考空间。</p></div>
        <div class="value-card"><h4>持久</h4><p>写三年后仍有价值的东西。</p></div>
      </div>

      <h3 class="about-section-title">版权声明</h3>
      <p class="about-body">
        除非特别标注，所有文章均为原创。你可以自由引用，但请注明出处。如果某篇文章帮到了你，告诉我会让我很开心。
      </p>
    </main>

    <aside class="sticky top-8 self-start">
      <div class="mb-7 text-center">
        <div class="avatar-box">🖊</div>
      </div>
      <div class="mb-7">
        <div class="section-label">{t('about.contact')}</div>
        <div class="contact-item">
          <span class="contact-label">GitHub</span>
          <a href="https://github.com/xiatiandeairen" class="contact-value">@xiatiandeairen</a>
        </div>
        <div class="contact-item">
          <span class="contact-label">Email</span>
          <a href="mailto:xiatian_672@163.com" class="contact-value">xiatian_672@163.com</a>
        </div>
        <div class="contact-item">
          <span class="contact-label">RSS</span>
          <a href="/rss.xml" class="contact-value">/rss.xml</a>
        </div>
      </div>
      <div class="mb-7">
        <div class="section-label">{t('about.aboutSite')}</div>
        <p class="colophon">
          使用 Astro 构建<br>
          部署于 GitHub Pages<br>
          字体：Playfair Display + Noto Serif SC + Inter<br>
          设计灵感：传统报纸排版<br>
          2024 年创刊
        </p>
      </div>
    </aside>
  </div>
</BaseLayout>

<style>
  .values-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
    margin: var(--space-5) 0;
  }
</style>

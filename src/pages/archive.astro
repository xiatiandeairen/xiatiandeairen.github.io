---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getAllNotes, sortNotes, formatDate } from '../utils/notes';
import { generatePageMeta } from '../utils/seo';
import { getLang, useT } from '../i18n';

const lang = getLang(Astro.url.pathname);
const t = useT(lang);

const allNotes = getAllNotes();
const sorted = sortNotes(allNotes, 'date', 'desc');
const seo = generatePageMeta({ title: t('archive.title'), description: t('archive.subtitle', { count: allNotes.length }), path: '/archive' });

type MonthGroup = { label: string; notes: typeof sorted };
type YearGroup = { year: string; months: MonthGroup[] };

const yearGroups: YearGroup[] = [];
let currentYear = '';
let currentMonth = '';

for (const note of sorted) {
  const d = new Date(note.date);
  const year = String(d.getFullYear());
  const month = d.toLocaleDateString('zh-CN', { month: 'long' });
  if (year !== currentYear) {
    yearGroups.push({ year, months: [] });
    currentYear = year;
    currentMonth = '';
  }
  if (month !== currentMonth) {
    yearGroups[yearGroups.length - 1].months.push({ label: month, notes: [] });
    currentMonth = month;
  }
  const yg = yearGroups[yearGroups.length - 1];
  yg.months[yg.months.length - 1].notes.push(note);
}

function readingTime(content: string): number {
  return Math.max(1, Math.round(content.replace(/\s+/g, ' ').trim().length / 300));
}

const types = [...new Set(sorted.map(n => n.question.type))].sort();
---

<BaseLayout title={t('archive.title')} seo={seo} lang={lang}>
  <header class="archive-header">
    <h1 class="font-display text-h1 mb-1">{t('archive.title')}</h1>
    <p class="font-sans text-small archive-subtitle">{t('archive.subtitle', { count: allNotes.length })}</p>
  </header>

  <div class="filter-bar">
    <button class="filter-btn active" data-filter="all">{t('archive.all')}</button>
    {types.map(type => (
      <button class="filter-btn" data-filter={type}>{type}</button>
    ))}
  </div>

  <div class="layout-dual-archive">
    <div>
      {yearGroups.map(yg => (
        <div class="year-group">
          <div class="font-display font-black archive-year">{yg.year}</div>
          {yg.months.map(mg => (
            <div class="month-group">
              <div class="month-label font-sans">
                {mg.label} · {mg.notes.length} 篇
              </div>
              {mg.notes.map(note => (
                <a href={`/notes/${note.slug}`} class="archive-item" data-type={note.question.type}>
                  <div>
                    <div class="archive-item-title">{note.title}</div>
                    <div class="cat-label">{note.question.type}</div>
                  </div>
                  <div class="archive-item-meta font-sans">
                    <div>{formatDate(note.date).slice(5)}</div>
                    <div class="archive-item-time">约 {readingTime(note.content)} 分钟</div>
                  </div>
                </a>
              ))}
            </div>
          ))}
        </div>
      ))}
    </div>
    <aside class="sticky top-8 self-start">
      <div class="mb-7">
        <div class="section-label">{t('archive.stats')}</div>
        <div class="stat-row font-sans">
          <span>{t('archive.total')}</span><span class="stat-value">{allNotes.length}</span>
        </div>
      </div>
      <div class="mb-7">
        <div class="section-label">{t('archive.categories')}</div>
        {types.map(type => {
          const count = sorted.filter(n => n.question.type === type).length;
          return (
            <div class="stat-row font-sans">
              <span>{type}</span><span class="stat-value">{count}</span>
            </div>
          );
        })}
      </div>
    </aside>
  </div>

  <script is:inline>
    (function() {
      function applyFilter(filter) {
        document.querySelectorAll('.filter-btn').forEach(function(b) { b.classList.remove('active'); });
        var active = document.querySelector('.filter-btn[data-filter="' + filter + '"]') || document.querySelector('.filter-btn[data-filter="all"]');
        if (active) active.classList.add('active');
        document.querySelectorAll('.archive-item').forEach(function(item) {
          item.style.display = (filter === 'all' || item.dataset.type === filter) ? '' : 'none';
        });
      }
      var initial = new URLSearchParams(window.location.search).get('category') || 'all';
      applyFilter(initial);
      document.querySelectorAll('.filter-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
          var filter = btn.dataset.filter;
          applyFilter(filter);
          var url = new URL(window.location);
          if (filter === 'all') { url.searchParams.delete('category'); } else { url.searchParams.set('category', filter); }
          history.replaceState(null, '', url);
        });
      });
    })();
  </script>
</BaseLayout>

<style>
  .archive-header {
    margin-bottom: var(--space-5);
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--rule-light);
  }
  .archive-subtitle { color: var(--ink-muted); }
  .filter-bar {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-bottom: var(--space-6);
    padding-bottom: var(--space-5);
    border-bottom: 1px solid var(--rule);
  }
  .year-group { margin-bottom: var(--space-7); }
  .archive-year {
    font-size: 42px;
    color: var(--rule);
    opacity: 0.4;
    letter-spacing: -0.03em;
    line-height: 1;
  }
  .month-group { margin-bottom: var(--space-4); }
  .month-label {
    font-size: var(--font-label);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--ink-ghost);
    margin-bottom: var(--space-2);
    padding-bottom: var(--space-1);
    border-bottom: 1px solid var(--rule-light);
  }
  .archive-item-title {
    font-size: var(--font-body);
    font-weight: 600;
    line-height: 1.35;
    color: var(--ink);
  }
  .archive-item-meta {
    font-size: var(--font-caption);
    color: var(--ink-ghost);
    white-space: nowrap;
    padding-top: var(--space-1);
  }
  .archive-item-time {
    font-size: var(--font-label);
    color: var(--ink-ghost);
    margin-top: var(--space-1);
  }
  .stat-row {
    display: flex;
    justify-content: space-between;
    padding: var(--space-1) 0;
    border-bottom: 1px solid var(--rule-faint);
    font-size: var(--font-caption);
    color: var(--ink-muted);
  }
  .stat-value {
    font-weight: 600;
    color: var(--ink);
  }
</style>

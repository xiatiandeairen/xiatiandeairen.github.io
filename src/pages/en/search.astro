---
import IndexLayout from '../../layouts/IndexLayout.astro';
import { generatePageMeta } from '../../utils/seo';
import { useT } from '../../i18n';

const lang = 'en' as const;
const t = useT(lang);
const seo = generatePageMeta({ title: t('search.title'), description: t('search.subtitle'), path: '/en/search' });
const query = Astro.url.searchParams.get('q') || '';
---

<IndexLayout title={t('search.title')} description={t('search.subtitle')} seo={seo} lang={lang}>
  <div class="space-y-6">
    <form method="GET" action="/en/search" class="flex gap-3">
      <input type="text" name="q" value={query} placeholder={t('search.placeholder')} class="flex-1 px-4 py-2.5 border border-rule bg-paper font-serif text-body text-ink placeholder:text-ink-ghost focus:outline-none focus:border-ink transition-colors" autofocus />
      <button type="submit" class="px-5 py-2.5 bg-ink text-paper font-sans text-small font-medium hover:bg-ink-light transition-colors">{t('search.button')}</button>
    </form>
    {query ? (
      <div id="search-results"><p class="font-sans text-small text-ink-muted">{t('search.loading')}</p></div>
    ) : (
      <div class="py-8 border-t border-rule-light">
        <p class="font-sans text-small text-ink-muted mb-3">Supports:</p>
        <ul class="list-disc list-inside space-y-1 font-sans text-small text-ink-muted">
          <li>Title, content, tags, topics, series</li>
          <li>Aliases (tag &amp; topic synonyms)</li>
          <li>Field prefixes: <code>tag:AI</code> · <code>topic:方法论</code> · <code>type:system-design</code> · <code>series:Skills</code></li>
        </ul>
      </div>
    )}
  </div>
  {query && (
    <script is:inline>
      (function() {
        var PREFIX_RE = /\b(tag|topic|type|series|date):([^\s]+)/gi;
        function parseDateSpec(spec) {
          if (!spec) return null;
          var now = new Date(); var m;
          if ((m = spec.match(/^(\d+)d$/))) { var s = new Date(now); s.setDate(s.getDate() - parseInt(m[1])); return { since: s.toISOString(), until: now.toISOString() }; }
          if ((m = spec.match(/^(\d+)y$/))) { var s2 = new Date(now); s2.setFullYear(s2.getFullYear() - parseInt(m[1])); return { since: s2.toISOString(), until: now.toISOString() }; }
          if ((m = spec.match(/^(\d{4})$/))) return { since: m[1] + '-01-01T00:00:00Z', until: m[1] + '-12-31T23:59:59Z' };
          if ((m = spec.match(/^(\d{4})-(\d{2})$/))) {
            var y = parseInt(m[1]), mo = parseInt(m[2]);
            var last = new Date(y, mo, 0).getDate();
            return { since: m[1] + '-' + m[2] + '-01T00:00:00Z', until: m[1] + '-' + m[2] + '-' + String(last).padStart(2,'0') + 'T23:59:59Z' };
          }
          return null;
        }
        function escapeHtml(s) { return String(s).replace(/[&<>"']/g, function(c){ return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]; }); }
        function escapeRe(s) { return s.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'); }
        function highlight(text, term) {
          if (!term) return escapeHtml(text);
          return escapeHtml(text).replace(new RegExp(escapeRe(escapeHtml(term)), 'gi'), '<mark>$&</mark>');
        }
        function parseQuery(raw) {
          var out = { free: '' }; var free = raw || ''; var m;
          PREFIX_RE.lastIndex = 0;
          while ((m = PREFIX_RE.exec(raw || '')) !== null) { out[m[1].toLowerCase()] = m[2].toLowerCase(); free = free.replace(m[0], ''); }
          out.free = free.trim().toLowerCase();
          return out;
        }
        function snippetOf(content, term) {
          if (!content) return ''; if (!term) return content.slice(0, 160);
          var idx = content.toLowerCase().indexOf(term);
          if (idx < 0) return content.slice(0, 160);
          var start = Math.max(0, idx - 60); var end = Math.min(content.length, idx + term.length + 100);
          return (start > 0 ? '…' : '') + content.slice(start, end) + (end < content.length ? '…' : '');
        }
        function searchNotes(rawQuery, index) {
          var q = parseQuery(rawQuery);
          if (!q.free && !q.tag && !q.topic && !q.type && !q.series && !q.date) return [];
          var dateRange = q.date ? parseDateSpec(q.date) : null;
          var hits = [];
          for (var i = 0; i < index.notes.length; i++) {
            var n = index.notes[i];
            if (q.tag) {
              var tHit = n.tags.some(function(t){ return t.toLowerCase().includes(q.tag); });
              var taHit = (n.tagAliases || []).some(function(a){ return a.toLowerCase().includes(q.tag); });
              if (!tHit && !taHit) continue;
            }
            if (q.topic) {
              var tpHit = n.topics.some(function(t){ return t.toLowerCase().includes(q.topic); });
              var tpaHit = (n.topicAliases || []).some(function(a){ return a.toLowerCase().includes(q.topic); });
              if (!tpHit && !tpaHit) continue;
            }
            if (q.type && !(n.questionType || '').toLowerCase().includes(q.type)) continue;
            if (q.series && !((n.series || '').toLowerCase().includes(q.series))) continue;
            if (dateRange && (n.date < dateRange.since || n.date > dateRange.until)) continue;

            var score = 0, matched = 'content', free = q.free;
            if (!free) { score = 50; matched = q.tag ? 'tag' : q.topic ? 'topic' : q.series ? 'series' : q.type ? 'type' : 'content'; }
            else {
              var title = n.title.toLowerCase(); var content = (n.content || '').toLowerCase();
              var tagsLow = n.tags.map(function(t){return t.toLowerCase();});
              var topicsLow = n.topics.map(function(t){return t.toLowerCase();});
              var aliasesLow = ((n.tagAliases || []).concat(n.topicAliases || [])).map(function(a){return a.toLowerCase();});
              var sLow = (n.series || '').toLowerCase();
              if (title === free) { score = 100; matched = 'title'; }
              else if (title.includes(free)) { score = 60; matched = 'title'; }
              else if (tagsLow.indexOf(free) >= 0) { score = 55; matched = 'tag'; }
              else if (topicsLow.indexOf(free) >= 0) { score = 55; matched = 'topic'; }
              else if (sLow === free) { score = 50; matched = 'series'; }
              else if (tagsLow.some(function(t){return t.includes(free);})) { score = 35; matched = 'tag'; }
              else if (topicsLow.some(function(t){return t.includes(free);})) { score = 35; matched = 'topic'; }
              else if (sLow.includes(free)) { score = 30; matched = 'series'; }
              else if (aliasesLow.some(function(a){return a.includes(free);})) { score = 25; matched = 'alias'; }
              else if (content.includes(free)) { score = 10; matched = 'content'; }
              else if (q.tag || q.topic || q.type || q.series) { score = 20; }
              else { continue; }
            }
            hits.push({ note: n, score: score, matchedField: matched, snippet: snippetOf(n.content || '', free || q.tag || q.topic || q.series || q.type || '') });
          }
          hits.sort(function(a, b) { if (b.score !== a.score) return b.score - a.score; return a.note.date < b.note.date ? 1 : a.note.date > b.note.date ? -1 : 0; });
          return hits;
        }

        async function performSearch() {
          var raw = new URLSearchParams(window.location.search).get('q') || '';
          if (!raw.trim()) return;
          var c = document.getElementById('search-results'); if (!c) return;
          try {
            var index = await (await fetch('/search-index.json')).json();
            var hits = searchNotes(raw, index);
            if (!hits.length) { c.innerHTML = '<div class="py-8 text-center"><p class="font-sans text-small text-ink-muted mb-3">No results for "' + escapeHtml(raw) + '"</p><p class="font-sans text-caption text-ink-ghost">Try other terms or prefixes tag:/topic:/type:/series:</p></div>'; return; }
            var parsed = parseQuery(raw);
            var term = parsed.free || parsed.tag || parsed.topic || parsed.series || parsed.type || '';
            var fieldLabel = { title: 'title', tag: 'tag', topic: 'topic', series: 'series', type: 'type', alias: 'alias', content: 'content' };
            c.innerHTML = '<p class="font-sans text-small text-ink-muted mb-4">' + hits.length + ' results found</p><div>' + hits.map(function(h) {
              var label = fieldLabel[h.matchedField] || '';
              return '<a href="/notes/' + h.note.slug + '" class="archive-item">' +
                '<div><div class="archive-item-title">' + highlight(h.note.title, term) + '</div>' +
                '<div class="cat-label">' + (label ? '['+label+'] · ' : '') + new Date(h.note.date).toLocaleDateString('en-US') + '</div></div>' +
                '<div class="archive-item-meta font-sans"><p>' + highlight(h.snippet, term) + '</p></div>' +
              '</a>';
            }).join('') + '</div>';
          } catch(e) { c.innerHTML = '<p class="font-sans text-small text-ink-muted text-center py-8">Search error</p>'; console.error(e); }
        }
        if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', performSearch); else performSearch();
      })();
    </script>
  )}
</IndexLayout>

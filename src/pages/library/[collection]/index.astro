---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollections, getCollectionChapters, LIBRARY_COLLECTIONS } from '../../../utils/library';
import { generatePageMeta } from '../../../utils/seo';
import { getLang } from '../../../i18n';

export async function getStaticPaths() {
  return getCollections().map((c) => ({ params: { collection: c.slug } }));
}

const { collection } = Astro.params;
const lang = getLang(Astro.url.pathname);
const meta = LIBRARY_COLLECTIONS[collection!];
const chapters = getCollectionChapters(collection!);
const seo = generatePageMeta({ title: meta.title, description: meta.description, path: `/library/${collection}` });

function readingMinutes(content: string): number {
  return Math.max(1, Math.round(content.replace(/\s+/g, '').length / 300));
}
const totalMinutes = chapters.reduce((sum, ch) => sum + readingMinutes(ch.content), 0);
---

<BaseLayout title={meta.title} seo={seo} lang={lang}>
  <nav class="library-crumb font-sans" aria-label="breadcrumb">
    <a href="/library">{lang === 'zh' ? '书库' : 'Library'}</a>
    <span aria-hidden="true">/</span>
    <span>{meta.title}</span>
  </nav>

  <header class="collection-header">
    <div class="collection-kicker font-sans">
      {lang === 'zh'
        ? `专题 · ${chapters.length} 章 · 约 ${totalMinutes} 分钟`
        : `Collection · ${chapters.length} chapters · ~${totalMinutes} min`}
    </div>
    <h1 class="collection-title font-display">{meta.title}</h1>
    <p class="collection-desc font-serif">{meta.description}</p>
  </header>

  <ol class="chapter-list">
    {chapters.map((ch) => (
      <li class="chapter-item">
        <a href={`/library/${collection}/${ch.slug}`} class="chapter-link">
          <span class="chapter-order font-sans">{String(ch.order).padStart(2, '0')}</span>
          <span class="chapter-body">
            <span class="chapter-title font-display">{ch.title}</span>
            <span class="chapter-summary font-serif">{ch.summary}</span>
          </span>
          <span class="chapter-min font-sans">{readingMinutes(ch.content)}'</span>
        </a>
      </li>
    ))}
  </ol>
</BaseLayout>

<style>
  .library-crumb { font-size: var(--font-caption); color: var(--ink-muted); margin-bottom: var(--space-4); display: flex; gap: 0.5rem; }
  .library-crumb a { color: var(--ink-muted); text-decoration: none; }
  .library-crumb a:hover { color: var(--ink); }

  .collection-header { margin-bottom: var(--space-6); padding-bottom: var(--space-5); border-bottom: 2px solid var(--ink); }
  .collection-kicker { font-size: var(--font-caption); letter-spacing: 0.06em; text-transform: uppercase; color: var(--ink-muted); margin-bottom: 0.5rem; }
  .collection-title { font-size: var(--font-h1); color: var(--ink); margin-bottom: 0.5rem; }
  .collection-desc { color: var(--ink-light); line-height: 1.7; max-width: 60ch; }

  /* Override base.css `ul, ol { max-width: 65ch }` — that readability cap is for
     prose lists; the chapter index is a full-width layout list. */
  .chapter-list { list-style: none; margin: 0; padding: 0; max-width: none; }
  .chapter-item { border-bottom: 1px solid var(--rule-light); }
  .chapter-link {
    display: grid;
    grid-template-columns: 2.5rem 1fr auto;
    align-items: baseline;
    gap: var(--space-4);
    padding: var(--space-4) 0;
    text-decoration: none;
    transition: background 0.12s;
  }
  .chapter-link:hover { background: var(--bg-subtle); }
  .chapter-order { color: var(--ink-ghost); font-variant-numeric: tabular-nums; }
  .chapter-body { display: flex; flex-direction: column; gap: 0.35rem; min-width: 0; }
  .chapter-title { font-size: var(--font-h3); color: var(--ink); }
  .chapter-link:hover .chapter-title { color: var(--ink-hover); }
  .chapter-summary {
    font-size: var(--font-small);
    color: var(--ink-muted);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .chapter-min { color: var(--ink-ghost); font-size: var(--font-caption); font-variant-numeric: tabular-nums; }
</style>

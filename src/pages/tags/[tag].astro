---
import IndexLayout from '../../layouts/IndexLayout.astro';
import NoteCard from '../../components/NoteCard.astro';
import Pagination from '../../components/Pagination.astro';
import TagHierarchy from '../../components/TagHierarchy.astro';
import { getAllNotes, getNotesByTag, sortNotes, paginateNotes } from '../../utils/notes';
import { resolveTagAlias, getChildTags } from '../../utils/tags';
import { getRelatedTags, getParentTopics } from '../../utils/rank';
import { generatePageMeta } from '../../utils/seo';

export async function getStaticPaths() {
  const allNotes = getAllNotes();
  const tagSet = new Set<string>();

  for (const note of allNotes) {
    for (const tag of note.tags) {
      tagSet.add(tag.name);
      if (tag.alias) {
        tag.alias.forEach(alias => tagSet.add(alias));
      }
    }
  }

  const paths = [];
  for (const tagName of tagSet) {
    const resolvedTag = resolveTagAlias(tagName, allNotes);
    const notes = getNotesByTag(resolvedTag, allNotes);
    const childTags = getChildTags(resolvedTag, allNotes);
    const allTagNotes = [...new Set([...notes, ...childTags.flatMap(child => getNotesByTag(child, allNotes))])];
    const totalPages = Math.ceil(allTagNotes.length / 20);

    for (let page = 1; page <= totalPages; page++) {
      paths.push({ params: { tag: tagName, page: page.toString() } });
    }
    if (totalPages === 0) {
      paths.push({ params: { tag: tagName, page: '1' } });
    }
  }

  return paths.map(({ params }) => {
    const tagName = params.tag;
    const page = parseInt(params.page || '1');
    const resolvedTag = resolveTagAlias(tagName, allNotes);
    const notes = getNotesByTag(resolvedTag, allNotes);
    const childTags = getChildTags(resolvedTag, allNotes);
    const allTagNotes = [...new Set([...notes, ...childTags.flatMap(child => getNotesByTag(child, allNotes))])];
    const sortedNotes = sortNotes(allTagNotes, 'date', 'desc');
    const { notes: paginatedNotes, pagination } = paginateNotes(sortedNotes, page);
    
    const seo = generatePageMeta({
      title: `标签: ${tagName}`,
      description: `标签 "${tagName}" 下的笔记`,
      path: `/tags/${tagName}`
    });

    return {
      params,
      props: {
        tagName: resolvedTag,
        notes: paginatedNotes,
        pagination,
        seo
      }
    };
  });
}

const { tagName, notes, pagination, seo } = Astro.props;
const allNotesForHierarchy = getAllNotes();
const parentTopics = getParentTopics(tagName, allNotesForHierarchy);
const relatedTags = getRelatedTags(tagName, allNotesForHierarchy, 5);
---

<IndexLayout title={`标签: ${tagName}`} seo={seo}>
  <TagHierarchy tagName={tagName} notes={allNotesForHierarchy} />

  {(parentTopics.length > 0 || relatedTags.length > 0) && (
    <div class="tag-bridge">
      {parentTopics.length > 0 && (
        <div class="tag-bridge-row">
          <span class="tag-bridge-label">所属主题</span>
          <div class="tag-bridge-chips">
            {parentTopics.map(topic => (
              <a href={`/topics/${encodeURIComponent(topic)}`} class="bridge-chip bridge-chip-primary">{topic}</a>
            ))}
          </div>
        </div>
      )}
      {relatedTags.length > 0 && (
        <div class="tag-bridge-row">
          <span class="tag-bridge-label">相关标签</span>
          <div class="tag-bridge-chips">
            {relatedTags.map(t => (
              <a href={`/tags/${encodeURIComponent(t.name)}`} class="bridge-chip">{t.name} <span class="bridge-chip-count">{t.count}</span></a>
            ))}
          </div>
        </div>
      )}
    </div>
  )}

  {notes.length === 0 ? (
    <p class="text-text-secondary">该标签下暂无笔记</p>
  ) : (
    <>
      <div class="space-y-4">
        {notes.map((note) => (
          <NoteCard note={note} showQuality={true} />
        ))}
      </div>
      <Pagination
        currentPage={pagination.currentPage}
        totalPages={pagination.totalPages}
        baseUrl={`/tags/${tagName}`}
      />
    </>
  )}
</IndexLayout>

<style>
  .tag-bridge {
    margin-bottom: var(--space-6);
    padding: var(--space-4);
    background: var(--bg-subtle);
    border: 1px solid var(--rule-faint);
    border-radius: var(--radius-md);
    display: grid;
    gap: var(--space-3);
  }
  .tag-bridge-row {
    display: flex;
    align-items: baseline;
    gap: var(--space-3);
    flex-wrap: wrap;
  }
  .tag-bridge-label {
    font-family: Inter, sans-serif;
    font-size: var(--font-label);
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-muted);
    flex-shrink: 0;
  }
  .tag-bridge-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  .bridge-chip {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 2px 10px;
    font-family: Inter, sans-serif;
    font-size: var(--font-caption);
    color: var(--ink-light);
    background: var(--paper);
    border: 1px solid var(--rule-light);
    border-radius: 999px;
    text-decoration: none;
    transition: border-color var(--duration-fast), color var(--duration-fast);
  }
  .bridge-chip:hover {
    color: var(--ink);
    border-color: var(--ink-muted);
  }
  .bridge-chip-primary {
    color: var(--accent);
    border-color: color-mix(in srgb, var(--accent) 30%, transparent);
  }
  .bridge-chip-primary:hover { border-color: var(--accent); }
  .bridge-chip-count {
    font-size: var(--font-xs);
    color: var(--ink-ghost);
  }
</style>

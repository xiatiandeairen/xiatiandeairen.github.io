---
import IndexLayout from '../../layouts/IndexLayout.astro';
import { getAllNotes } from '../../utils/notes';
import { buildTagHierarchy } from '../../utils/tags';
import { generatePageMeta } from '../../utils/seo';

const allNotes = getAllNotes();
const tagHierarchy = buildTagHierarchy(allNotes);
const rootTags = Array.from(tagHierarchy.values())
  .filter(tag => !tag.parent)
  .sort((a, b) => a.name.localeCompare(b.name));

const seo = generatePageMeta({
  title: '标签索引',
  description: '浏览所有标签',
  path: '/tags'
});
---

<IndexLayout title="标签索引" description="按标签浏览笔记。" seo={seo}>
  {rootTags.length === 0 ? (
    <p class="text-ink-muted text-center py-16 font-sans">暂无标签</p>
  ) : (
    <div>
      {rootTags.map((rootTag) => {
        const noteCount = allNotes.filter(note =>
          note.tags.some(tag => tag.name === rootTag.name || tag.parent === rootTag.name)
        ).length;

        return (
          <div>
            <a href={`/tags/${rootTag.name}`} class="archive-item">
              <div>
                <div class="archive-item-title">{rootTag.name}</div>
              </div>
              <div class="archive-item-meta font-sans">
                <span>{noteCount} 篇</span>
              </div>
            </a>

            {rootTag.children.length > 0 && (
              <div class="ml-6">
                {rootTag.children.map((childTag) => {
                  const childNoteCount = allNotes.filter(note =>
                    note.tags.some(tag => tag.name === childTag.name)
                  ).length;

                  return (
                    <a href={`/tags/${childTag.name}`} class="archive-item">
                      <div>
                        <div class="archive-item-title" style="font-weight:400">{childTag.name}</div>
                      </div>
                      <div class="archive-item-meta font-sans">
                        <span>{childNoteCount} 篇</span>
                      </div>
                    </a>
                  );
                })}
              </div>
            )}
          </div>
        );
      })}
    </div>
  )}
</IndexLayout>

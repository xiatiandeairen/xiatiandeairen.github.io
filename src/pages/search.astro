---
import IndexLayout from '../layouts/IndexLayout.astro';
import { generatePageMeta } from '../utils/seo';
import { getLang, useT } from '../i18n';
import type { SearchIndex } from '../utils/search';

const lang = getLang(Astro.url.pathname);
const t = useT(lang);

const seo = generatePageMeta({
  title: t('search.title'),
  description: t('search.subtitle'),
  path: '/search'
});

const query = Astro.url.searchParams.get('q') || '';
---

<IndexLayout title={t('search.title')} description={t('search.subtitle')} seo={seo} lang={lang}>
  <div class="space-y-6">
    <form method="GET" action="/search" class="flex gap-3">
      <input
        type="text"
        name="q"
        value={query}
        placeholder={t('search.placeholder')}
        class="flex-1 px-4 py-2.5 border border-rule bg-paper font-serif text-body text-ink placeholder:text-ink-ghost focus:outline-none focus:border-ink transition-colors"
        autofocus
      />
      <button
        type="submit"
        class="px-5 py-2.5 bg-ink text-paper font-sans text-small font-medium hover:bg-ink-light transition-colors"
      >
        {t('search.button')}
      </button>
    </form>

    {query ? (
      <div id="search-results">
        <p class="font-sans text-small text-ink-muted">{t('search.loading')}</p>
      </div>
    ) : (
      <div class="py-8 border-t border-rule-light">
        <p class="font-sans text-small text-ink-muted mb-3">
          支持搜索：
        </p>
        <ul class="list-disc list-inside space-y-1 font-sans text-small text-ink-muted">
          <li>笔记标题</li>
          <li>笔记内容全文</li>
          <li>标签和主题</li>
        </ul>
      </div>
    )}
  </div>

  {query && (
    <script is:inline>
      (function() {
        async function performSearch() {
          const query = new URLSearchParams(window.location.search).get('q') || '';
          if (!query.trim()) return;

          const resultsContainer = document.getElementById('search-results');
          if (!resultsContainer) return;

          try {
            const response = await fetch('/search-index.json');
            if (!response.ok) {
              throw new Error(`HTTP error! status: ${response.status}`);
            }
            const index = await response.json();

            const searchTerm = query.toLowerCase().trim();
            const results = index.notes.filter(note => {
              const titleMatch = note.title.toLowerCase().includes(searchTerm);
              const contentMatch = note.content.toLowerCase().includes(searchTerm);
              const tagMatch = note.tags.some(tag => tag.toLowerCase().includes(searchTerm));
              const topicMatch = note.topics.some(topic => topic.toLowerCase().includes(searchTerm));
              return titleMatch || contentMatch || tagMatch || topicMatch;
            });

            if (results.length === 0) {
              resultsContainer.innerHTML = '<div class="py-8 text-center"><p class="font-sans text-small text-ink-muted mb-3">未找到「' + query.replace(/</g,'&lt;') + '」的匹配结果</p><p class="font-sans text-caption text-ink-ghost">试试搜索文章标题、标签或内容关键词</p></div>';
              return;
            }

            function highlight(text, term) {
              var re = new RegExp('(' + term.replace(/[.*+?^${}()|[\]\\]/g, '\\$&') + ')', 'gi');
              return text.replace(re, '<mark>$1</mark>');
            }

            resultsContainer.innerHTML = '<p class="font-sans text-small text-ink-muted mb-4">找到 ' + results.length + ' 条结果</p><div>' + results.map(function(note) {
              var escapedTitle = note.title.replace(/</g, '&lt;').replace(/>/g, '&gt;');
              var snippet = note.content.substring(0, 150).replace(/</g, '&lt;').replace(/>/g, '&gt;');
              var dateStr = new Date(note.date).toLocaleDateString('zh-CN');
              var tagsStr = note.tags.length > 0 ? note.tags.join(' · ') : '';
              return '<a href="/notes/' + note.slug + '" class="archive-item"><div><div class="archive-item-title">' + highlight(escapedTitle, searchTerm) + '</div><div class="cat-label">' + dateStr + (tagsStr ? ' · ' + tagsStr : '') + '</div></div><div class="archive-item-meta font-sans"><p>' + highlight(snippet, searchTerm) + (note.content.length > 150 ? '…' : '') + '</p></div></a>';
            }).join('') + '</div>';
          } catch (error) {
            const errorMessage = error instanceof Error ? error.message : String(error);
            resultsContainer.innerHTML = `
              <p class="font-sans text-small text-ink-muted text-center py-8">搜索时发生错误，请稍后重试</p>
              <p class="font-sans text-caption text-ink-ghost text-center mt-2">${errorMessage}</p>
            `;
            console.error('Search error:', error);
          }
        }

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', performSearch);
        } else {
          performSearch();
        }
      })();
    </script>
  )}
</IndexLayout>

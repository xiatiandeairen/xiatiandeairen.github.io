---
import IndexLayout from '../layouts/IndexLayout.astro';
import NoteCard from '../components/NoteCard.astro';
import { generatePageMeta } from '../utils/seo';
import type { SearchIndex } from '../utils/search';

const seo = generatePageMeta({
  title: '搜索',
  description: '搜索技术笔记',
  path: '/search'
});

const query = Astro.url.searchParams.get('q') || '';
---

<IndexLayout title="搜索" seo={seo}>
  <div class="space-y-6">
    <form method="GET" action="/search" class="space-y-4">
      <div class="flex gap-4">
        <input
          type="text"
          name="q"
          value={query}
          placeholder="搜索笔记标题、内容、标签..."
          class="flex-1 px-4 py-3 border border-border rounded-lg focus:outline-none focus:ring-2 focus:ring-link/20 focus:border-link text-body"
          autofocus
        />
        <button
          type="submit"
          class="px-6 py-3 bg-link text-white rounded-lg hover:bg-link-hover transition-colors font-medium"
        >
          搜索
        </button>
      </div>
    </form>

    {query ? (
      <div id="search-results" class="space-y-4">
        <p class="text-text-secondary">正在加载搜索结果...</p>
      </div>
    ) : (
      <div class="p-6 border border-border rounded-lg bg-bg-subtle">
        <p class="text-text-secondary mb-2">
          搜索功能支持：
        </p>
        <ul class="list-disc list-inside space-y-1 text-small text-text-secondary">
          <li>笔记标题搜索</li>
          <li>笔记内容全文搜索</li>
          <li>标签和主题搜索</li>
        </ul>
        <p class="text-text-secondary mt-4 text-small">
          搜索索引文件在构建时自动生成，支持实时搜索功能。
        </p>
      </div>
    )}
  </div>

  {query && (
    <script>
      async function performSearch() {
        const query = new URLSearchParams(window.location.search).get('q') || '';
        if (!query.trim()) return;

        try {
          const response = await fetch('/search-index.json');
          const index: SearchIndex = await response.json();
          
          const searchTerm = query.toLowerCase().trim();
          const results = index.notes.filter(note => {
            const titleMatch = note.title.toLowerCase().includes(searchTerm);
            const contentMatch = note.content.toLowerCase().includes(searchTerm);
            const tagMatch = note.tags.some(tag => tag.toLowerCase().includes(searchTerm));
            const topicMatch = note.topics.some(topic => topic.toLowerCase().includes(searchTerm));
            
            return titleMatch || contentMatch || tagMatch || topicMatch;
          });

          const resultsContainer = document.getElementById('search-results');
          if (!resultsContainer) return;

          if (results.length === 0) {
            resultsContainer.innerHTML = `
              <p class="text-text-secondary text-center py-8">
                未找到匹配的笔记
              </p>
            `;
            return;
          }

          resultsContainer.innerHTML = `
            <p class="text-text-secondary mb-4">
              找到 ${results.length} 条结果
            </p>
            <div class="space-y-4">
              ${results.map(note => `
                <article class="border-b border-border-light pb-4 last:border-b-0">
                  <h3 class="text-h3 mb-2">
                    <a href="/notes/${note.slug}" class="text-link hover:underline">
                      ${note.title}
                    </a>
                  </h3>
                  <p class="text-small text-text-secondary mb-2">
                    ${note.content.substring(0, 150)}${note.content.length > 150 ? '...' : ''}
                  </p>
                  <div class="flex items-center gap-4 text-small text-text-muted">
                    <span>${new Date(note.date).toLocaleDateString('zh-CN')}</span>
                    ${note.tags.length > 0 ? `<span>标签: ${note.tags.join(', ')}</span>` : ''}
                    ${note.topics.length > 0 ? `<span>主题: ${note.topics.join(', ')}</span>` : ''}
                  </div>
                </article>
              `).join('')}
            </div>
          `;
        } catch (error) {
          const resultsContainer = document.getElementById('search-results');
          if (resultsContainer) {
            resultsContainer.innerHTML = `
              <p class="text-text-secondary text-center py-8">
                搜索时发生错误，请稍后重试
              </p>
            `;
          }
          console.error('Search error:', error);
        }
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', performSearch);
      } else {
        performSearch();
      }
    </script>
  )}
</IndexLayout>

---
import IndexLayout from '../layouts/IndexLayout.astro';
import { generatePageMeta } from '../utils/seo';
import { getLang, useT } from '../i18n';

const lang = getLang(Astro.url.pathname);
const t = useT(lang);

const seo = generatePageMeta({
  title: t('search.title'),
  description: t('search.subtitle'),
  path: '/search'
});

const query = Astro.url.searchParams.get('q') || '';
---

<IndexLayout title={t('search.title')} description={t('search.subtitle')} seo={seo} lang={lang}>
  <div class="space-y-6">
    <form method="GET" action="/search" class="flex gap-3">
      <input
        type="text"
        name="q"
        value={query}
        placeholder={t('search.placeholder')}
        class="flex-1 px-4 py-2.5 border border-rule bg-paper font-serif text-body text-ink placeholder:text-ink-ghost focus:outline-none focus:border-ink transition-colors"
        autofocus
      />
      <button
        type="submit"
        class="px-5 py-2.5 bg-ink text-paper font-sans text-small font-medium hover:bg-ink-light transition-colors"
      >
        {t('search.button')}
      </button>
    </form>

    {query ? (
      <div id="search-results">
        <p class="font-sans text-small text-ink-muted">{t('search.loading')}</p>
      </div>
    ) : (
      <div class="py-8 border-t border-rule-light">
        <p class="font-sans text-small text-ink-muted mb-3">支持搜索：</p>
        <ul class="list-disc list-inside space-y-1 font-sans text-small text-ink-muted">
          <li>笔记标题、正文、标签、主题、系列名</li>
          <li>同义词（tag 和 topic 的 alias）</li>
          <li>字段前缀：<code>tag:AI</code> · <code>topic:方法论</code> · <code>type:系统设计</code> · <code>series:Skills</code></li>
        </ul>
      </div>
    )}
  </div>

  {query && (
    <script is:inline>
      (function() {
        var RT = window.SiteRuntime;
        var escapeHtml = RT.escapeHtml;
        var highlight = RT.highlight;
        var parseQuery = RT.parseQuery;
        var searchNotes = RT.searchNotes;

        async function performSearch() {
          var raw = new URLSearchParams(window.location.search).get('q') || '';
          if (!raw.trim()) return;
          var box = document.getElementById('search-results');
          if (!box) return;
          try {
            var index = await (await fetch('/search-index.json')).json();
            RT.indexVersionWarning(index);
            var hits = searchNotes(raw, index);
            if (!hits.length) {
              box.innerHTML = '<div class="py-8 text-center"><p class="font-sans text-small text-ink-muted mb-3">未找到「' + escapeHtml(raw) + '」的匹配结果</p><p class="font-sans text-caption text-ink-ghost">试试其他关键词或用 tag:/topic:/type:/series: 前缀</p></div>';
              return;
            }
            var parsed = parseQuery(raw);
            var term = parsed.free || parsed.tag || parsed.topic || parsed.series || parsed.type || '';
            var fieldLabel = { title: '标题', tag: '标签', topic: '主题', series: '系列', type: '类型', alias: '同义词', content: '正文' };
            box.innerHTML = '<p class="font-sans text-small text-ink-muted mb-4">找到 ' + hits.length + ' 条结果</p><div>' + hits.map(function(h) {
              var tagsStr = h.note.tags.length > 0 ? h.note.tags.join(' · ') : '';
              var dateStr = new Date(h.note.date).toLocaleDateString('zh-CN');
              var label = fieldLabel[h.matchedField] || '';
              return '<a href="/notes/' + h.note.slug + '" class="archive-item">' +
                '<div><div class="archive-item-title">' + highlight(h.note.title, term) + '</div>' +
                '<div class="cat-label">' + (label ? '['+label+'] · ' : '') + dateStr + (tagsStr ? ' · ' + tagsStr : '') + '</div></div>' +
                '<div class="archive-item-meta font-sans"><p>' + highlight(h.snippet, term) + '</p></div>' +
              '</a>';
            }).join('') + '</div>';
          } catch (error) {
            box.innerHTML = '<p class="font-sans text-small text-ink-muted text-center py-8">搜索时发生错误，请稍后重试</p>';
            console.error('Search error:', error);
          }
        }
        if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', performSearch);
        else performSearch();
      })();
    </script>
  )}
</IndexLayout>

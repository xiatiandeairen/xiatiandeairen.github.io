---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import Pagination from '../components/Pagination.astro';
import { getAllNotes, sortNotes, paginateNotes } from '../utils/notes';
import { generatePageMeta } from '../utils/seo';
import { getLang, useT } from '../i18n';

const lang = getLang(Astro.url.pathname);
const t = useT(lang);

const allNotes = getAllNotes();
const sortedNotes = sortNotes(allNotes, 'date', 'desc');
const { notes, pagination } = paginateNotes(sortedNotes, 1);
const seo = generatePageMeta({
  title: t('site.title'),
  description: t('site.tagline'),
  path: '/'
});

const websiteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: '夏天的爱人',
  url: 'https://xiatiandeairen.github.io',
  potentialAction: {
    '@type': 'SearchAction',
    target: 'https://xiatiandeairen.github.io/search?q={search_term_string}',
    'query-input': 'required name=search_term_string',
  },
};

const featuredNote = sortedNotes.find((n: any) => n.featured === true);
const featured = featuredNote || notes[0];
const sidebarNotes = notes.slice(1, 4);
const secondaryNotes = notes.slice(4, 6);
const remainingNotes = notes.slice(6);
---

<BaseLayout title={t('site.title')} description={t('site.tagline')} seo={seo} lang={lang} jsonLd={websiteJsonLd}>
  {notes.length === 0 ? (
    <p class="text-ink-muted text-center py-16 font-sans">{t('common.empty')}</p>
  ) : (
    <>
      <div class="layout-featured">
        <div class="layout-featured-main">
          <ArticleCard note={featured} variant="headline" lang={lang} />
        </div>

        <div class="layout-featured-divider"></div>

        <aside class="layout-featured-side">
          <div class="section-label">{t('article.featured')}</div>
          {sidebarNotes.map((note) => (
            <ArticleCard note={note} variant="sidebar" lang={lang} />
          ))}
        </aside>
        {secondaryNotes.length > 0 && (
          <div class="layout-featured-secondary">
            {secondaryNotes.map((note) => (
              <ArticleCard note={note} variant="secondary" lang={lang} />
            ))}
          </div>
        )}
      </div>

      {remainingNotes.length > 0 && (
        <div class="remaining-section">
          <div class="post-list">
            {remainingNotes.map((note) => (
              <ArticleCard note={note} variant="list" lang={lang} />
            ))}
          </div>
        </div>
      )}

      <Pagination
        currentPage={pagination.currentPage}
        totalPages={pagination.totalPages}
        baseUrl="/"
        lang={lang}
      />
    </>
  )}
</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import NoteCard from '../components/NoteCard.astro';
import Pagination from '../components/Pagination.astro';
import { getAllNotes, sortNotes, paginateNotes } from '../utils/notes';
import { generatePageMeta } from '../utils/seo';
import { SITE_CONFIG } from '../utils/constants';

const allNotes = getAllNotes();
const sortedNotes = sortNotes(allNotes, 'date', 'desc');
const { notes, pagination } = paginateNotes(sortedNotes, 1);
const seo = generatePageMeta({
  title: SITE_CONFIG.title,
  description: SITE_CONFIG.description,
  path: '/'
});

const featured = notes[0];
const sidebarNotes = notes.slice(1, 5);
const remainingNotes = notes.slice(5);

function plainText(content: string): string {
  return content
    .replace(/```[\s\S]*?```/g, '')
    .replace(/`[^`]+`/g, '')
    .replace(/#{1,6}\s/g, '')
    .replace(/\*\*?|__?/g, '')
    .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1')
    .replace(/[<>]/g, '')
    .replace(/\n+/g, ' ')
    .trim();
}
---

<BaseLayout title={SITE_CONFIG.title} description={SITE_CONFIG.description} seo={seo}>
  {notes.length === 0 ? (
    <p class="text-ink-muted text-center py-16 font-sans">暂无笔记</p>
  ) : (
    <>
      <div class="layout-featured">
        <article class="layout-featured-main">
          <div class="cat-label">
            {featured.question.type}
            {featured.question.subType ? ` · ${featured.question.subType}` : ''}
          </div>
          <h2 class="font-display leading-tight ft-heading">
            <a href={`/notes/${featured.slug}`}>{featured.title}</a>
          </h2>
          <p class="featured-lead italic max-w-reading">
            {plainText(featured.content).slice(0, 180)}…
          </p>
          <div class="featured-body font-sans">
            {plainText(featured.content).slice(180, 450)}…
          </div>
          <a href={`/notes/${featured.slug}`} class="featured-link font-sans">
            {'阅读全文 →'}
          </a>
        </article>

        <div class="layout-featured-divider"></div>

        <aside class="layout-featured-side">
          <div class="section-label">近期文章</div>
          {sidebarNotes.map((note) => (
            <div class="sidebar-item">
              <div class="cat-label">{note.question.type}</div>
              <h4 class="sidebar-item-title">
                <a href={`/notes/${note.slug}`}>{note.title}</a>
              </h4>
              <p class="sidebar-item-excerpt font-sans">
                {plainText(note.content).slice(0, 70)}…
              </p>
            </div>
          ))}
        </aside>
      </div>

      {remainingNotes.length > 0 && (
        <div class="remaining-section">
          <div class="section-label">更多文章</div>
          <div class="post-list">
            {remainingNotes.map((note) => (
              <NoteCard note={note} showExcerpt={true} />
            ))}
          </div>
        </div>
      )}

      <Pagination
        currentPage={pagination.currentPage}
        totalPages={pagination.totalPages}
        baseUrl="/"
      />
    </>
  )}
</BaseLayout>

---
import NoteLayout from '../../layouts/NoteLayout.astro';
import MetaFields from '../../components/MetaFields.astro';
import { getAllNotes, sortNotes } from '../../utils/notes';
import { getRelated as rankGetRelated } from '../../utils/rank';
import { generateSEOMeta } from '../../utils/seo';
import { localePath, getLang } from '../../i18n';
import { marked } from 'marked';
import '../../styles/pages/notes.css';

export async function getStaticPaths() {
  function slugify(text: string): string {
    return text.toLowerCase().replace(/[^\w\u4e00-\u9fff]+/g, '-').replace(/^-|-$/g, '');
  }

  function addHeadingIds(html: string): string {
    return html.replace(/<h([23])>([\s\S]*?)<\/h\1>/g, (_, level, inner) => {
      const raw = inner.replace(/<[^>]+>/g, '').replace(/&[^;]+;/g, ' ').trim();
      const id = slugify(raw);
      return `<h${level} id="${id}">${inner}</h${level}>`;
    });
  }

  function extractToc(content: string): { id: string; text: string; level: number }[] {
    const toc: { id: string; text: string; level: number }[] = [];
    const lines = content.split('\n');
    for (const line of lines) {
      const match = line.match(/^(#{2,3})\s+(.+)$/);
      if (match) {
        const text = match[2].replace(/\*\*?|`[^`]+`/g, '').trim();
        const id = slugify(text);
        toc.push({ id, text, level: match[1].length });
      }
    }
    return toc;
  }

  // Multi-signal related: tag + topic + series + question.type weighted overlap.
  // See src/utils/rank.ts for the scoring weights.
  const getRelated = (current: any, allNotes: any[], max: number = 3) =>
    rankGetRelated(current, allNotes, { max });

  const notes = getAllNotes();
  const sortedNotes = sortNotes(notes, 'date', 'desc');

  return notes.map((note) => {
    const seo = generateSEOMeta(note);
    const mode = 'public';
    const contentWithoutH1 = note.content.replace(/^#\s+.+\n*/m, '');
    const htmlContent = addHeadingIds(marked.parse(contentWithoutH1) as string);
    const toc = extractToc(note.content);
    const related = getRelated(note, notes);

    const idx = sortedNotes.findIndex(n => n.slug === note.slug);
    const prevNote = idx < sortedNotes.length - 1 ? sortedNotes[idx + 1] : null;
    const nextNote = idx > 0 ? sortedNotes[idx - 1] : null;

    return {
      params: { slug: note.slug },
      props: { note, htmlContent, seo, mode, prevNote, nextNote, toc, related }
    };
  });
}

const { note, htmlContent, seo, mode, prevNote, nextNote, toc, related } = Astro.props;
const lang = getLang(Astro.url.pathname);
const urlMode = Astro.url.searchParams.get('mode');
const displayMode = urlMode === 'audit' ? 'audit' : mode;

const charCount = note.content.replace(/\s+/g, '').length;
const readingMinutes = Math.max(1, Math.round(charCount / 300));

// Series detection from frontmatter
const series = note.series;
const seriesNotes = series ? getAllNotes()
  .filter((n) => n.series?.name === series.name)
  .sort((a, b) => (a.series?.order || 0) - (b.series?.order || 0))
  : [];
const seriesIndex = seriesNotes.findIndex((n: any) => n.slug === note.slug);
const seriesPrev = seriesIndex > 0 ? seriesNotes[seriesIndex - 1] : null;
const seriesNext = seriesIndex < seriesNotes.length - 1 ? seriesNotes[seriesIndex + 1] : null;

// Topic siblings: parallel to series-continue, surfaces same-topic notes for readers arriving via topic page.
const primaryTopic = note.topics?.[0]?.name ?? null;
const topicSiblings = primaryTopic
  ? getAllNotes()
      .filter((n: any) => n.slug !== note.slug && n.topics?.some((t: any) => t.name === primaryTopic))
      .sort((a: any, b: any) => (a.date < b.date ? 1 : -1))
      .slice(0, 3)
  : [];
const topicTotalCount = primaryTopic
  ? getAllNotes().filter((n: any) => n.topics?.some((t: any) => t.name === primaryTopic)).length
  : 0;

const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: note.title,
  datePublished: note.date,
  description: note.content.slice(0, 160).replace(/\n/g, ' ').trim(),
  author: { '@type': 'Person', name: '夏天的爱人', url: 'https://xiatiandeairen.github.io/about' },
  url: `https://xiatiandeairen.github.io/notes/${note.slug}`,
  // Per-slug OG image generation is v2; use og-default.svg as static fallback.
  image: `https://xiatiandeairen.github.io/og-default.svg`,
};
---

<NoteLayout note={note} seo={seo} mode={displayMode} jsonLd={articleJsonLd}>
  <div class="reading-progress" id="reading-progress"></div>
  <div class="chapter-progress" id="chapter-progress" aria-hidden="true"></div>

  {/* Series banner */}
  {series && (
    <div class="series-banner">
      <span class="series-label font-sans">{'系列文章'}</span>
      <span class="series-name font-serif">{series.name}</span>
      <span class="series-pos font-sans">{`${seriesIndex + 1} / ${seriesNotes.length}`}</span>
    </div>
  )}

  <header class="article-header">
    <div class="article-kicker">{note.question.type}</div>
    <h1 class="article-title font-display">{note.title}</h1>
    <div class="article-dateline" aria-label="article meta">
      {(note.topics.length > 0 || note.tags.length > 0) && (
        <div class="dateline-tax">
          {note.topics.map((topic) => (
            <a href={`/topics/${encodeURIComponent(topic.name)}`} class="taxonomy-link taxonomy-link-primary font-sans">{topic.name}</a>
          ))}
          {note.tags.map((tag) => (
            <a href={`/tags/${encodeURIComponent(tag.name)}`} class="taxonomy-link font-sans">{tag.name}</a>
          ))}
        </div>
      )}
      <div class="dateline-meta">
        <time datetime={note.date}>{new Date(note.date).toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
        <span class="dateline-meta-sep" aria-hidden="true"></span>
        <span>{readingMinutes + ' min read'}</span>
      </div>
    </div>
  </header>

  <article id="article-body" class="prose prose-lg max-w-none
    prose-headings:font-display prose-headings:text-ink prose-headings:font-bold
    prose-h2:text-xl prose-h2:mt-10 prose-h2:mb-3
    prose-h3:text-lg prose-h3:mt-8 prose-h3:mb-2
    prose-p:text-ink-light prose-p:leading-relaxed prose-p:text-body
    prose-strong:text-ink prose-strong:font-semibold
    prose-a:text-ink prose-a:underline prose-a:decoration-rule prose-a:underline-offset-2 hover:prose-a:decoration-ink
    prose-code:text-ink prose-code:bg-bg-subtle prose-code:font-mono prose-code:text-[0.875em]
    prose-pre:bg-bg-subtle prose-pre:border prose-pre:border-rule-light
    prose-blockquote:border-ink prose-blockquote:border-l-3 prose-blockquote:text-ink-light prose-blockquote:italic
    prose-li:text-ink-light prose-li:leading-relaxed"
  >
    <div set:html={htmlContent} />
  </article>

  {/* Mode toggle — left click cycles default → reading → book → default; right click opens menu */}
  <div class="mode-toggle-float">
    <button class="mode-toggle-btn" id="mode-toggle" aria-label="切换阅读形态" aria-haspopup="menu" aria-expanded="false" title="点击：循环切换 · 右键：精确选择">
      <svg class="mode-icon mode-icon-default" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="4" y="3" width="16" height="18" rx="1.5"/><line x1="8" y1="9" x2="16" y2="9"/><line x1="8" y1="13" x2="16" y2="13"/><line x1="8" y1="17" x2="12" y2="17"/></svg>
      <svg class="mode-icon mode-icon-reading" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
      <svg class="mode-icon mode-icon-book" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="8" height="16" rx="1"/><rect x="13" y="4" width="8" height="16" rx="1"/></svg>
    </button>
    <div class="mode-menu" id="mode-menu" role="menu" aria-label="阅读形态" hidden>
      <button class="mode-menu-item" role="menuitem" data-mode="default">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="3" width="16" height="18" rx="1.5"/><line x1="8" y1="9" x2="16" y2="9"/><line x1="8" y1="13" x2="16" y2="13"/><line x1="8" y1="17" x2="12" y2="17"/></svg>
        <span>默认</span>
      </button>
      <button class="mode-menu-item" role="menuitem" data-mode="reading">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
        <span>阅读模式</span>
      </button>
      <button class="mode-menu-item" role="menuitem" data-mode="book">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="8" height="16" rx="1"/><rect x="13" y="4" width="8" height="16" rx="1"/></svg>
        <span>翻页模式</span>
      </button>
    </div>
  </div>

  {/* Typography controls (font size / family / width) */}
  <div class="type-float">
    <button class="type-float-btn" id="type-toggle" aria-label="排版" aria-expanded="false">
      <span class="type-aa">Aa</span>
    </button>
    <div class="type-panel" id="type-panel" role="dialog" aria-label="排版设置">
      <div class="type-row">
        <span class="type-label">字号</span>
        <div class="type-options" data-group="font-size">
          <button class="type-opt" data-value="s" aria-label="小">A<sup>-</sup></button>
          <button class="type-opt" data-value="m" aria-label="中">A</button>
          <button class="type-opt" data-value="l" aria-label="大">A<sup>+</sup></button>
        </div>
      </div>
      <div class="type-row">
        <span class="type-label">字体</span>
        <div class="type-options" data-group="font-family">
          <button class="type-opt type-opt-text serif" data-value="serif">衬线</button>
          <button class="type-opt type-opt-text" data-value="sans">无衬线</button>
        </div>
      </div>
      <div class="type-row">
        <span class="type-label">行宽</span>
        <div class="type-options" data-group="width">
          <button class="type-opt type-opt-text" data-value="narrow">窄</button>
          <button class="type-opt type-opt-text" data-value="default">默认</button>
          <button class="type-opt type-opt-text" data-value="wide">宽</button>
        </div>
      </div>
      <div class="type-row">
        <span class="type-label">进度</span>
        <div class="type-options" data-group="progress">
          <button class="type-opt type-opt-text" data-value="off" id="progress-off">隐藏</button>
          <button class="type-opt type-opt-text" data-value="on" id="progress-on">显示</button>
        </div>
      </div>
    </div>
  </div>

  {/* Floating TOC button + overlay */}
  {toc.length > 0 && (
    <div class="toc-float" id="toc-float">
<button class="toc-float-btn" id="toc-toggle" aria-label="目录">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="15" y2="12"/><line x1="3" y1="18" x2="11" y2="18"/></svg>
      </button>
      <nav class="toc-panel" id="toc-panel">
        <div class="section-label">{'目录'}</div>
        {toc.map((item) => (
          <a
            href={`#${item.id}`}
            class:list={['toc-item', item.level === 3 && 'toc-sub']}
            data-id={item.id}
          >
            {item.text}
          </a>
        ))}
      </nav>
    </div>
  )}

  {/* Related articles */}
  {related.length > 0 && (
    <div class="related-section">
      <div class="section-label">{'相关文章'}</div>
      <div class="related-grid">
        {related.map((r: any) => (
          <a href={`/notes/${r.slug}`} class="related-card">
            <div class="cat-label">{r.question.type}</div>
            <div class="related-card-title font-serif">{r.title}</div>
          </a>
        ))}
      </div>
    </div>
  )}

  {/* Comments (giscus) */}
  <section class="giscus-section" id="comments">
    <div class="section-label">评论</div>
    <div class="giscus-hint">
      使用 GitHub 账号登录即可留言。表情、回复均支持。
    </div>
    <div class="giscus-container">
      <script
        src="https://giscus.app/client.js"
        data-repo="xiatiandeairen/xiatiandeairen.github.io"
        data-repo-id="R_kgDONiKBwA"
        data-category="Announcements"
        data-category-id="DIC_kwDONiKBwM4C7GHk"
        data-mapping="pathname"
        data-strict="0"
        data-reactions-enabled="1"
        data-emit-metadata="0"
        data-input-position="top"
        data-theme="https://xiatiandeairen.github.io/giscus-light.css"
        data-lang="zh-CN"
        data-loading="lazy"
        crossorigin="anonymous"
        async
      ></script>
    </div>
  </section>

  {/* Series continue block: progress + remaining + next-card emphasis */}
  {series && seriesNotes.length > 1 && (
    <section class="series-continue" aria-label="系列阅读">
      <header class="series-continue-head">
        <div class="series-continue-meta">
          <span class="series-continue-label">系列 · {series.name}</span>
          <span class="series-continue-progress">{(seriesIndex + 1) + ' / ' + seriesNotes.length}</span>
        </div>
        <div class="series-continue-bar" aria-hidden="true">
          <span style={`width:${((seriesIndex + 1) / seriesNotes.length) * 100}%`}></span>
        </div>
      </header>
      {seriesNext && (
        <a href={`/notes/${seriesNext.slug}`} class="series-continue-next">
          <div class="series-continue-tag">下一篇 · 第 {seriesIndex + 2} 篇 →</div>
          <div class="series-continue-title font-serif">{seriesNext.title}</div>
        </a>
      )}
      {seriesNotes.length - (seriesIndex + 1) > 1 && (
        <div class="series-continue-remaining">系列剩余 {seriesNotes.length - (seriesIndex + 1)} 篇 · <a href={localePath('/series', lang)}>查看全部</a></div>
      )}
      {seriesPrev && !seriesNext && (
        <a href={`/notes/${seriesPrev.slug}`} class="series-continue-next">
          <div class="series-continue-tag">← 上一篇 · 第 {seriesIndex} 篇</div>
          <div class="series-continue-title font-serif">{seriesPrev.title}</div>
        </a>
      )}
    </section>
  )}

  {/* Topic continue block: parallel to series-continue; shown when note has a primary topic with siblings */}
  {primaryTopic && topicSiblings.length > 0 && (
    <section class="series-continue topic-continue" aria-label="主题阅读">
      <header class="series-continue-head">
        <div class="series-continue-meta">
          <span class="series-continue-label">主题 · {primaryTopic}</span>
          <span class="series-continue-progress">{topicTotalCount} 篇</span>
        </div>
      </header>
      {topicSiblings.map((s: any) => (
        <a href={`/notes/${s.slug}`} class="series-continue-next">
          <div class="series-continue-tag">同主题 →</div>
          <div class="series-continue-title font-serif">{s.title}</div>
        </a>
      ))}
      <div class="series-continue-remaining">
        <a href={localePath(`/topics/${primaryTopic}`, lang)}>查看主题全部 {topicTotalCount} 篇 →</a>
      </div>
    </section>
  )}

  {/* Series navigation (compact prev/next) */}
  {series && (seriesPrev || seriesNext) && (
    <nav class="series-nav" aria-label="系列导航">
      {seriesPrev ? (
        <a href={`/notes/${seriesPrev.slug}`} class="series-nav-link">
          <div class="cat-label">{'← 上一篇 · ' + series.name}</div>
          <div class="series-nav-title font-serif">{seriesPrev.title}</div>
        </a>
      ) : <div />}
      {seriesNext ? (
        <a href={`/notes/${seriesNext.slug}`} class="series-nav-link series-nav-next">
          <div class="cat-label">{series.name + ' · 下一篇 →'}</div>
          <div class="series-nav-title font-serif">{seriesNext.title}</div>
        </a>
      ) : <div />}
    </nav>
  )}

  {/* Prev / Next navigation (skipped when series nav already covers it) */}
  {!series && (prevNote || nextNote) && (
    <nav class="grid grid-cols-2 gap-6 mt-8 pt-6 border-t border-rule" aria-label="文章导航">
      {prevNote ? (
        <a href={`/notes/${prevNote.slug}`} class="no-underline group">
          <div class="cat-label">{'← 上一篇'}</div>
          <div class="font-serif text-h3 group-hover:text-link-hover transition-colors prev-next-title">{prevNote.title}</div>
        </a>
      ) : <div />}
      {nextNote ? (
        <a href={`/notes/${nextNote.slug}`} class="no-underline text-right group">
          <div class="cat-label">{'下一篇 →'}</div>
          <div class="font-serif text-h3 group-hover:text-link-hover transition-colors prev-next-title">{nextNote.title}</div>
        </a>
      ) : <div />}
    </nav>
  )}

  <a href="#main-content" class="back-to-top">{'回到顶部 ↑'}</a>

  {/* Source-context: prefer sessionStorage (set by upstream pages on click), fall back to document.referrer for direct same-tab nav.
      Cleared after read so a refresh / direct visit reverts to default rendering. */}
  <script is:inline>
    (function () {
      var html = document.documentElement;
      var ctx = null;
      try { ctx = sessionStorage.getItem('entryContext'); } catch (e) {}
      if (!ctx) {
        var ref = document.referrer;
        if (ref) {
          try {
            var u = new URL(ref);
            if (u.origin === location.origin) {
              if (u.pathname.indexOf('/topics/') === 0) ctx = 'topic';
              else if (u.pathname.indexOf('/series') === 0) ctx = 'series';
              else if (u.pathname.indexOf('/tags/') === 0) ctx = 'tag';
            }
          } catch (e) {}
        }
      }
      if (ctx) {
        html.dataset.sourceContext = ctx;
        try { sessionStorage.removeItem('entryContext'); } catch (e) {}
      }
    })();
  </script>

  {/* Book mode page indicator (only visible when data-article-layout="columns") */}
  <div class="book-page-indicator" id="book-page-indicator" aria-hidden="true">1 / 1</div>

  {/* Resume-reading toast (populated by JS if saved position exists) */}
  <div class="resume-toast" id="resume-toast" role="status" aria-live="polite">
    <span id="resume-toast-label">继续上次阅读</span>
    <button class="resume-toast-btn" id="resume-toast-go">继续</button>
    <button class="resume-toast-dismiss" id="resume-toast-close" aria-label="忽略">×</button>
  </div>


  <script is:inline>
    (function() {
      // Typography controls (font-size / font-family / width / progress)
      var TYPE_KEYS = { 'font-size': { default: 'm', attr: 'data-font-size' },
                        'font-family': { default: 'serif', attr: 'data-font-family' },
                        'width': { default: 'default', attr: 'data-width' },
                        'progress': { default: 'off', attr: 'data-reading-progress' } };
      function applyType(group, value) {
        var conf = TYPE_KEYS[group];
        if (!conf) return;
        document.documentElement.setAttribute(conf.attr, value);
        try { localStorage.setItem('type.' + group, value); } catch (e) {}
        var opts = document.querySelectorAll('.type-options[data-group="' + group + '"] .type-opt');
        opts.forEach(function(o) { o.classList.toggle('active', o.getAttribute('data-value') === value); });
      }
      Object.keys(TYPE_KEYS).forEach(function(group) {
        var stored;
        try { stored = localStorage.getItem('type.' + group); } catch (e) {}
        applyType(group, stored || TYPE_KEYS[group].default);
      });
      document.querySelectorAll('.type-options .type-opt').forEach(function(btn) {
        btn.addEventListener('click', function() {
          var group = btn.parentElement.getAttribute('data-group');
          var value = btn.getAttribute('data-value');
          applyType(group, value);
        });
      });
      var typeToggle = document.getElementById('type-toggle');
      var typePanel = document.getElementById('type-panel');
      if (typeToggle && typePanel) {
        typeToggle.addEventListener('click', function(e) {
          e.stopPropagation();
          var open = typePanel.classList.toggle('open');
          typeToggle.setAttribute('aria-expanded', open ? 'true' : 'false');
        });
        document.addEventListener('click', function(e) {
          if (typePanel.classList.contains('open') && !typePanel.contains(e.target) && e.target !== typeToggle) {
            typePanel.classList.remove('open');
            typeToggle.setAttribute('aria-expanded', 'false');
          }
        });
      }

      // Page mode registry — presets compose orthogonal capability attrs.
      // Add a new mode by: (1) defining preset here, (2) adding capability rules in CSS (no new mode-named selectors needed).
      var MODE_PRESETS = {
        'default': { 'chrome': 'visible', 'typography-controls': 'off', 'reading-progress': 'off', 'article-layout': 'flow' },
        'reading': { 'chrome': 'hidden',  'typography-controls': 'on',  'reading-progress': 'on',  'article-layout': 'flow' },
        'book':    { 'chrome': 'hidden',  'typography-controls': 'on',  'reading-progress': 'off', 'article-layout': 'columns' }
      };
      // MODE_ORDER derived from MODE_PRESETS — adding a new mode requires only a single edit above.
      var MODE_ORDER = Object.keys(MODE_PRESETS);
      var modeToggle = document.getElementById('mode-toggle');
      var modeMenu = document.getElementById('mode-menu');
      // (MODE_ORDER derived from MODE_PRESETS above)
      function applyMode(name) {
        var preset = MODE_PRESETS[name] || MODE_PRESETS['default'];
        var html = document.documentElement;
        html.setAttribute('data-mode', name);
        Object.keys(preset).forEach(function(k) {
          // reading-progress is user-controlled via #progress-toggle; don't let mode preset override stored preference.
          if (k === 'reading-progress') return;
          html.setAttribute('data-' + k, preset[k]);
        });
        if (modeMenu) {
          modeMenu.querySelectorAll('.mode-menu-item[data-mode]').forEach(function(item) {
            item.setAttribute('aria-current', item.getAttribute('data-mode') === name ? 'true' : 'false');
          });
        }
        if (modeToggle) {
          modeToggle.setAttribute('aria-label', '当前：' + name + ' · 点击循环切换 · 右键精确选择');
        }
        try { localStorage.setItem('mode', name); } catch (e) {}
      }
      (function initMode() {
        var saved;
        try { saved = localStorage.getItem('mode'); } catch (e) {}
        if (!saved) {
          // migrate legacy flag
          try { saved = localStorage.getItem('readingMode') === '1' ? 'reading' : 'default'; } catch (e) { saved = 'default'; }
        }
        applyMode(MODE_PRESETS[saved] ? saved : 'default');
      })();
      function modeMenuOpen() {
        if (modeMenu) modeMenu.hidden = false;
        if (modeToggle) modeToggle.setAttribute('aria-expanded', 'true');
      }
      function modeMenuClose() {
        if (modeMenu) modeMenu.hidden = true;
        if (modeToggle) modeToggle.setAttribute('aria-expanded', 'false');
      }
      if (modeToggle) {
        // Left click cycles
        modeToggle.addEventListener('click', function(e) {
          e.stopPropagation();
          var current = document.documentElement.getAttribute('data-mode') || 'default';
          var idx = MODE_ORDER.indexOf(current);
          if (idx < 0) idx = 0;
          applyMode(MODE_ORDER[(idx + 1) % MODE_ORDER.length]);
          modeMenuClose();
        });
        // Right click opens menu
        modeToggle.addEventListener('contextmenu', function(e) {
          e.preventDefault();
          e.stopPropagation();
          if (modeMenu && modeMenu.hidden) modeMenuOpen(); else modeMenuClose();
        });
        // Long press for touch devices
        var longPressTimer = null;
        modeToggle.addEventListener('touchstart', function() {
          longPressTimer = setTimeout(modeMenuOpen, 500);
        }, { passive: true });
        modeToggle.addEventListener('touchend', function() { clearTimeout(longPressTimer); }, { passive: true });
      }
      if (modeMenu) {
        modeMenu.querySelectorAll('.mode-menu-item').forEach(function(item) {
          item.addEventListener('click', function(e) {
            e.stopPropagation();
            applyMode(item.getAttribute('data-mode'));
            modeMenuClose();
          });
        });
        document.addEventListener('click', function(e) {
          if (!modeMenu.hidden && !modeMenu.contains(e.target) && e.target !== modeToggle && !modeToggle.contains(e.target)) {
            modeMenuClose();
          }
        });
      }

      // ── Book mode (pagination) ──
      var articleBody = document.getElementById('article-body');
      var bookSpread = 0;
      var bookMaxSpread = 0;
      var bookPosKey = 'book-pos:' + location.pathname;

      function bookInColumns() {
        return document.documentElement.getAttribute('data-article-layout') === 'columns';
      }
      function bookUpdateMetrics() {
        if (!bookInColumns() || !articleBody) return;
        var W = articleBody.clientWidth;
        if (!W) return;
        var total = articleBody.scrollWidth;
        bookMaxSpread = Math.max(0, Math.ceil(total / W) - 1);
        if (bookSpread > bookMaxSpread) bookSpread = bookMaxSpread;
        bookApply();
      }
      function bookApply() {
        if (!articleBody) return;
        var W = articleBody.clientWidth;
        // Round to integer pixel to avoid sub-pixel column drift
        articleBody.style.setProperty('--book-offset', Math.round(-bookSpread * W) + 'px');
        var ind = document.getElementById('book-page-indicator');
        if (ind) ind.textContent = (bookSpread + 1) + ' / ' + (bookMaxSpread + 1);
        try { localStorage.setItem(bookPosKey, String(bookSpread)); } catch (e) {}
      }
      function bookNext() { if (bookSpread < bookMaxSpread) { bookSpread++; bookApply(); } }
      function bookPrev() { if (bookSpread > 0) { bookSpread--; bookApply(); } }
      function bookFirst() { bookSpread = 0; bookApply(); }
      function bookLast() { bookSpread = bookMaxSpread; bookApply(); }
      function bookEnter() {
        try { bookSpread = parseInt(localStorage.getItem(bookPosKey) || '0', 10) || 0; } catch (e) { bookSpread = 0; }
        // Defer one frame so layout settles after mode attrs applied
        requestAnimationFrame(function() { requestAnimationFrame(bookUpdateMetrics); });
      }

      // Touch swipe (mobile): swipe left → next, right → prev. Threshold 60px, vertical guard.
      (function bindBookSwipe() {
        if (!articleBody) return;
        var startX = 0, startY = 0, tracking = false;
        articleBody.addEventListener('touchstart', function(e) {
          if (!bookInColumns() || e.touches.length !== 1) return;
          startX = e.touches[0].clientX; startY = e.touches[0].clientY; tracking = true;
        }, { passive: true });
        articleBody.addEventListener('touchend', function(e) {
          if (!tracking || !bookInColumns()) { tracking = false; return; }
          tracking = false;
          var t = e.changedTouches[0]; if (!t) return;
          var dx = t.clientX - startX, dy = t.clientY - startY;
          if (Math.abs(dx) < 60 || Math.abs(dy) > Math.abs(dx)) return; // not a horizontal swipe
          if (dx < 0) bookNext(); else bookPrev();
        }, { passive: true });
      })();

      // Observe data-article-layout changes to trigger (re)measure
      new MutationObserver(function(muts) {
        muts.forEach(function(m) {
          if (m.attributeName === 'data-article-layout') {
            if (bookInColumns()) bookEnter();
          }
          if (m.attributeName === 'data-font-size' || m.attributeName === 'data-font-family' || m.attributeName === 'data-width') {
            if (bookInColumns()) requestAnimationFrame(bookUpdateMetrics);
          }
        });
      }).observe(document.documentElement, { attributes: true });

      window.addEventListener('resize', function() {
        if (bookInColumns()) setTimeout(bookUpdateMetrics, 50);
      });

      // If already in book mode on load, initialize
      if (bookInColumns()) bookEnter();

      /* keydownDispatcher — single document-level keydown listener.
         Avoids prior multi-listener priority bugs (e.g. g/G collision in book mode).
         Order matters: mode keys → menu/Esc → book nav → flow nav → r (reading toggle). */
      function keydownDispatcher(e) {
        if (e.ctrlKey || e.metaKey || e.altKey) return;
        var tag = (e.target && e.target.tagName) || '';
        if (tag === 'INPUT' || tag === 'TEXTAREA' || (e.target && e.target.isContentEditable)) return;
        var current = document.documentElement.getAttribute('data-mode') || 'default';

        // 1. Mode-menu close (Esc takes priority over mode exit)
        if (e.key === 'Escape') {
          if (modeMenu && !modeMenu.hidden) { modeMenuClose(); e.preventDefault(); return; }
          if (current === 'book') { applyMode('default'); e.preventDefault(); return; }
        }

        // 2. Mode toggle keys
        if (e.key === 'r' || e.key === 'R') {
          applyMode(current === 'reading' ? 'default' : 'reading'); e.preventDefault(); return;
        }
        if (e.key === 'b' || e.key === 'B') {
          applyMode(current === 'book' ? 'default' : 'book'); e.preventDefault(); return;
        }

        // 3. Book mode owns nav keys when paginated
        if (bookInColumns()) {
          if (e.key === 'ArrowRight' || e.key === 'PageDown' || e.key === ' ') { bookNext(); e.preventDefault(); return; }
          if (e.key === 'ArrowLeft' || e.key === 'PageUp') { bookPrev(); e.preventDefault(); return; }
          if (e.key === 'Home' || e.key === 'g') { bookFirst(); e.preventDefault(); return; }
          if (e.key === 'End' || e.key === 'G') { bookLast(); e.preventDefault(); return; }
          return; // swallow other keys in book mode to prevent flow handler
        }

        // 4. Flow mode navigation (default + reading)
        var pageStep = window.innerHeight * 0.9;
        if (e.key === ' ' || e.key === 'PageDown') { window.scrollBy({ top: pageStep, behavior: 'smooth' }); e.preventDefault(); }
        else if (e.key === 'PageUp' || (e.key === ' ' && e.shiftKey)) { window.scrollBy({ top: -pageStep, behavior: 'smooth' }); e.preventDefault(); }
        else if (e.key === 'g' || e.key === 'Home') { window.scrollTo({ top: 0, behavior: 'smooth' }); e.preventDefault(); }
        else if (e.key === 'G' || e.key === 'End') { window.scrollTo({ top: document.documentElement.scrollHeight, behavior: 'smooth' }); e.preventDefault(); }
        else if (e.key === 'n' || e.key === 'p') {
          var hs = Array.prototype.slice.call(document.querySelectorAll('#article-body h2, #article-body h3'));
          if (!hs.length) return;
          var y = window.scrollY + 80;
          var idx = -1;
          for (var i = 0; i < hs.length; i++) { if (hs[i].offsetTop <= y) idx = i; }
          var next = e.key === 'n' ? idx + 1 : idx - 1;
          if (next >= 0 && next < hs.length) {
            window.scrollTo({ top: hs[next].offsetTop - 60, behavior: 'smooth' });
            e.preventDefault();
          }
        }
      }
      document.addEventListener('keydown', keydownDispatcher);

      // Reading progress (single bar fallback)
      var bar = document.getElementById('reading-progress');
      if (bar) {
        window.addEventListener('scroll', function() {
          var h = document.documentElement.scrollHeight - window.innerHeight;
          if (h > 0) bar.style.width = (window.scrollY / h * 100) + '%';
        }, { passive: true });
      }

      // Chapter progress: segmented bar by h2 boundaries
      (function setupChapterProgress() {
        var container = document.getElementById('chapter-progress');
        var bodyEl = document.getElementById('article-body');
        if (!container || !bodyEl) return;
        var headings = Array.prototype.slice.call(bodyEl.querySelectorAll('h2'));
        if (!headings.length) return;

        // Compute segments: each section spans from its h2 to next h2 (or end).
        var bodyTop = bodyEl.getBoundingClientRect().top + window.scrollY;
        var bodyBottom = bodyTop + bodyEl.offsetHeight;
        var sections = headings.map(function(h, i) {
          var start = h.getBoundingClientRect().top + window.scrollY;
          var end = (i < headings.length - 1)
            ? headings[i + 1].getBoundingClientRect().top + window.scrollY
            : bodyBottom;
          return { id: h.id, title: h.textContent || '', start: start, end: end };
        });
        // Prepend implicit intro section (article top → first h2)
        if (sections.length && sections[0].start > bodyTop + 50) {
          sections.unshift({ id: '', title: '引言', start: bodyTop, end: sections[0].start });
        }
        var totalLen = sections.reduce(function(s, x){ return s + (x.end - x.start); }, 0);
        if (totalLen <= 0) return;

        // Render segments
        container.innerHTML = sections.map(function(s) {
          var ratio = (s.end - s.start) / totalLen;
          var anchor = s.id ? ('#' + s.id) : '';
          return '<a class="cp-seg" href="' + anchor + '" data-start="' + s.start + '" data-end="' + s.end + '" style="flex: ' + ratio.toFixed(4) + '" title="' + s.title.replace(/"/g, '&quot;') + '"><span class="cp-fill"></span><span class="cp-label">0%</span></a>';
        }).join('');
        var segs = container.querySelectorAll('.cp-seg');

        function updateProgress() {
          var y = window.scrollY + window.innerHeight * 0.4; // reader's eye
          for (var i = 0; i < sections.length; i++) {
            var s = sections[i], seg = segs[i];
            if (!seg) continue;
            var fill;
            if (y <= s.start) fill = 0;
            else if (y >= s.end) fill = 100;
            else fill = ((y - s.start) / (s.end - s.start)) * 100;
            seg.style.setProperty('--fill', fill + '%');
            seg.classList.toggle('cp-current', y > s.start && y < s.end);
            seg.classList.toggle('cp-done', y >= s.end);
            var label = seg.querySelector('.cp-label');
            if (label) label.textContent = Math.round(fill) + '%';
          }
        }
        window.addEventListener('scroll', updateProgress, { passive: true });
        window.addEventListener('resize', function() {
          // Recompute section bounds
          for (var i = 0; i < sections.length; i++) {
            if (!sections[i].id) continue;
            var el = document.getElementById(sections[i].id);
            if (el) {
              sections[i].start = el.getBoundingClientRect().top + window.scrollY;
              sections[i].end = (i < sections.length - 1 && sections[i+1].id)
                ? document.getElementById(sections[i+1].id).getBoundingClientRect().top + window.scrollY
                : (bodyEl.getBoundingClientRect().top + window.scrollY + bodyEl.offsetHeight);
            }
          }
          updateProgress();
        });
        updateProgress();
      })();

      // Giscus theme sync on toggle — custom paper-matched themes
      var giscusThemeUrl = function() {
        var isDark = document.documentElement.classList.contains('dark');
        return isDark
          ? 'https://xiatiandeairen.github.io/giscus-dark.css'
          : 'https://xiatiandeairen.github.io/giscus-light.css';
      };
      var observer = new MutationObserver(function() {
        var iframe = document.querySelector('iframe.giscus-frame');
        if (iframe) {
          iframe.contentWindow.postMessage({ giscus: { setConfig: { theme: giscusThemeUrl() } } }, 'https://giscus.app');
        }
      });
      observer.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });

      // TOC toggle
      var tocToggle = document.getElementById('toc-toggle');
      var tocPanel = document.getElementById('toc-panel');
      if (tocToggle && tocPanel) {
        tocToggle.addEventListener('click', function(e) {
          e.stopPropagation();
          tocPanel.classList.toggle('open');
        });
        document.addEventListener('click', function(e) {
          if (tocPanel.classList.contains('open') && !tocPanel.contains(e.target)) {
            tocPanel.classList.remove('open');
          }
        });
        tocPanel.querySelectorAll('a').forEach(function(a) {
          a.addEventListener('click', function(e) {
            tocPanel.classList.remove('open');
            var id = (a.getAttribute('href') || '').slice(1);
            var heading = id ? document.getElementById(id) : null;
            if (!heading) return;
            // In book mode, translate scroll target into spread index.
            if (bookInColumns()) {
              e.preventDefault();
              var ab = document.getElementById('article-body');
              if (ab && typeof bookSpread !== 'undefined') {
                var W = ab.clientWidth;
                if (W) {
                  // Remove transform temporarily to measure heading's natural offsetLeft
                  var prevTransform = ab.style.transform;
                  ab.style.transition = 'none';
                  ab.style.transform = 'translateX(0px)';
                  void ab.offsetWidth;
                  var headingLeft = heading.getBoundingClientRect().left + window.scrollX - ab.getBoundingClientRect().left;
                  ab.style.transition = '';
                  ab.style.transform = prevTransform;
                  void ab.offsetWidth;
                  bookSpread = Math.max(0, Math.min(bookMaxSpread, Math.floor(headingLeft / W)));
                  bookApply();
                }
              }
            }
            heading.classList.remove('toc-target');
            void heading.offsetWidth;
            heading.classList.add('toc-target');
            setTimeout(function() { heading.classList.remove('toc-target'); }, 2400);
          });
        });
      }

      // Article-scoped shortcut help lives in ShortcutsHelp.astro static markup —
      // visible on every page so readers know r/b exist before opening an article.

      // Idle fade — dim floats after 2s of inactivity
      var idleTimer = null;
      function setIdle(v) { document.documentElement.setAttribute('data-idle', v ? 'true' : 'false'); }
      function bumpIdle() {
        setIdle(false);
        clearTimeout(idleTimer);
        idleTimer = setTimeout(function() { setIdle(true); }, 2000);
      }
      ['mousemove', 'scroll', 'keydown', 'touchstart', 'wheel'].forEach(function(ev) {
        window.addEventListener(ev, bumpIdle, { passive: true });
      });
      bumpIdle();

      // (flow-mode nav merged into keydownDispatcher above — single document-level listener)

      // Track visit for "最近浏览" widget (localStorage FIFO max 5)
      (function trackVisit() {
        try {
          var key = 'recentlyViewed';
          var slug = location.pathname.replace(/^\/notes\//, '').replace(/\/$/, '');
          var titleEl = document.querySelector('.article-title');
          var entry = { slug: slug, title: titleEl ? titleEl.textContent.trim() : slug, ts: Date.now() };
          var list;
          try { list = JSON.parse(localStorage.getItem(key) || '[]'); } catch (e) { list = []; }
          list = list.filter(function(x) { return x.slug !== slug; });
          list.unshift(entry);
          list = list.slice(0, 5);
          localStorage.setItem(key, JSON.stringify(list));
        } catch (e) {}
      })();

      // Resume reading position (per-slug, saved on scroll-idle)
      var posKey = 'read-pos:' + location.pathname;
      var posSaveTimer = null;
      window.addEventListener('scroll', function() {
        clearTimeout(posSaveTimer);
        posSaveTimer = setTimeout(function() {
          try { localStorage.setItem(posKey, String(Math.round(window.scrollY))); } catch (e) {}
        }, 400);
      }, { passive: true });
      (function showResumeToast() {
        var saved;
        try { saved = parseInt(localStorage.getItem(posKey) || '0', 10); } catch (e) { return; }
        if (!saved || saved < 200 || window.scrollY > 100) return;
        var toast = document.getElementById('resume-toast');
        var goBtn = document.getElementById('resume-toast-go');
        var closeBtn = document.getElementById('resume-toast-close');
        var label = document.getElementById('resume-toast-label');
        if (!toast || !goBtn || !closeBtn) return;
        var docH = document.documentElement.scrollHeight - window.innerHeight;
        var pct = docH > 0 ? Math.round((saved / docH) * 100) : 0;
        if (label) label.textContent = '继续上次阅读（' + pct + '%）';
        toast.classList.add('show');
        var dismissTimer = setTimeout(function() { toast.classList.remove('show'); }, 10000);
        goBtn.addEventListener('click', function() {
          clearTimeout(dismissTimer);
          window.scrollTo({ top: saved, behavior: 'smooth' });
          toast.classList.remove('show');
        });
        closeBtn.addEventListener('click', function() {
          clearTimeout(dismissTimer);
          toast.classList.remove('show');
        });
      })();

      // TOC scroll spy
      var tocItems = document.querySelectorAll('.toc-item');
      if (tocItems.length === 0) return;
      var headings = [];
      tocItems.forEach(function(item) {
        var id = item.getAttribute('data-id');
        var el = document.getElementById(id);
        if (el) headings.push({ el: el, item: item });
      });
      if (headings.length === 0) return;

      var current = null;
      function updateToc() {
        var scrollY = window.scrollY + 100;
        var active = headings[0];
        for (var i = 0; i < headings.length; i++) {
          if (headings[i].el.offsetTop <= scrollY) active = headings[i];
        }
        if (active && active !== current) {
          if (current) current.item.classList.remove('active');
          active.item.classList.add('active');
          current = active;
        }
      }
      window.addEventListener('scroll', updateToc, { passive: true });
      updateToc();

      // Code block copy buttons
      document.querySelectorAll('pre').forEach(function(pre) {
        var code = pre.querySelector('code');
        if (!code) return;
        var wrapper = document.createElement('div');
        wrapper.style.cssText = 'position:relative;';
        pre.parentNode.insertBefore(wrapper, pre);
        wrapper.appendChild(pre);

        var btn = document.createElement('button');
        btn.textContent = '复制';
        btn.style.cssText = 'position:absolute;top:8px;right:8px;padding:3px 10px;font-family:Inter,sans-serif;font-size:11px;background:var(--rule-light);color:var(--ink-muted);border:1px solid var(--rule);border-radius:3px;cursor:pointer;opacity:0;transition:opacity 0.15s;z-index:1;';
        wrapper.appendChild(btn);

        wrapper.addEventListener('mouseenter', function() { btn.style.opacity = '1'; });
        wrapper.addEventListener('mouseleave', function() { btn.style.opacity = '0'; });

        btn.addEventListener('click', function() {
          navigator.clipboard.writeText(code.textContent || '').then(function() {
            btn.textContent = '已复制';
            setTimeout(function() { btn.textContent = '复制'; }, 2000);
          });
        });
      });
    })();
  </script>
</NoteLayout>

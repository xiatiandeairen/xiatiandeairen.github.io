        return isDark
          ? 'https://xiatiandeairen.github.io/giscus-dark.css'
          : 'https://xiatiandeairen.github.io/giscus-light.css';
      };
      var observer = new MutationObserver(function() {
        var iframe = document.querySelector('iframe.giscus-frame');
        if (iframe) {
          iframe.contentWindow.postMessage({ giscus: { setConfig: { theme: giscusThemeUrl() } } }, 'https://giscus.app');
        }
      });
      observer.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });

      // TOC toggle
      var tocToggle = document.getElementById('toc-toggle');
      var tocPanel = document.getElementById('toc-panel');
      if (tocToggle && tocPanel) {
        tocToggle.addEventListener('click', function(e) {
          e.stopPropagation();
          tocPanel.classList.toggle('open');
        });
        document.addEventListener('click', function(e) {
          if (tocPanel.classList.contains('open') && !tocPanel.contains(e.target)) {
            tocPanel.classList.remove('open');
          }
        });
        tocPanel.querySelectorAll('a').forEach(function(a) {
          a.addEventListener('click', function() {
            tocPanel.classList.remove('open');
            var id = (a.getAttribute('href') || '').slice(1);
            var heading = id ? document.getElementById(id) : null;
            if (heading) {
              heading.classList.remove('toc-target');
              void heading.offsetWidth;
              heading.classList.add('toc-target');
              setTimeout(function() { heading.classList.remove('toc-target'); }, 2400);
            }
          });
        });
      }

      // Register article-specific shortcuts into the global help modal
      if (window.__registerShortcuts) {
        window.__registerShortcuts({
          id: 'article-modes',
          section: '模式切换',
          items: [
            { keys: ['r'], label: '进入 / 退出阅读模式' },
            { keys: ['b'], label: '进入 / 退出翻页模式' },
          ]
        });
        window.__registerShortcuts({
          id: 'article-reading',
          section: '阅读模式',
          items: [
            { keys: ['Space'], label: '向下翻一屏' },
            { keys: ['Shift', 'Space'], label: '向上翻一屏' },
            { keys: ['PgDn'], label: '向下翻一屏' },
            { keys: ['PgUp'], label: '向上翻一屏' },
            { keys: ['n'], label: '下一个章节' },
            { keys: ['p'], label: '上一个章节' },
            { keys: ['g'], label: '回到顶部' },
            { keys: ['G'], label: '到达底部' },
          ]
        });
        window.__registerShortcuts({
          id: 'article-book',
          section: '翻页模式',
          items: [
            { keys: ['→'], label: '下一页' },
            { keys: ['←'], label: '上一页' },
            { keys: ['Space'], label: '下一页' },
            { keys: ['PgDn'], label: '下一页' },
            { keys: ['PgUp'], label: '上一页' },
            { keys: ['Home'], label: '第一页' },
            { keys: ['End'], label: '最后一页' },
            { keys: ['g'], label: '第一页' },
            { keys: ['G'], label: '最后一页' },
          ]
        });
      }

      // Idle fade — dim floats after 2s of inactivity
      var idleTimer = null;
      function setIdle(v) { document.documentElement.setAttribute('data-idle', v ? 'true' : 'false'); }
      function bumpIdle() {
        setIdle(false);
        clearTimeout(idleTimer);
        idleTimer = setTimeout(function() { setIdle(true); }, 2000);
      }
      ['mousemove', 'scroll', 'keydown', 'touchstart', 'wheel'].forEach(function(ev) {
        window.addEventListener(ev, bumpIdle, { passive: true });
      });
      bumpIdle();

      // Keyboard navigation for flow mode (reading + default). Book mode handles its own keys above.
      document.addEventListener('keydown', function(e) {
        if (e.ctrlKey || e.metaKey || e.altKey) return;
        var tag = (e.target && e.target.tagName) || '';
        if (tag === 'INPUT' || tag === 'TEXTAREA' || (e.target && e.target.isContentEditable)) return;
        if (bookInColumns()) return; // book handler owns all nav keys when paginated
        var pageStep = window.innerHeight * 0.9;
        if (e.key === ' ' || e.key === 'PageDown') {
          window.scrollBy({ top: pageStep, behavior: 'smooth' }); e.preventDefault();
        } else if (e.key === 'PageUp' || (e.key === ' ' && e.shiftKey)) {
          window.scrollBy({ top: -pageStep, behavior: 'smooth' }); e.preventDefault();
        } else if (e.key === 'g' || e.key === 'Home') {
          window.scrollTo({ top: 0, behavior: 'smooth' }); e.preventDefault();
        } else if (e.key === 'G' || e.key === 'End') {
          window.scrollTo({ top: document.documentElement.scrollHeight, behavior: 'smooth' }); e.preventDefault();
        } else if (e.key === 'n' || e.key === 'p') {
          var hs = Array.prototype.slice.call(document.querySelectorAll('#article-body h2, #article-body h3'));
          if (!hs.length) return;
          var y = window.scrollY + 80;
          var idx = -1;
          for (var i = 0; i < hs.length; i++) { if (hs[i].offsetTop <= y) idx = i; }
          var next = e.key === 'n' ? idx + 1 : idx - 1;
          if (next >= 0 && next < hs.length) {
            window.scrollTo({ top: hs[next].offsetTop - 60, behavior: 'smooth' });
            e.preventDefault();
          }
        }
      });

      // Track visit for "最近浏览" widget (localStorage FIFO max 5)
      (function trackVisit() {
        try {
          var key = 'recentlyViewed';
          var slug = location.pathname.replace(/^\/notes\//, '').replace(/\/$/, '');
          var titleEl = document.querySelector('.article-title');
          var entry = { slug: slug, title: titleEl ? titleEl.textContent.trim() : slug, ts: Date.now() };
          var list;
          try { list = JSON.parse(localStorage.getItem(key) || '[]'); } catch (e) { list = []; }
          list = list.filter(function(x) { return x.slug !== slug; });
          list.unshift(entry);
          list = list.slice(0, 5);
          localStorage.setItem(key, JSON.stringify(list));
        } catch (e) {}
      })();

      // Resume reading position (per-slug, saved on scroll-idle)
      var posKey = 'read-pos:' + location.pathname;
      var posSaveTimer = null;
      window.addEventListener('scroll', function() {
        clearTimeout(posSaveTimer);
        posSaveTimer = setTimeout(function() {
          try { localStorage.setItem(posKey, String(Math.round(window.scrollY))); } catch (e) {}
        }, 400);
      }, { passive: true });
      (function showResumeToast() {
        var saved;
        try { saved = parseInt(localStorage.getItem(posKey) || '0', 10); } catch (e) { return; }
        if (!saved || saved < 200 || window.scrollY > 100) return;
        var toast = document.getElementById('resume-toast');
        var goBtn = document.getElementById('resume-toast-go');
        var closeBtn = document.getElementById('resume-toast-close');
        var label = document.getElementById('resume-toast-label');
        if (!toast || !goBtn || !closeBtn) return;
        var docH = document.documentElement.scrollHeight - window.innerHeight;
        var pct = docH > 0 ? Math.round((saved / docH) * 100) : 0;
        if (label) label.textContent = '继续上次阅读（' + pct + '%）';
        toast.classList.add('show');
        var dismissTimer = setTimeout(function() { toast.classList.remove('show'); }, 10000);
        goBtn.addEventListener('click', function() {
          clearTimeout(dismissTimer);
          window.scrollTo({ top: saved, behavior: 'smooth' });
          toast.classList.remove('show');
        });
        closeBtn.addEventListener('click', function() {
          clearTimeout(dismissTimer);
          toast.classList.remove('show');
        });
      })();

      // TOC scroll spy
      var tocItems = document.querySelectorAll('.toc-item');
      if (tocItems.length === 0) return;
      var headings = [];
      tocItems.forEach(function(item) {
        var id = item.getAttribute('data-id');
        var el = document.getElementById(id);
        if (el) headings.push({ el: el, item: item });
      });
      if (headings.length === 0) return;

      var current = null;
      function updateToc() {
        var scrollY = window.scrollY + 100;
        var active = headings[0];
        for (var i = 0; i < headings.length; i++) {
          if (headings[i].el.offsetTop <= scrollY) active = headings[i];
        }
        if (active && active !== current) {
          if (current) current.item.classList.remove('active');
          active.item.classList.add('active');
          current = active;
        }
      }
      window.addEventListener('scroll', updateToc, { passive: true });
      updateToc();

      // Code block copy buttons
      document.querySelectorAll('pre').forEach(function(pre) {
        var code = pre.querySelector('code');
        if (!code) return;
        var wrapper = document.createElement('div');
        wrapper.style.cssText = 'position:relative;';
        pre.parentNode.insertBefore(wrapper, pre);
        wrapper.appendChild(pre);

        var btn = document.createElement('button');
        btn.textContent = '复制';
        btn.style.cssText = 'position:absolute;top:8px;right:8px;padding:3px 10px;font-family:Inter,sans-serif;font-size:11px;background:var(--rule-light);color:var(--ink-muted);border:1px solid var(--rule);border-radius:3px;cursor:pointer;opacity:0;transition:opacity 0.15s;z-index:1;';
        wrapper.appendChild(btn);

        wrapper.addEventListener('mouseenter', function() { btn.style.opacity = '1'; });
        wrapper.addEventListener('mouseleave', function() { btn.style.opacity = '0'; });

        btn.addEventListener('click', function() {
          navigator.clipboard.writeText(code.textContent || '').then(function() {
            btn.textContent = '已复制';
            setTimeout(function() { btn.textContent = '复制'; }, 2000);
          });
        });
      });
    })();
  </script>
</NoteLayout>

---
import NoteLayout from '../../layouts/NoteLayout.astro';
import MetaFields from '../../components/MetaFields.astro';
import { getAllNotes, sortNotes } from '../../utils/notes';
import { generateSEOMeta } from '../../utils/seo';
import { marked } from 'marked';

export async function getStaticPaths() {
  const notes = getAllNotes();
  const sortedNotes = sortNotes(notes, 'date', 'desc');

  return notes.map((note) => {
    const seo = generateSEOMeta(note);
    const mode = 'public';
    const htmlContent = marked.parse(note.content);

    // Find prev/next notes
    const idx = sortedNotes.findIndex(n => n.slug === note.slug);
    const prevNote = idx < sortedNotes.length - 1 ? sortedNotes[idx + 1] : null;
    const nextNote = idx > 0 ? sortedNotes[idx - 1] : null;

    return {
      params: { slug: note.slug },
      props: {
        note,
        htmlContent,
        seo,
        mode,
        prevNote,
        nextNote,
      }
    };
  });
}

const { note, htmlContent, seo, mode, prevNote, nextNote } = Astro.props;
const urlMode = Astro.url.searchParams.get('mode');
const displayMode = urlMode === 'audit' ? 'audit' : mode;

// Reading time: Chinese ~400 chars/min
const charCount = note.content.replace(/\s+/g, '').length;
const readingMinutes = Math.max(1, Math.round(charCount / 400));
const wordCount = note.content.replace(/\s+/g, ' ').trim().length;
---

<NoteLayout note={note} seo={seo} mode={displayMode}>
  <!-- Reading progress bar -->
  <div class="reading-progress" id="reading-progress"></div>

  {/* Article header */}
  <header class="mb-8 pb-6 border-b border-rule">
    <div class="cat-label mb-2">
      {note.question.type}
      {note.question.subType ? ` · ${note.question.subType}` : ''}
    </div>
    <h1 class="font-display text-h1 mb-3" style="color:var(--ink);">{note.title}</h1>
    <div class="flex flex-wrap items-center gap-4 font-sans" style="font-size:11px;color:var(--ink-faint);">
      <time datetime={note.date}>{new Date(note.date).toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
      <span>·</span>
      <span class="reading-badge">📖 约 {readingMinutes} 分钟阅读</span>
      <span>·</span>
      <span>{wordCount.toLocaleString()} 字</span>
    </div>
  </header>

  {/* Article body with sidebar */}
  <div class="grid gap-12" style="grid-template-columns: 1fr 220px;">
    <article class="prose prose-lg max-w-reading
      prose-headings:font-display prose-headings:text-ink prose-headings:font-bold
      prose-h2:text-xl prose-h2:mt-10 prose-h2:mb-3
      prose-h3:text-lg prose-h3:mt-8 prose-h3:mb-2
      prose-p:text-ink-light prose-p:leading-relaxed prose-p:text-body
      prose-strong:text-ink prose-strong:font-semibold
      prose-a:text-ink prose-a:underline prose-a:decoration-rule prose-a:underline-offset-2 hover:prose-a:decoration-ink
      prose-code:text-ink prose-code:bg-bg-subtle prose-code:font-mono prose-code:text-[0.875em]
      prose-pre:bg-bg-subtle prose-pre:border prose-pre:border-rule-light
      prose-blockquote:border-ink prose-blockquote:border-l-3 prose-blockquote:text-ink-light prose-blockquote:italic
      prose-li:text-ink-light prose-li:leading-relaxed"
    >
      <div set:html={htmlContent} />
    </article>

    {/* Sidebar */}
    <aside class="sticky top-8 self-start space-y-7">
      {/* Tags */}
      {note.tags.length > 0 && (
        <div>
          <div class="section-label">标签</div>
          <div class="flex flex-wrap gap-1.5">
            {note.tags.map((tag) => (
              <a
                href={`/tags/${encodeURIComponent(tag.name)}`}
                class="font-sans text-caption px-2.5 py-1 border border-rule-light rounded text-ink-muted no-underline hover:border-ink hover:text-ink transition-all"
              >
                {tag.name}
              </a>
            ))}
          </div>
        </div>
      )}

      {/* Topics */}
      {note.topics.length > 0 && (
        <div>
          <div class="section-label">主题</div>
          <div class="space-y-1">
            {note.topics.map((topic) => (
              <a
                href={`/topics/${encodeURIComponent(topic.name)}`}
                class="block font-sans text-small text-ink-muted no-underline hover:text-ink transition-colors"
              >
                {topic.name}
              </a>
            ))}
          </div>
        </div>
      )}
    </aside>
  </div>

  {/* Prev / Next navigation */}
  {(prevNote || nextNote) && (
    <nav class="grid grid-cols-2 gap-6 mt-8 pt-6 border-t border-rule" aria-label="文章导航">
      {prevNote ? (
        <a href={`/notes/${prevNote.slug}`} class="no-underline group">
          <div class="cat-label">← 上一篇</div>
          <div class="font-serif text-h3 text-ink group-hover:text-link-hover transition-colors">{prevNote.title}</div>
        </a>
      ) : <div />}
      {nextNote ? (
        <a href={`/notes/${nextNote.slug}`} class="no-underline text-right group">
          <div class="cat-label">下一篇 →</div>
          <div class="font-serif text-h3 text-ink group-hover:text-link-hover transition-colors">{nextNote.title}</div>
        </a>
      ) : <div />}
    </nav>
  )}

  <a href="#main-content" class="back-to-top">回到顶部 ↑</a>

  <script is:inline>
    (function() {
      const bar = document.getElementById('reading-progress');
      if (!bar) return;
      window.addEventListener('scroll', function() {
        const h = document.documentElement.scrollHeight - window.innerHeight;
        if (h > 0) bar.style.width = (window.scrollY / h * 100) + '%';
      }, { passive: true });
    })();
  </script>
</NoteLayout>

---
/* Category: Layout
   Patterns: text-hierarchy, card-divider
   Tokens: --font-caption, --font-small, --ink, --ink-muted, --rule-faint
   See: .know/docs/arch/design-patterns.md §2.6 */
import { getAllNotes } from '../utils/notes';
import { getFeatured } from '../utils/rank';
import { useT, localePath, type Lang } from '../i18n';

interface Props {
  lang?: Lang;
}

const { lang = 'zh' } = Astro.props;
const t = useT(lang);

const allNotes = getAllNotes();

// Featured: by quality.overall (with featured flag bonus), date desc fallback
const featured = getFeatured(allNotes, 3);

// All notes serialized for client-side random pick + recently-viewed lookup
const notesIndex = allNotes.map(n => ({ slug: n.slug, title: n.title }));

// Hot tags: top 5 by note count
const tagCountMap = new Map<string, number>();
for (const note of allNotes) {
  for (const tag of note.tags) {
    tagCountMap.set(tag.name, (tagCountMap.get(tag.name) || 0) + 1);
  }
}
const hotTags = Array.from(tagCountMap.entries())
  .sort((a, b) => b[1] - a[1])
  .slice(0, 5);

// Series: unique series names
const seriesMap = new Map<string, number>();
for (const note of allNotes) {
  const s = note.series;
  if (s?.name) {
    seriesMap.set(s.name, (seriesMap.get(s.name) || 0) + 1);
  }
}
const seriesList = Array.from(seriesMap.entries()).slice(0, 3);
const hasMoreSeries = seriesMap.size > 3;
---

<aside class="sidebar">
  {/* Featured (by quality.overall + featured flag) */}
  <div class="sidebar-section">
    <div class="section-label">{t('sidebar.featured')}</div>
    {featured.map((note, i) => (
      <a href={`/notes/${note.slug}`} class="sidebar-popular-item">
        <span class="sidebar-popular-num font-sans">{String(i + 1).padStart(2, '0')}</span>
        <span class="sidebar-popular-title">{note.title}</span>
      </a>
    ))}
  </div>

  {/* Recently viewed (client-rendered from localStorage) */}
  <div class="sidebar-section recently-viewed" data-recently-viewed hidden>
    <div class="section-label">{t('sidebar.recent')}</div>
    <div class="recently-viewed-list" id="recently-viewed-list"></div>
  </div>

  {/* Random article button */}
  <div class="sidebar-section random-note">
    <button type="button" class="sidebar-random-btn" id="sidebar-random-btn" data-notes={JSON.stringify(notesIndex)}>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="16 3 21 3 21 8"/><line x1="4" y1="20" x2="21" y2="3"/><polyline points="21 16 21 21 16 21"/><line x1="15" y1="15" x2="21" y2="21"/><line x1="4" y1="4" x2="9" y2="9"/></svg>
      <span>{t('sidebar.random')}</span>
    </button>
  </div>

  {/* Series */}
  {seriesList.length > 0 && (
    <div class="sidebar-section">
      <div class="section-label">{t('sidebar.series')}</div>
      {seriesList.map(([name, count]) => (
        <a href={localePath('/series', lang)} class="sidebar-series-item">
          <span>{name}</span>
          <span class="sidebar-series-count font-sans">{count}</span>
        </a>
      ))}
      {hasMoreSeries && (
        <a href={localePath('/series', lang)} class="sidebar-more font-sans">{lang === 'zh' ? '全部系列 →' : 'All series →'}</a>
      )}
    </div>
  )}

  {/* Hot Tags */}
  {hotTags.length > 0 && (
    <div class="sidebar-section">
      <div class="section-label">{lang === 'zh' ? '热门标签' : 'Tags'}</div>
      <div class="sidebar-tags">
        {hotTags.map(([name, count]) => (
          <a href={`/tags/${name}`} class="sidebar-tag-chip font-sans">
            {name} <span class="sidebar-tag-count">{count}</span>
          </a>
        ))}
      </div>
    </div>
  )}

  {/* RSS */}
  <div class="sidebar-section">
    <a href="/rss.xml" class="sidebar-rss">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M4 11a9 9 0 0 1 9 9"/><path d="M4 4a16 16 0 0 1 16 16"/><circle cx="5" cy="19" r="1"/></svg>
      <span>{t('sidebar.subscribe')}</span>
    </a>
  </div>
</aside>

<script is:inline>
  (function() {
    // Recently viewed: read from localStorage and render
    var section = document.querySelector('[data-recently-viewed]');
    var listEl = document.getElementById('recently-viewed-list');
    if (section && listEl) {
      var items;
      try { items = JSON.parse(localStorage.getItem('recentlyViewed') || '[]'); } catch (e) { items = []; }
      var currentSlug = (location.pathname.match(/^\/notes\/([^\/]+)/) || [])[1] || '';
      items = items.filter(function(x) { return x && x.slug && x.slug !== currentSlug; });
      if (items.length) {
        section.hidden = false;
        listEl.innerHTML = items.slice(0, 5).map(function(x) {
          return '<a href="/notes/' + encodeURIComponent(x.slug) + '" class="sidebar-recent-item">' +
            '<span class="sidebar-recent-title">' + (x.title || x.slug).replace(/[<>&]/g, function(c){ return {'<':'&lt;','>':'&gt;','&':'&amp;'}[c]; }) + '</span>' +
            '</a>';
        }).join('');
      }
    }

    // Random article button
    var btn = document.getElementById('sidebar-random-btn');
    if (btn) {
      btn.addEventListener('click', function() {
        var notes;
        try { notes = JSON.parse(btn.getAttribute('data-notes') || '[]'); } catch (e) { return; }
        var currentSlug = (location.pathname.match(/^\/notes\/([^\/]+)/) || [])[1] || '';
        var pool = notes.filter(function(n) { return n.slug !== currentSlug; });
        if (!pool.length) return;
        var pick = pool[Math.floor(Math.random() * pool.length)];
        location.href = '/notes/' + encodeURIComponent(pick.slug);
      });
    }
  })();
</script>

<style>
  .sidebar-section {
    margin-bottom: var(--space-6);
  }

  .sidebar-section:last-child {
    margin-bottom: 0;
  }

  /* Featured / popular articles */
  .sidebar-popular-item {
    display: flex;
    align-items: flex-start;
    gap: var(--space-2);
    padding: var(--space-2) 0;
    border-bottom: 1px solid var(--rule-faint);
    text-decoration: none;
    color: inherit;
    transition: all var(--duration-fast);
  }

  .sidebar-popular-item:hover {
    padding-left: var(--space-1);
  }

  .sidebar-popular-item:last-of-type {
    border-bottom: none;
  }

  .sidebar-popular-num {
    font-size: var(--font-label);
    color: var(--ink-ghost);
    font-weight: 600;
    line-height: 1.35;
    flex-shrink: 0;
    min-width: 18px;
  }

  .sidebar-popular-title {
    font-size: var(--font-caption);
    font-weight: 600;
    line-height: 1.35;
    color: var(--ink);
    transition: color var(--transition-color);
  }

  .sidebar-popular-item:hover .sidebar-popular-title {
    color: var(--accent);
  }

  /* Recently viewed */
  .sidebar-recent-item {
    display: block;
    padding: var(--space-1) 0;
    border-bottom: 1px solid var(--rule-faint);
    text-decoration: none;
    font-size: var(--font-caption);
    color: var(--ink-muted);
    line-height: 1.35;
    transition: color var(--transition-color);
  }
  .sidebar-recent-item:last-child { border-bottom: none; }
  .sidebar-recent-item:hover { color: var(--accent); }
  .sidebar-recent-title { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }

  /* Random button */
  .sidebar-random-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: 6px var(--space-3);
    background: transparent;
    border: 1px solid var(--rule);
    border-radius: 999px;
    cursor: pointer;
    font-family: Inter, sans-serif;
    font-size: var(--font-caption);
    color: var(--ink-muted);
    transition: all var(--duration-fast);
  }
  .sidebar-random-btn:hover {
    border-color: var(--ink-muted);
    color: var(--ink);
  }

  /* Series */
  .sidebar-series-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-1) 0;
    border-bottom: 1px solid var(--rule-faint);
    text-decoration: none;
    font-size: var(--font-caption);
    color: var(--ink-muted);
    transition: color var(--transition-color);
  }

  .sidebar-series-item:hover {
    color: var(--ink);
  }

  .sidebar-series-item:last-of-type {
    border-bottom: none;
  }

  .sidebar-series-count {
    font-size: var(--font-label);
    color: var(--ink-ghost);
    font-weight: 600;
  }

  /* More link */
  .sidebar-more {
    display: block;
    font-size: var(--font-label);
    color: var(--ink-ghost);
    text-decoration: none;
    margin-top: var(--space-2);
    transition: color var(--transition-color);
  }

  .sidebar-more:hover {
    color: var(--accent);
  }

  /* Tags */
  .sidebar-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-1);
  }

  .sidebar-tag-chip {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    padding: 2px var(--space-2);
    font-size: var(--font-label);
    color: var(--ink-muted);
    border: 1px solid var(--rule-faint);
    text-decoration: none;
    transition: all var(--duration-fast);
  }

  .sidebar-tag-chip:hover {
    color: var(--ink);
    border-color: var(--rule);
  }

  .sidebar-tag-count {
    font-size: var(--font-label);
    color: var(--ink-ghost);
  }

  /* RSS */
  .sidebar-rss {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: Inter, sans-serif;
    font-size: var(--font-caption);
    color: var(--ink-muted);
    text-decoration: none;
    transition: color var(--transition-color);
  }

  .sidebar-rss:hover {
    color: var(--accent);
  }
</style>

---
/* Category: Content
   Patterns: hover-indicator, hover-shift, card-divider, text-hierarchy
   Tokens: --font-h3, --font-small, --ink-muted, --ink-hover, --space-2, --space-3
   Variants: headline | sidebar | secondary
   See: .know/docs/arch/design-tokens.md + design-patterns.md §2.1 */
import type { Note } from '../utils/notes';
import { getRealComments } from '../utils/comments';
import { useT, type Lang } from '../i18n';

interface Props {
  note: Note;
  variant: 'headline' | 'sidebar' | 'secondary';
  lang?: Lang;
}

const { note, variant, lang = 'zh' } = Astro.props;
const t = useT(lang);
const url = `/notes/${note.slug}`;
const realComments = variant === 'headline' ? getRealComments(note.slug, 3) : [];

function plainText(content: string): string {
  return content
    .replace(/```[\s\S]*?```/g, '')
    .replace(/`[^`]+`/g, '')
    .replace(/#{1,6}\s/g, '')
    .replace(/\*\*?|__?/g, '')
    .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1')
    .replace(/[<>]/g, '')
    .replace(/\n+/g, ' ')
    .trim();
}

const excerptLen = variant === 'headline' ? 500 : 80;
const excerpt = variant === 'sidebar' ? '' : plainText(note.content).slice(0, excerptLen) + '…';
---

{variant === 'headline' && (
  <div class="article-card article-card-headline">
    <a href={url} class="article-card-headline-link">
      <h2 class="article-card-title font-display">
        {note.title}
      </h2>
      <p class="article-card-excerpt">{excerpt}</p>
    </a>
    {realComments.length > 0 && (
      <div class="article-card-comments">
        {realComments.map((c, i) => (
          <a href={`${url}#comments`} class="reader-letter">
            {i === 0 && <span class="reader-letter-quote">"</span>}
            <blockquote class="reader-letter-text font-serif">{c.body}</blockquote>
            <cite class="reader-letter-author">— @{c.author}</cite>
          </a>
        ))}
      </div>
    )}
  </div>
)}

{variant === 'sidebar' && (
  <a href={url} class="article-card article-card-sidebar">
    <time class="article-card-sidebar-date font-sans" datetime={note.date}>{note.date.slice(5, 10)}</time>
    <span class="article-card-sidebar-title font-display">{note.title}</span>
  </a>
)}

{variant === 'secondary' && (
  <article class="article-card article-card-secondary">
    <h3 class="article-card-title font-serif">
      <a href={url}>{note.title}</a>
    </h3>
    <p class="article-card-excerpt font-sans">{excerpt}</p>
  </article>
)}


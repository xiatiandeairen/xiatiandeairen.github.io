---
/* Category: Content
   Patterns: hover-indicator, hover-shift, card-divider, text-hierarchy
   Tokens: --font-h3, --font-caption, --ink, --ink-hover, --ink-ghost, --rule-faint
   See: .know/docs/arch/design-tokens.md + design-patterns.md §2.2 */
import type { Note } from '../utils/notes';
import { formatDate } from '../utils/notes';
import { QUALITY_COLORS, QUALITY_THRESHOLDS } from '../utils/constants';
import { useT, type Lang } from '../i18n';

interface Props {
  note: Note;
  showQuality?: boolean;
  showExcerpt?: boolean;
  hideTag?: string;
  lang?: Lang;
}

const { note, showQuality = false, showExcerpt = false, hideTag, lang = 'zh' } = Astro.props;
const visibleTags = hideTag ? note.tags.filter(t => t.name !== hideTag) : note.tags;
const t = useT(lang);
const dateFormatted = formatDate(note.date, lang === 'en' ? 'en-US' : 'zh-CN');

const charCount = note.content.replace(/\s+/g, '').length;
const readingMinutes = Math.max(1, Math.round(charCount / 300));

function getQualityColor(score: number): string {
  if (score >= QUALITY_THRESHOLDS.high) return QUALITY_COLORS.high;
  if (score >= QUALITY_THRESHOLDS.medium) return QUALITY_COLORS.medium;
  return QUALITY_COLORS.low;
}

function getExcerpt(content: string, maxLen: number = 120): string {
  const plain = content.replace(/#{1,6}\s/g, '').replace(/\*\*?|__?/g, '').replace(/[<>]/g, '').replace(/\n+/g, ' ').trim();
  if (plain.length <= maxLen) return plain;
  return plain.slice(0, maxLen).trim() + '…';
}
---

<article class="post-card">
  <div class="cat-label">
    {note.question.type}
    {note.question.subType ? ` · ${note.question.subType}` : ''}
  </div>
  <h2 class="post-card-title">
    <a href={`/notes/${note.slug}`}>{note.title}</a>
  </h2>
  {showExcerpt && note.content && (
    <p class="font-sans max-w-reading notecard-excerpt">
      {getExcerpt(note.content)}
    </p>
  )}
  <div class="flex flex-wrap items-center gap-2 font-sans notecard-meta">
    <time datetime={note.date}>{dateFormatted}</time>
    <span>{'·'}</span>
    <span>{t('article.readingTime', { min: readingMinutes })}</span>
    {showQuality && (
      <>
        <span>{'·'}</span>
        <span style={`color: ${getQualityColor(note.quality.overall)}`}>
          {note.quality.overall}/10
        </span>
      </>
    )}
    {visibleTags.length > 0 && (
      <>
        <span>{'·'}</span>
        <span>{visibleTags.slice(0, 3).map(tag => tag.name).join(' · ')}</span>
      </>
    )}
  </div>
</article>

<style>
  .notecard-excerpt {
    font-size: var(--font-small);
    color: var(--ink-muted);
    line-height: 1.55;
    margin: var(--space-1) 0 var(--space-2);
  }
  .notecard-meta {
    font-size: var(--font-caption);
    color: var(--ink-ghost);
  }
</style>

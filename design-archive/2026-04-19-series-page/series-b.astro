---
/*
  系列页方向 B：Hero + Chapter 列表
  每个 series 是独立"小书"：大标题 + tagline + 4 格 stats + 起点 CTA + 章节列表。
  合成 2 个 series 演示多系列场景。
*/
import BaseLayout from '../../layouts/BaseLayout.astro';

type Chapter = { order: number; title: string; date: string; minutes: number; excerpt: string };
type SeriesMock = { name: string; tagline: string; chapters: Chapter[] };

const seriesList: SeriesMock[] = [
  {
    name: 'AI Skills 系列',
    tagline: '从碎片经验到可复用的 skill — 让 AI 把你的"默会"变成可调用的能力',
    chapters: [
      { order: 1, title: 'Sprint：给 AI 一条流水线而不是一句话', date: '2026-04-10', minutes: 11, excerpt: '一个任务，两种执行方式。假设你的任务是：把博客的标签系统从扁平列表改成层级结构。标签之间有父子关系，URL 路由…' },
      { order: 2, title: 'Diagnose：AI 调试不应该是碰运气', date: '2026-04-12', minutes: 10, excerpt: 'AI 调试的默认模式：随机搜索。你告诉 AI：「部署后首屏白屏」，它给你 3 个可能原因…' },
      { order: 3, title: 'Skill 设计模式：如何写出 AI 真正能执行的指令', date: '2026-04-13', minutes: 12, excerpt: '为什么你的 prompt 无法成为 Skill？因为它不具备可复用性。Skill ≠ Prompt。Skill 是一条可以…' },
      { order: 4, title: 'Know：让 AI 不再重复犯同样的错', date: '2026-04-14', minutes: 9, excerpt: '同一个坑，踩了三次。我的博客项目有一个约定：工具函数不能引入外部依赖，所有 utility 用原生…' },
      { order: 5, title: 'Long Sprint 实践：让 AI 自主完成大型任务', date: '2026-04-15', minutes: 14, excerpt: '当一个 Sprint 放不下。Sprint 设计上是为单一、聚焦的任务优化的。添加一个功能、修复一个 bug…' },
    ],
  },
  {
    name: 'AI 阅读习惯',
    tagline: '从碎片阅读到结构化吸收 — 把对话变成知识资产',
    chapters: [
      { order: 1, title: '为什么个人博客不该追热点', date: '2025-11-02', minutes: 7, excerpt: '追热点是反杠杆的。你花 2 小时抓住的流量，热度过去后归零；而一篇能复用的方法文…' },
      { order: 2, title: '改稿的三条纪律', date: '2025-12-18', minutes: 8, excerpt: '纪律一：先删再改。删字是最便宜的结构优化。纪律二：把结论前置…' },
      { order: 3, title: '从问题到文章：不写废话的结构法', date: '2026-02-10', minutes: 10, excerpt: '写作是一个从模糊到精确的过程。问题 → 论点 → 论据 → 行动。每一层都要…' },
    ],
  },
];

// Helpers
function fmt(d: string): string { return d.slice(5); }
function totalChars(ch: Chapter): number { return ch.excerpt.length * 30; /* synth proxy */ }
function stats(s: SeriesMock) {
  const dates = s.chapters.map(c => c.date).sort();
  const readingMin = s.chapters.reduce((n, c) => n + c.minutes, 0);
  const totalWords = s.chapters.reduce((n, c) => n + totalChars(c), 0);
  const spanDays = Math.round((new Date(dates[dates.length-1]).getTime() - new Date(dates[0]).getTime()) / 86400000);
  return { count: s.chapters.length, readingMin, totalWords, start: dates[0], end: dates[dates.length-1], spanDays };
}
---

<BaseLayout title="系列 · Hero + 章节列表 Mockup">
  <header class="series-header">
    <h1 class="font-display text-h1 mb-1">系列</h1>
    <p class="font-sans text-small series-subtitle">按主题组织的连续写作，共 {seriesList.length} 组。</p>
  </header>

  {/* Sticky chip nav: 多系列间跳转 */}
  <nav class="series-nav font-sans">
    {seriesList.map((s, i) => (
      <a href={`#s-${i}`} class="series-nav-chip">{s.name}</a>
    ))}
  </nav>

  {seriesList.map((s, i) => {
    const st = stats(s);
    const first = s.chapters[0];
    return (
      <section class="series-card" id={`s-${i}`}>
        <header class="series-card-head">
          <div class="series-card-kicker font-sans">系列 · {st.count} 篇 · {st.start} → {st.end}</div>
          <h2 class="series-card-title font-display">{s.name}</h2>
          <p class="series-card-tagline font-serif">—— {s.tagline}</p>

          <div class="series-stats">
            <div class="stat-cell">
              <div class="stat-cell-value">{st.count}</div>
              <div class="stat-cell-label font-sans">篇</div>
            </div>
            <div class="stat-cell">
              <div class="stat-cell-value">{(st.totalWords / 1000).toFixed(1)}<span class="stat-cell-unit">k</span></div>
              <div class="stat-cell-label font-sans">字</div>
            </div>
            <div class="stat-cell">
              <div class="stat-cell-value">{st.readingMin}<span class="stat-cell-unit">min</span></div>
              <div class="stat-cell-label font-sans">阅读</div>
            </div>
            <div class="stat-cell">
              <div class="stat-cell-value">{st.spanDays}<span class="stat-cell-unit">d</span></div>
              <div class="stat-cell-label font-sans">跨度</div>
            </div>
          </div>

          <a href="#" class="series-start-cta font-sans">从这里开始 · 《{first.title}》 →</a>
        </header>

        <ol class="chapter-list">
          {s.chapters.map(c => (
            <li class="chapter-item">
              <a href="#" class="chapter-link">
                <span class="chapter-num font-sans">{String(c.order).padStart(2, '0')}</span>
                <div class="chapter-body">
                  <div class="chapter-title font-display">{c.title}</div>
                  <p class="chapter-excerpt font-sans">{c.excerpt}</p>
                  <div class="chapter-meta font-sans">{fmt(c.date)} · 约 {c.minutes} min</div>
                </div>
              </a>
            </li>
          ))}
        </ol>
      </section>
    );
  })}
</BaseLayout>

<style>
  .series-header {
    margin-bottom: var(--space-5);
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--rule-light);
  }
  .series-subtitle { color: var(--ink-muted); }

  /* Sticky chip nav */
  .series-nav {
    position: sticky;
    top: var(--space-3);
    z-index: 10;
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
    padding: var(--space-3) 0;
    margin-bottom: var(--space-5);
    background: var(--paper);
    border-bottom: 1px solid var(--rule-faint);
  }
  .series-nav-chip {
    padding: 4px 12px;
    font-size: var(--font-caption);
    color: var(--ink-muted);
    background: var(--bg-subtle);
    border: 1px solid var(--rule-light);
    border-radius: 999px;
    text-decoration: none;
    transition: border-color var(--duration-fast);
  }
  .series-nav-chip:hover { border-color: var(--ink-muted); color: var(--ink); }

  /* Series card hero */
  .series-card { margin-bottom: var(--space-7); }
  .series-card-head {
    padding: var(--space-5);
    background: var(--bg-subtle);
    border-left: 4px solid var(--accent);
    border-radius: var(--radius-md);
    margin-bottom: var(--space-4);
  }
  .series-card-kicker {
    font-size: var(--font-label);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--accent);
    margin-bottom: var(--space-2);
  }
  .series-card-title { font-size: var(--font-h1); font-weight: 700; line-height: 1.15; margin: 0 0 var(--space-2); color: var(--ink); letter-spacing: -0.01em; }
  .series-card-tagline { font-size: var(--font-body); font-style: italic; color: var(--ink-muted); margin: 0 0 var(--space-4); line-height: 1.5; }

  .series-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-3);
    padding: var(--space-3) 0;
    border-top: 1px solid var(--rule-faint);
    border-bottom: 1px solid var(--rule-faint);
    margin-bottom: var(--space-4);
  }
  .stat-cell { text-align: center; }
  .stat-cell-value {
    font-family: var(--font-display, Georgia, serif);
    font-size: 28px;
    font-weight: 700;
    color: var(--ink);
    line-height: 1;
    font-variant-numeric: tabular-nums;
  }
  .stat-cell-unit { font-size: 14px; font-weight: 400; color: var(--ink-muted); margin-left: 2px; }
  .stat-cell-label {
    font-size: var(--font-label);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink-ghost);
    margin-top: 4px;
  }

  .series-start-cta {
    display: inline-block;
    padding: var(--space-2) var(--space-4);
    background: var(--ink);
    color: var(--paper);
    border-radius: var(--radius-sm);
    text-decoration: none;
    font-size: var(--font-small);
    font-weight: 600;
    transition: background var(--duration-fast);
  }
  .series-start-cta:hover { background: var(--ink-hover); color: var(--paper); }

  /* Chapter list */
  .chapter-list { list-style: none; padding: 0; margin: 0; }
  .chapter-item { border-bottom: 1px solid var(--rule-faint); }
  .chapter-item:last-child { border-bottom: none; }
  .chapter-link {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-4);
    padding: var(--space-4) 0;
    text-decoration: none;
    color: inherit;
    transition: padding-left var(--duration-fast);
  }
  .chapter-link:hover { padding-left: var(--space-2); color: inherit; }
  .chapter-link:hover .chapter-title { color: var(--ink-hover); text-decoration: underline; text-underline-offset: 0.15em; }
  .chapter-num {
    font-family: var(--font-display, Georgia, serif);
    font-size: 36px;
    font-weight: 700;
    color: var(--rule);
    opacity: 0.6;
    line-height: 1;
    font-variant-numeric: tabular-nums;
    min-width: 48px;
  }
  .chapter-body { min-width: 0; }
  .chapter-title { font-size: var(--font-h3); font-weight: 700; color: var(--ink); line-height: 1.3; margin-bottom: var(--space-1); }
  .chapter-excerpt {
    font-size: var(--font-small);
    color: var(--ink-muted);
    line-height: 1.55;
    margin: 0 0 var(--space-2);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .chapter-meta { font-size: var(--font-caption); color: var(--ink-ghost); font-variant-numeric: tabular-nums; }

  @media (max-width: 640px) {
    .series-stats { grid-template-columns: repeat(2, 1fr); }
    .chapter-num { font-size: 24px; min-width: 32px; }
  }
</style>

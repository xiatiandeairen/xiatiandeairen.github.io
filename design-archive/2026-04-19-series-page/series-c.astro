---
/*
  系列页方向 C：时间线视图
  每 series 是一条纵向 timeline — 左侧一竖线，articles 作为节点从上到下。
  节点 = 日期小圆 + 标题 + excerpt + 阅读时长，最新篇标"最新"。
*/
import BaseLayout from '../../layouts/BaseLayout.astro';

type Chapter = { order: number; title: string; date: string; minutes: number; excerpt: string };
type SeriesMock = { name: string; tagline: string; chapters: Chapter[] };

const seriesList: SeriesMock[] = [
  {
    name: 'AI Skills 系列',
    tagline: '从碎片经验到可复用的 skill',
    chapters: [
      { order: 1, title: 'Sprint：给 AI 一条流水线而不是一句话', date: '2026-04-10', minutes: 11, excerpt: '一个任务，两种执行方式。假设你的任务是：把博客的标签系统从扁平列表改成层级结构…' },
      { order: 2, title: 'Diagnose：AI 调试不应该是碰运气', date: '2026-04-12', minutes: 10, excerpt: 'AI 调试的默认模式：随机搜索。你告诉 AI：「部署后首屏白屏」，它给你 3 个可能原因…' },
      { order: 3, title: 'Skill 设计模式：如何写出 AI 真正能执行的指令', date: '2026-04-13', minutes: 12, excerpt: '为什么你的 prompt 无法成为 Skill？因为它不具备可复用性…' },
      { order: 4, title: 'Know：让 AI 不再重复犯同样的错', date: '2026-04-14', minutes: 9, excerpt: '同一个坑，踩了三次。我的博客项目有一个约定：工具函数不能引入外部依赖…' },
      { order: 5, title: 'Long Sprint 实践：让 AI 自主完成大型任务', date: '2026-04-15', minutes: 14, excerpt: '当一个 Sprint 放不下。Sprint 设计上是为单一、聚焦的任务优化的…' },
    ],
  },
  {
    name: 'AI 阅读习惯',
    tagline: '从碎片阅读到结构化吸收',
    chapters: [
      { order: 1, title: '为什么个人博客不该追热点', date: '2025-11-02', minutes: 7, excerpt: '追热点是反杠杆的。你花 2 小时抓住的流量，热度过去后归零…' },
      { order: 2, title: '改稿的三条纪律', date: '2025-12-18', minutes: 8, excerpt: '纪律一：先删再改。删字是最便宜的结构优化…' },
      { order: 3, title: '从问题到文章：不写废话的结构法', date: '2026-02-10', minutes: 10, excerpt: '写作是一个从模糊到精确的过程。问题 → 论点 → 论据 → 行动…' },
    ],
  },
];

function fmt(d: string) { return d.slice(5); }
function spanDays(s: SeriesMock): number {
  const dates = s.chapters.map(c => c.date).sort();
  return Math.round((new Date(dates[dates.length-1]).getTime() - new Date(dates[0]).getTime()) / 86400000);
}
---

<BaseLayout title="系列 · 时间线 Mockup">
  <header class="series-header">
    <h1 class="font-display text-h1 mb-1">系列</h1>
    <p class="font-sans text-small series-subtitle">按主题组织的连续写作，共 {seriesList.length} 组。</p>
  </header>

  <nav class="series-nav font-sans">
    {seriesList.map((s, i) => (
      <a href={`#s-${i}`} class="series-nav-chip">{s.name}</a>
    ))}
  </nav>

  {seriesList.map((s, i) => (
    <section class="series-card" id={`s-${i}`}>
      <header class="series-card-head">
        <div class="series-card-kicker font-sans">
          系列 · {s.chapters.length} 篇 · {s.chapters.reduce((n, c) => n + c.minutes, 0)} min · 跨度 {spanDays(s)} 天
        </div>
        <h2 class="series-card-title font-display">{s.name}</h2>
        <p class="series-card-tagline font-serif">—— {s.tagline}</p>
      </header>

      <ol class="timeline">
        {s.chapters.map((c, idx) => {
          const isLast = idx === s.chapters.length - 1;
          return (
            <li class={`timeline-node ${isLast ? 'timeline-node-latest' : ''}`}>
              <span class="timeline-dot" aria-hidden="true"></span>
              <time class="timeline-date font-sans" datetime={c.date}>{fmt(c.date)}</time>
              <div class="timeline-body">
                <a href="#" class="timeline-title font-display">
                  <span class="timeline-order font-sans">#{String(c.order).padStart(2, '0')}</span>
                  {c.title}
                </a>
                {isLast && <span class="timeline-latest font-sans">最新</span>}
                <p class="timeline-excerpt font-sans">{c.excerpt}</p>
                <div class="timeline-meta font-sans">约 {c.minutes} min</div>
              </div>
            </li>
          );
        })}
      </ol>
    </section>
  ))}
</BaseLayout>

<style>
  .series-header {
    margin-bottom: var(--space-5);
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--rule-light);
  }
  .series-subtitle { color: var(--ink-muted); }

  .series-nav {
    position: sticky;
    top: var(--space-3);
    z-index: 10;
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
    padding: var(--space-3) 0;
    margin-bottom: var(--space-5);
    background: var(--paper);
    border-bottom: 1px solid var(--rule-faint);
  }
  .series-nav-chip {
    padding: 4px 12px;
    font-size: var(--font-caption);
    color: var(--ink-muted);
    background: var(--bg-subtle);
    border: 1px solid var(--rule-light);
    border-radius: 999px;
    text-decoration: none;
  }
  .series-nav-chip:hover { border-color: var(--ink-muted); color: var(--ink); }

  /* Series header block */
  .series-card { margin-bottom: var(--space-7); }
  .series-card-head {
    padding: 0 0 var(--space-4) 0;
    margin-bottom: var(--space-4);
    border-bottom: 1px solid var(--rule-light);
  }
  .series-card-kicker {
    font-size: var(--font-label);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--accent);
    margin-bottom: var(--space-1);
  }
  .series-card-title { font-size: var(--font-h1); font-weight: 700; line-height: 1.15; margin: 0 0 var(--space-1); color: var(--ink); letter-spacing: -0.01em; }
  .series-card-tagline { font-size: var(--font-body); font-style: italic; color: var(--ink-muted); margin: 0; }

  /* Timeline */
  .timeline {
    list-style: none;
    padding: 0;
    margin: 0;
    position: relative;
    padding-left: 120px; /* reserve space for date column + dot rail */
  }
  .timeline::before {
    content: '';
    position: absolute;
    left: 90px;
    top: 8px;
    bottom: 8px;
    width: 2px;
    background: var(--rule-light);
  }
  .timeline-node {
    position: relative;
    padding: var(--space-3) 0 var(--space-4);
  }
  .timeline-dot {
    position: absolute;
    left: -37px;
    top: calc(var(--space-3) + 4px);
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--paper);
    border: 2px solid var(--accent);
    z-index: 1;
  }
  .timeline-node-latest .timeline-dot {
    background: var(--accent);
    box-shadow: 0 0 0 4px color-mix(in oklab, var(--accent) 20%, transparent);
  }
  .timeline-date {
    position: absolute;
    left: -120px;
    top: calc(var(--space-3) + 2px);
    width: 72px;
    text-align: right;
    font-size: var(--font-caption);
    color: var(--ink-ghost);
    font-variant-numeric: tabular-nums;
  }
  .timeline-body { min-width: 0; }
  .timeline-title {
    display: block;
    font-size: var(--font-h3);
    font-weight: 700;
    color: var(--ink);
    line-height: 1.3;
    text-decoration: none;
    margin-bottom: var(--space-1);
  }
  .timeline-title:hover { color: var(--ink-hover); text-decoration: underline; text-underline-offset: 0.15em; }
  .timeline-order {
    display: inline-block;
    font-size: var(--font-caption);
    color: var(--ink-ghost);
    font-weight: 400;
    margin-right: var(--space-2);
    font-variant-numeric: tabular-nums;
  }
  .timeline-latest {
    display: inline-block;
    padding: 1px 8px;
    font-size: var(--font-xs);
    background: var(--accent);
    color: var(--paper);
    border-radius: var(--radius-sm);
    letter-spacing: 0.05em;
    margin-bottom: var(--space-2);
    vertical-align: baseline;
  }
  .timeline-excerpt {
    font-size: var(--font-small);
    color: var(--ink-muted);
    line-height: 1.55;
    margin: var(--space-1) 0 var(--space-1);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .timeline-meta { font-size: var(--font-caption); color: var(--ink-ghost); font-variant-numeric: tabular-nums; }

  @media (max-width: 640px) {
    .timeline { padding-left: 44px; }
    .timeline::before { left: 14px; }
    .timeline-dot { left: -37px; }
    .timeline-date {
      position: static;
      left: auto;
      width: auto;
      text-align: left;
      margin-bottom: var(--space-1);
    }
  }
</style>

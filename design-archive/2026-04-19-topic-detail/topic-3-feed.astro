---
/*
  主题详情页 · 方向 3：简约 Feed
  header + bridge + filter + 大列表 + pagination
*/
import BaseLayout from '../../layouts/BaseLayout.astro';

const topic = {
  name: 'AI 工程化',
  count: 7,
  types: ['全部', '系统设计', '方法论'],
  tags: ['AI', 'agent', 'engineering', 'sprint', 'diagnose', 'know'],
  coTopics: ['开发工具', '方法论'],
  notes: [
    { title: 'Long Sprint 实践：让 AI 自主完成大型任务', type: '系统设计', date: '2026-04-15', minutes: 14, tags: ['AI', 'agent'], excerpt: '当一个 Sprint 放不下…Sprint 设计上是为单一、聚焦的任务优化的。' },
    { title: '我给 AI Agent 写了一套操作系统', type: '系统设计', date: '2026-04-14', minutes: 18, tags: ['AI', 'agent'], excerpt: 'AI 能写代码，但不能交付。我们需要给它一套操作系统…' },
    { title: 'Decay：用 Rust 给代码做体检', type: '系统设计', date: '2026-04-14', minutes: 10, tags: ['Rust'], excerpt: 'Decay：用 Rust 给代码做体检。技术债是慢性病…' },
    { title: 'Know：让 AI 不再重复犯同样的错', type: '方法论', date: '2026-04-14', minutes: 9, tags: ['AI', 'know'], excerpt: '同一个坑，踩了三次。我的博客项目有一个约定…' },
    { title: 'Skill 设计模式：如何写出 AI 真正能执行的指令', type: '方法论', date: '2026-04-13', minutes: 12, tags: ['AI', 'skill'], excerpt: '为什么你的 prompt 无法成为 Skill？因为它不具备可复用性。' },
    { title: 'Diagnose：AI 调试不应该是碰运气', type: '系统设计', date: '2026-04-12', minutes: 10, tags: ['AI', 'diagnose'], excerpt: 'AI 调试的默认模式：随机搜索…' },
    { title: 'Sprint：给 AI 一条流水线而不是一句话', type: '系统设计', date: '2026-04-10', minutes: 11, tags: ['AI', 'sprint'], excerpt: '一个任务，两种执行方式。假设你的任务是把博客的标签系统改成层级结构…' },
  ],
};
---

<BaseLayout title="主题 · Feed Mockup">
  <nav class="topic-breadcrumb font-sans">
    <a href="#">← 主题索引</a>
  </nav>

  <header class="topic-head">
    <h1 class="topic-title font-display">{topic.name}</h1>
    <p class="topic-subtitle font-sans">{topic.count} 篇笔记</p>
  </header>

  <aside class="topic-bridge">
    <div class="topic-bridge-row">
      <span class="topic-bridge-label font-sans">包含标签</span>
      <div class="topic-bridge-chips">
        {topic.tags.map(t => <a href="#" class="bridge-chip font-sans">{t}</a>)}
      </div>
    </div>
    <div class="topic-bridge-row">
      <span class="topic-bridge-label font-sans">关联主题</span>
      <div class="topic-bridge-chips">
        {topic.coTopics.map(t => <a href="#" class="bridge-chip bridge-chip-primary font-sans">{t}</a>)}
      </div>
    </div>
  </aside>

  <div class="filter-bar">
    {topic.types.map((t, i) => (
      <button class={`filter-btn ${i === 0 ? 'active' : ''}`}>{t}</button>
    ))}
  </div>

  <ul class="feed-list">
    {topic.notes.map(n => (
      <li class="feed-item">
        <a href="#" class="feed-link">
          <h2 class="feed-title font-display">{n.title}</h2>
          <p class="feed-excerpt font-sans">{n.excerpt}</p>
          <div class="feed-meta font-sans">
            <time>{n.date}</time>
            <span>·</span>
            <span>{n.type}</span>
            <span>·</span>
            <span>约 {n.minutes} 分钟</span>
            {n.tags.length > 0 && (
              <>
                <span>·</span>
                <span>{n.tags.join(' · ')}</span>
              </>
            )}
          </div>
        </a>
      </li>
    ))}
  </ul>

  <nav class="pagination font-sans">
    <span class="pagination-info">1 / 1</span>
  </nav>
</BaseLayout>

<style>
  .topic-breadcrumb { font-size: var(--font-small); color: var(--ink-muted); margin-bottom: var(--space-3); }
  .topic-breadcrumb a { color: inherit; text-decoration: none; }

  .topic-head {
    padding: 0 0 var(--space-4) 0;
    margin-bottom: var(--space-5);
    border-bottom: 1px solid var(--rule-light);
  }
  .topic-title { font-size: var(--font-h1); font-weight: 700; line-height: 1.15; margin: 0 0 var(--space-1); color: var(--ink); }
  .topic-subtitle { font-size: var(--font-small); color: var(--ink-muted); margin: 0; }

  /* Bridge */
  .topic-bridge {
    padding: var(--space-3) var(--space-4);
    background: var(--bg-subtle);
    border: 1px solid var(--rule-faint);
    border-radius: var(--radius-md);
    display: grid;
    gap: var(--space-2);
    margin-bottom: var(--space-5);
  }
  .topic-bridge-row { display: flex; align-items: baseline; gap: var(--space-3); flex-wrap: wrap; }
  .topic-bridge-label { font-size: var(--font-label); text-transform: uppercase; letter-spacing: 0.08em; color: var(--ink-ghost); flex-shrink: 0; }
  .topic-bridge-chips { display: flex; flex-wrap: wrap; gap: 6px; }
  .bridge-chip {
    display: inline-flex;
    gap: 4px;
    padding: 2px 10px;
    font-size: var(--font-caption);
    color: var(--ink-muted);
    background: var(--paper);
    border: 1px solid var(--rule-light);
    border-radius: 999px;
    text-decoration: none;
  }
  .bridge-chip:hover { color: var(--ink); border-color: var(--ink-muted); }
  .bridge-chip-primary { color: var(--accent); border-color: color-mix(in srgb, var(--accent) 30%, transparent); }

  /* Filter bar */
  .filter-bar {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-bottom: var(--space-5);
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--rule);
  }
  .filter-btn {
    padding: 4px 12px;
    font-size: var(--font-small);
    color: var(--ink-muted);
    background: transparent;
    border: 1px solid var(--rule-light);
    border-radius: 4px;
    cursor: pointer;
    transition: border-color var(--duration-fast), color var(--duration-fast);
    font-family: Inter, sans-serif;
  }
  .filter-btn.active { color: var(--ink); border-color: var(--ink); }
  .filter-btn:hover { color: var(--ink); border-color: var(--ink-muted); }

  /* Feed list */
  .feed-list { list-style: none; padding: 0; margin: 0 0 var(--space-5); }
  .feed-item { padding: var(--space-4) 0; border-bottom: 1px solid var(--rule-faint); }
  .feed-link { display: block; text-decoration: none; color: inherit; }
  .feed-title { font-size: var(--font-h3); font-weight: 700; color: var(--ink); margin: 0 0 var(--space-2); line-height: 1.3; }
  .feed-link:hover .feed-title { color: var(--ink-hover); text-decoration: underline; text-underline-offset: 0.15em; }
  .feed-excerpt {
    font-size: var(--font-small);
    color: var(--ink-muted);
    line-height: 1.6;
    margin: 0 0 var(--space-2);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .feed-meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    font-size: var(--font-caption);
    color: var(--ink-ghost);
  }

  .pagination { text-align: center; padding: var(--space-5) 0; color: var(--ink-ghost); font-size: var(--font-small); }
</style>

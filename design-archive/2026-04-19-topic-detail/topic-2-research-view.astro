---
/*
  主题详情页 · 方向 2：研究视图
  Sparkline + type 分布 + tag 频次 + 文章列表
*/
import BaseLayout from '../../layouts/BaseLayout.astro';

const topic = {
  name: 'AI 工程化',
  tagline: '讲如何把 AI 变成能用的工具而不是聊天玩具',
  count: 7,
  totalMin: 104,
  totalChars: 28524,
  spanDays: 5,
  // synth monthly sparkline
  rhythm: [
    { ym: '2025-11', count: 0 },
    { ym: '2025-12', count: 0 },
    { ym: '2026-01', count: 0 },
    { ym: '2026-02', count: 1 },
    { ym: '2026-03', count: 2 },
    { ym: '2026-04', count: 4 },
  ],
  byType: [
    { type: '系统设计', count: 5 },
    { type: '方法论', count: 2 },
  ],
  tags: [
    { name: 'AI', count: 7 },
    { name: 'agent', count: 7 },
    { name: 'engineering', count: 7 },
    { name: 'sprint', count: 2 },
    { name: 'diagnose', count: 1 },
    { name: 'know', count: 1 },
  ],
  notes: [
    { title: 'Long Sprint 实践：让 AI 自主完成大型任务', type: '系统设计', date: '2026-04-15', minutes: 14, excerpt: '当一个 Sprint 放不下…' },
    { title: '我给 AI Agent 写了一套操作系统', type: '系统设计', date: '2026-04-14', minutes: 18, excerpt: 'AI 能写代码，但不能交付…' },
    { title: 'Decay：用 Rust 给代码做体检', type: '系统设计', date: '2026-04-14', minutes: 10, excerpt: '技术债是慢性病…' },
    { title: 'Know：让 AI 不再重复犯同样的错', type: '方法论', date: '2026-04-14', minutes: 9, excerpt: '同一个坑，踩了三次…' },
    { title: 'Skill 设计模式：如何写出 AI 真正能执行的指令', type: '方法论', date: '2026-04-13', minutes: 12, excerpt: '为什么你的 prompt 无法成为 Skill？' },
    { title: 'Diagnose：AI 调试不应该是碰运气', type: '系统设计', date: '2026-04-12', minutes: 10, excerpt: 'AI 调试的默认模式…' },
    { title: 'Sprint：给 AI 一条流水线而不是一句话', type: '系统设计', date: '2026-04-10', minutes: 11, excerpt: '一个任务，两种执行方式…' },
  ],
};
const maxCount = Math.max(...topic.rhythm.map(b => b.count));
const maxTagCount = Math.max(...topic.tags.map(t => t.count));
---

<BaseLayout title="主题 · 研究视图 Mockup">
  <nav class="topic-breadcrumb font-sans">
    <a href="#">← 主题索引</a>
  </nav>

  <header class="topic-head">
    <div class="topic-kicker font-sans">主题 · {topic.count} 篇 · {topic.totalMin} min · 跨度 {topic.spanDays} 天</div>
    <h1 class="topic-title font-display">{topic.name}</h1>
    <p class="topic-tagline font-serif">—— {topic.tagline}</p>
  </header>

  <section class="stat-row">
    <div class="stat-cell"><div class="stat-value">{topic.count}</div><div class="stat-label font-sans">篇</div></div>
    <div class="stat-cell"><div class="stat-value">{(topic.totalChars / 1000).toFixed(1)}<span class="stat-unit">k</span></div><div class="stat-label font-sans">字</div></div>
    <div class="stat-cell"><div class="stat-value">{topic.totalMin}<span class="stat-unit">min</span></div><div class="stat-label font-sans">阅读</div></div>
    <div class="stat-cell"><div class="stat-value">{topic.spanDays}<span class="stat-unit">d</span></div><div class="stat-label font-sans">跨度</div></div>
  </section>

  <section class="chart-block">
    <div class="chart-label font-sans">写作节奏</div>
    <div class="chart-bars">
      {topic.rhythm.map(b => (
        <span class={`chart-bar ${b.count === 0 ? 'chart-bar-empty' : ''}`} style={`--h: ${maxCount > 0 ? (b.count / maxCount) * 100 : 0}%`} title={`${b.ym} · ${b.count} 篇`}></span>
      ))}
    </div>
    <div class="chart-axis font-sans">
      <span>{topic.rhythm[0].ym}</span>
      <span>{topic.rhythm[topic.rhythm.length - 1].ym}</span>
    </div>
  </section>

  <div class="dist-grid">
    <section class="dist-block">
      <div class="chart-label font-sans">按类型</div>
      {topic.byType.map(t => (
        <div class="dist-row">
          <span class="dist-row-name">{t.type}</span>
          <span class="dist-row-bar" style={`width: ${(t.count / topic.count) * 100}%`}></span>
          <span class="dist-row-count font-sans">{t.count}</span>
        </div>
      ))}
    </section>

    <section class="dist-block">
      <div class="chart-label font-sans">标签频次</div>
      {topic.tags.map(t => (
        <div class="dist-row">
          <span class="dist-row-name">{t.name}</span>
          <span class="dist-row-bar" style={`width: ${(t.count / maxTagCount) * 100}%`}></span>
          <span class="dist-row-count font-sans">{t.count}</span>
        </div>
      ))}
    </section>
  </div>

  <section class="note-list-section">
    <div class="chart-label font-sans">所有文章（{topic.count} 篇，按时间）</div>
    <ul class="note-list">
      {topic.notes.map(n => (
        <li class="note-item">
          <a href="#" class="note-link">
            <time class="note-date font-sans">{n.date.slice(5, 10)}</time>
            <div class="note-body">
              <div class="note-title font-display">{n.title}</div>
              <p class="note-excerpt font-sans">{n.excerpt}</p>
              <div class="note-kickers font-sans">
                <span class="note-type">{n.type}</span>
                <span>约 {n.minutes} min</span>
              </div>
            </div>
          </a>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>

<style>
  .topic-breadcrumb { font-size: var(--font-small); color: var(--ink-muted); margin-bottom: var(--space-3); }
  .topic-breadcrumb a { color: inherit; text-decoration: none; }

  .topic-head {
    padding: 0 0 var(--space-4) 0;
    margin-bottom: var(--space-5);
    border-bottom: 1px solid var(--rule-light);
  }
  .topic-kicker { font-size: var(--font-label); text-transform: uppercase; letter-spacing: 0.08em; color: var(--accent); margin-bottom: var(--space-1); }
  .topic-title { font-size: var(--font-h1); font-weight: 700; line-height: 1.15; margin: 0 0 var(--space-1); color: var(--ink); }
  .topic-tagline { font-size: var(--font-body); font-style: italic; color: var(--ink-muted); margin: 0; }

  /* Stat row */
  .stat-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-4);
    padding: var(--space-4);
    background: var(--bg-subtle);
    border: 1px solid var(--rule-faint);
    border-radius: var(--radius-md);
    margin-bottom: var(--space-5);
  }
  .stat-cell { text-align: center; }
  .stat-value { font-family: var(--font-display, Georgia, serif); font-size: 28px; font-weight: 700; color: var(--ink); line-height: 1; font-variant-numeric: tabular-nums; }
  .stat-unit { font-size: 14px; font-weight: 400; color: var(--ink-muted); margin-left: 2px; }
  .stat-label { font-size: var(--font-label); text-transform: uppercase; letter-spacing: 0.08em; color: var(--ink-ghost); margin-top: 4px; }

  /* Charts */
  .chart-label { font-size: var(--font-label); text-transform: uppercase; letter-spacing: 0.12em; color: var(--ink-ghost); margin-bottom: var(--space-2); }
  .chart-block { margin-bottom: var(--space-5); padding: var(--space-3) 0 var(--space-4); border-bottom: 1px solid var(--rule-faint); }
  .chart-bars { display: flex; align-items: flex-end; gap: 4px; height: 64px; margin-bottom: var(--space-1); }
  .chart-bar {
    flex: 1;
    min-width: 4px;
    height: calc(var(--h, 0%) + 4px);
    background: var(--accent);
    opacity: 0.75;
    border-radius: 1px;
  }
  .chart-bar:hover { opacity: 1; }
  .chart-bar-empty { height: 2px; background: var(--rule); opacity: 0.4; }
  .chart-axis { display: flex; justify-content: space-between; font-size: var(--font-xs); color: var(--ink-ghost); font-variant-numeric: tabular-nums; }

  /* Distribution bars */
  .dist-grid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-5); margin-bottom: var(--space-5); }
  .dist-block { padding: var(--space-3) 0; }
  .dist-row {
    display: grid;
    grid-template-columns: 100px 1fr auto;
    gap: var(--space-2);
    align-items: center;
    padding: 4px 0;
  }
  .dist-row-name { font-size: var(--font-small); color: var(--ink); font-family: var(--font-display, Georgia, serif); font-weight: 600; }
  .dist-row-bar {
    height: 12px;
    background: color-mix(in oklab, var(--accent) 60%, var(--bg-subtle));
    border-radius: 2px;
    display: inline-block;
  }
  .dist-row-count { font-size: var(--font-caption); color: var(--ink-ghost); font-variant-numeric: tabular-nums; min-width: 24px; text-align: right; }

  @media (max-width: 768px) {
    .dist-grid { grid-template-columns: 1fr; }
    .stat-row { grid-template-columns: repeat(2, 1fr); }
  }

  /* Notes */
  .note-list-section { padding-top: var(--space-3); border-top: 1px solid var(--rule); }
  .note-list { list-style: none; padding: 0; margin: 0; }
  .note-item { border-bottom: 1px solid var(--rule-faint); }
  .note-item:last-child { border-bottom: none; }
  .note-link {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-4);
    padding: var(--space-3) 0;
    text-decoration: none;
    color: inherit;
    transition: padding-left var(--duration-fast);
  }
  .note-link:hover { padding-left: var(--space-2); }
  .note-link:hover .note-title { color: var(--ink-hover); text-decoration: underline; text-underline-offset: 0.12em; }
  .note-date { font-size: var(--font-caption); color: var(--ink-ghost); font-variant-numeric: tabular-nums; padding-top: 4px; min-width: 48px; }
  .note-body { min-width: 0; }
  .note-title { font-size: var(--font-body); font-weight: 700; color: var(--ink); line-height: 1.3; margin-bottom: var(--space-1); }
  .note-excerpt {
    font-size: var(--font-small);
    color: var(--ink-muted);
    line-height: 1.5;
    margin: 0 0 var(--space-1);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .note-kickers { display: flex; gap: var(--space-2); font-size: var(--font-caption); color: var(--ink-ghost); }
  .note-type { color: var(--accent); letter-spacing: 0.04em; }
</style>

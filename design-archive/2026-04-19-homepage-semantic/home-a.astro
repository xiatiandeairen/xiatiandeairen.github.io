---
/*
  首页重设计 — 方向 A：语义分区
  不再是"按日期切 slice"，而是让 series / topic 两个维度显影。
  结构：
    1. Hero 头条
    2. 系列进行中（2 张 series card）
    3. 主题专栏（2 个 topic column）
    4. 最新 5 篇（compact 列表）
    5. 查看归档入口
*/
import BaseLayout from '../../layouts/BaseLayout.astro';

// ── mock data（脱离真实业务数据，仅为 mockup） ──
const hero = {
  title: 'Long Sprint 实践：让 AI 自主完成大型任务',
  excerpt: '当一个 Sprint 放不下、Sprint 设计上是为单一、聚焦的任务优化的。添加一个功能、修复一个 bug、重构一个模块——这些任务的边界清晰，一条流水线走完就能交付。但有些任务天然就很大。',
  type: '系统设计',
  minutes: 13,
  date: '2026年4月15日',
};

const activeSeries = [
  {
    name: 'Sprint Methodology',
    progress: '3 / 5',
    description: '给 AI 一条流水线而不是一句话',
    latest: [
      'Long Sprint 实践：让 AI 自主完成大型任务',
      'Sprint 的停机位：任务中断时怎么办',
      'Sprint：给 AI 一条流水线而不是一句话',
    ],
  },
  {
    name: 'AI 阅读习惯',
    progress: '2 / 4',
    description: '从碎片阅读到结构化吸收',
    latest: [
      'Know：让 AI 不再重复犯同样的错',
      '把对话变成站点：AI 笔记的落地',
    ],
  },
];

const topicColumns = [
  {
    topic: 'AI 工程化',
    count: 12,
    picks: [
      { title: 'Decay：用 Rust 给代码做体检', type: '工具实现', date: '04-14' },
      { title: 'Diagnose：AI 调试不应该是碰运气', type: '方法论', date: '04-13' },
      { title: 'Skill 设计模式：如何写出 AI 真正能执行的指令', type: '方法论', date: '04-11' },
    ],
  },
  {
    topic: '写作方法论',
    count: 7,
    picks: [
      { title: '从问题到文章：不写废话的结构法', type: '方法论', date: '04-09' },
      { title: '改稿的三条纪律', type: '方法论', date: '04-05' },
      { title: '为什么个人博客不该追热点', type: '观察', date: '03-30' },
    ],
  },
];

const recent = [
  { title: 'Long Sprint 实践：让 AI 自主完成大型任务', date: '04-15', minutes: 13 },
  { title: 'Decay：用 Rust 给代码做体检', date: '04-14', minutes: 8 },
  { title: 'Diagnose：AI 调试不应该是碰运气', date: '04-13', minutes: 10 },
  { title: 'Sprint：给 AI 一条流水线而不是一句话', date: '04-12', minutes: 11 },
  { title: 'Know：让 AI 不再重复犯同样的错', date: '04-10', minutes: 9 },
];
---

<BaseLayout title="首页 A · 语义分区 · Mockup">
  <main class="home-a">

    {/* ═══════ 1. Hero ═══════ */}
    <section class="hero">
      <div class="hero-kicker">{hero.type}</div>
      <h1 class="hero-title font-display">{hero.title}</h1>
      <p class="hero-excerpt font-sans">{hero.excerpt}</p>
      <div class="hero-meta font-sans">{hero.date} · {hero.minutes} min</div>
    </section>

    {/* ═══════ 2. 系列进行中 ═══════ */}
    <section class="block">
      <header class="block-head">
        <div class="block-label">[ 系列进行中 ]</div>
        <a class="block-more" href="#">全部系列 →</a>
      </header>
      <div class="series-grid">
        {activeSeries.map(s => (
          <article class="series-card">
            <div class="series-card-meta font-sans">系列 · {s.progress}</div>
            <h3 class="series-card-name font-display">{s.name}</h3>
            <p class="series-card-desc font-sans">{s.description}</p>
            <ul class="series-card-list">
              {s.latest.map((t, i) => (
                <li>
                  <span class="series-card-list-num font-sans">{String(i + 1).padStart(2, '0')}</span>
                  <a href="#" class="series-card-list-title">{t}</a>
                </li>
              ))}
            </ul>
          </article>
        ))}
      </div>
    </section>

    {/* ═══════ 3. 主题专栏 ═══════ */}
    <section class="block">
      <header class="block-head">
        <div class="block-label">[ 主题专栏 ]</div>
        <a class="block-more" href="#">全部主题 →</a>
      </header>
      <div class="topic-grid">
        {topicColumns.map(c => (
          <article class="topic-col">
            <header class="topic-col-head">
              <h3 class="topic-col-name font-display">{c.topic}</h3>
              <span class="topic-col-count font-sans">{c.count} 篇</span>
            </header>
            <ul class="topic-col-list">
              {c.picks.map(p => (
                <li class="topic-col-item">
                  <div class="topic-col-item-kicker font-sans">{p.type}</div>
                  <a href="#" class="topic-col-item-title font-display">{p.title}</a>
                  <time class="topic-col-item-date font-sans">{p.date}</time>
                </li>
              ))}
            </ul>
          </article>
        ))}
      </div>
    </section>

    {/* ═══════ 4. 最新 5 篇 ═══════ */}
    <section class="block">
      <header class="block-head">
        <div class="block-label">[ 最新 ]</div>
      </header>
      <ul class="recent-list">
        {recent.map(r => (
          <li class="recent-item">
            <time class="recent-item-date font-sans">{r.date}</time>
            <a href="#" class="recent-item-title">{r.title}</a>
            <span class="recent-item-min font-sans">{r.minutes} min</span>
          </li>
        ))}
      </ul>
    </section>

    {/* ═══════ 5. 归档入口 ═══════ */}
    <section class="archive-cta">
      <a href="#" class="archive-cta-link font-display">查看完整归档 →</a>
    </section>

  </main>
</BaseLayout>

<style>
  .home-a { max-width: 1120px; margin: 0 auto; padding: var(--space-6) var(--space-4); }

  /* ── Hero ── */
  .hero { padding: var(--space-5) 0 var(--space-6); border-bottom: 3px solid var(--ink); }
  .hero-kicker { font-family: Inter, sans-serif; font-size: var(--font-label); color: var(--accent); letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: var(--space-2); }
  .hero-title { font-size: var(--font-h1); font-weight: 700; line-height: 1.15; margin: 0 0 var(--space-3); color: var(--ink); }
  .hero-excerpt { font-size: var(--font-body); line-height: 1.6; color: var(--ink-muted); max-width: 720px; margin: 0 0 var(--space-3); }
  .hero-meta { font-size: var(--font-caption); color: var(--ink-ghost); letter-spacing: 0.04em; }

  /* ── Block shell ── */
  .block { margin-top: var(--space-6); }
  .block-head { display: flex; align-items: baseline; justify-content: space-between; margin-bottom: var(--space-4); }
  .block-label { font-family: var(--font-display, Georgia, serif); font-size: var(--font-h3); font-weight: 600; color: var(--accent); }
  .block-more { font-family: Inter, sans-serif; font-size: var(--font-small); color: var(--ink-muted); text-decoration: none; }
  .block-more:hover { color: var(--ink-hover); }

  /* ── Series ── */
  .series-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--space-5); }
  .series-card {
    padding: var(--space-5);
    background: var(--bg-subtle);
    border: 1px solid var(--rule-faint);
    border-left: 3px solid var(--accent);
    border-radius: var(--radius-md);
  }
  .series-card-meta { font-size: var(--font-label); color: var(--accent); letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: var(--space-2); }
  .series-card-name { font-size: var(--font-h3); font-weight: 700; margin: 0 0 var(--space-1); color: var(--ink); }
  .series-card-desc { font-size: var(--font-small); color: var(--ink-muted); margin: 0 0 var(--space-3); font-style: italic; }
  .series-card-list { list-style: none; padding: 0; margin: 0; border-top: 1px solid var(--rule-faint); }
  .series-card-list li { display: flex; gap: var(--space-3); align-items: baseline; padding: var(--space-2) 0; border-bottom: 1px solid var(--rule-faint); }
  .series-card-list li:last-child { border-bottom: none; }
  .series-card-list-num { flex: 0 0 auto; font-size: var(--font-caption); color: var(--ink-ghost); font-variant-numeric: tabular-nums; }
  .series-card-list-title { font-family: var(--font-display, Georgia, serif); font-size: var(--font-small); color: var(--ink); text-decoration: none; line-height: 1.4; }
  .series-card-list-title:hover { color: var(--ink-hover); text-decoration: underline; text-underline-offset: 0.12em; }

  /* ── Topic ── */
  .topic-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--space-6); }
  .topic-col { border-top: 2px solid var(--ink); padding-top: var(--space-3); }
  .topic-col-head { display: flex; align-items: baseline; justify-content: space-between; margin-bottom: var(--space-3); }
  .topic-col-name { font-size: var(--font-h3); font-weight: 700; margin: 0; color: var(--ink); }
  .topic-col-count { font-size: var(--font-caption); color: var(--ink-ghost); }
  .topic-col-list { list-style: none; padding: 0; margin: 0; }
  .topic-col-item { padding: var(--space-3) 0; border-bottom: 1px solid var(--rule-faint); }
  .topic-col-item:last-child { border-bottom: none; }
  .topic-col-item-kicker { font-size: var(--font-label); color: var(--accent); letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 4px; }
  .topic-col-item-title { display: block; font-size: var(--font-body); font-weight: 600; color: var(--ink); text-decoration: none; line-height: 1.35; margin-bottom: 4px; }
  .topic-col-item-title:hover { color: var(--ink-hover); text-decoration: underline; }
  .topic-col-item-date { font-size: var(--font-caption); color: var(--ink-ghost); font-variant-numeric: tabular-nums; }

  /* ── Recent ── */
  .recent-list { list-style: none; padding: 0; margin: 0; border-top: 1px solid var(--rule); }
  .recent-item { display: grid; grid-template-columns: 72px 1fr auto; gap: var(--space-3); align-items: baseline; padding: var(--space-2) 0; border-bottom: 1px solid var(--rule-faint); }
  .recent-item-date { font-family: Inter, sans-serif; font-size: var(--font-caption); color: var(--ink-ghost); font-variant-numeric: tabular-nums; }
  .recent-item-title { font-family: var(--font-display, Georgia, serif); font-size: var(--font-body); font-weight: 600; color: var(--ink); text-decoration: none; }
  .recent-item-title:hover { color: var(--ink-hover); text-decoration: underline; }
  .recent-item-min { font-size: var(--font-caption); color: var(--ink-ghost); }

  /* ── Archive CTA ── */
  .archive-cta { margin-top: var(--space-6); padding: var(--space-5) 0; text-align: center; border-top: 1px solid var(--rule); }
  .archive-cta-link { font-size: var(--font-h3); font-weight: 600; color: var(--ink); text-decoration: none; }
  .archive-cta-link:hover { color: var(--accent); }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .series-grid, .topic-grid { grid-template-columns: 1fr; }
    .recent-item { grid-template-columns: 64px 1fr; }
    .recent-item-min { grid-column: 2; margin-top: -4px; }
  }
</style>

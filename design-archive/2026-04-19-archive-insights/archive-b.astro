---
/*
  归档页增强 · 方案 B 预览
  Heatmap（52 周 × 7 天，GitHub contribution 风格）+ 节奏微指标
  数据为合成 — 模拟 52 周间的发文分布（重度偏 0，集中爆发）
*/
import BaseLayout from '../../layouts/BaseLayout.astro';

// ── 合成 1 年每日数据 ──
type Cell = { date: string; count: number; dow: number; week: number; monthLabel?: string };

// Deterministic pseudo-random for demo stability
let seed = 42;
function rand() { seed = (seed * 9301 + 49297) % 233280; return seed / 233280; }

const endDate = new Date('2026-04-19');
const startDate = new Date(endDate);
startDate.setDate(endDate.getDate() - 52 * 7); // 52 weeks back
// Align to previous Monday
const dayShift = (startDate.getDay() + 6) % 7;
startDate.setDate(startDate.getDate() - dayShift);

const cells: Cell[] = [];
let weekIdx = 0;
let dayCursor = new Date(startDate);
let lastMonth = -1;
while (dayCursor <= endDate) {
  const dow = (dayCursor.getDay() + 6) % 7; // 0 = Monday
  // Randomly assign post count: mostly 0, occasional bursts
  let count = 0;
  const r = rand();
  if (r < 0.08) count = 1;
  else if (r < 0.11) count = 2;
  else if (r < 0.12) count = 3;
  const iso = dayCursor.toISOString().slice(0, 10);
  const month = dayCursor.getMonth();
  const monthLabel = (month !== lastMonth && dow === 0) ? dayCursor.toLocaleDateString('zh-CN', { month: 'short' }) : undefined;
  if (dow === 0 && month !== lastMonth) lastMonth = month;
  cells.push({ date: iso, count, dow, week: weekIdx, monthLabel });
  dayCursor.setDate(dayCursor.getDate() + 1);
  if (dow === 6) weekIdx += 1;
}

// Organize cells into a map keyed by week * 7 + dow for grid placement
const weeks = weekIdx + 1;

// ── Stats derived ──
const totalPosts = cells.reduce((n, c) => n + c.count, 0);
const activeDays = cells.filter(c => c.count > 0).length;
const totalDays = cells.length;

// Longest streak of consecutive days with posts
let longestStreak = 0, currStreak = 0;
for (const c of cells) {
  if (c.count > 0) { currStreak += 1; longestStreak = Math.max(longestStreak, currStreak); }
  else currStreak = 0;
}
// Longest gap
let longestGap = 0, currGap = 0;
for (const c of cells) {
  if (c.count === 0) { currGap += 1; longestGap = Math.max(longestGap, currGap); }
  else currGap = 0;
}
// Average interval (days between posts)
const avgInterval = activeDays > 1 ? (totalDays / activeDays).toFixed(1) : '—';

// Month labels at first-Monday-of-month columns
const monthLabels = cells.filter(c => c.monthLabel).map(c => ({ week: c.week, label: c.monthLabel! }));
---

<BaseLayout title="归档 · Heatmap Mockup">
  <header class="archive-header">
    <h1 class="font-display text-h1 mb-1">归档</h1>
    <p class="font-sans text-small archive-subtitle">共 {totalPosts} 篇文章（合成数据），按时间排列。</p>
  </header>

  {/* ── 1. Heatmap ── */}
  <section class="heatmap-section">
    <div class="heatmap-label font-sans">写作热力图 · 最近 52 周</div>
    <div class="heatmap-wrap">
      <div class="heatmap-dow font-sans">
        <span>一</span>
        <span>二</span>
        <span>三</span>
        <span>四</span>
        <span>五</span>
        <span>六</span>
        <span>日</span>
      </div>
      <div class="heatmap-content">
        <div class="heatmap-months font-sans" style={`grid-template-columns: repeat(${weeks}, 1fr);`}>
          {Array.from({ length: weeks }).map((_, w) => {
            const label = monthLabels.find(m => m.week === w)?.label;
            return <span class="heatmap-month-label">{label || ''}</span>;
          })}
        </div>
        <div class="heatmap-grid" style={`grid-template-columns: repeat(${weeks}, 1fr);`}>
          {Array.from({ length: weeks * 7 }).map((_, idx) => {
            const w = Math.floor(idx / 7);
            const d = idx % 7;
            const cell = cells.find(c => c.week === w && c.dow === d);
            const level = cell ? (cell.count === 0 ? 0 : cell.count === 1 ? 1 : cell.count === 2 ? 2 : 3) : -1;
            const style = `grid-column: ${w + 1}; grid-row: ${d + 1};`;
            if (level < 0) return <span class="heatmap-cell heatmap-cell-empty" style={style}></span>;
            return (
              <span
                class={`heatmap-cell heatmap-cell-l${level}`}
                style={style}
                title={cell ? `${cell.date} · ${cell.count} 篇` : ''}
              ></span>
            );
          })}
        </div>
      </div>
    </div>
    <div class="heatmap-legend font-sans">
      <span class="heatmap-legend-text">少</span>
      <span class="heatmap-cell heatmap-cell-l0"></span>
      <span class="heatmap-cell heatmap-cell-l1"></span>
      <span class="heatmap-cell heatmap-cell-l2"></span>
      <span class="heatmap-cell heatmap-cell-l3"></span>
      <span class="heatmap-legend-text">多</span>
    </div>
  </section>

  {/* ── 2. 节奏微指标 ── */}
  <section class="micro-stats font-sans">
    <div class="micro-stat">
      <span class="micro-stat-label">最长空档</span>
      <span class="micro-stat-value">{longestGap}</span>
      <span class="micro-stat-unit">天</span>
    </div>
    <div class="micro-stat">
      <span class="micro-stat-label">最长连发</span>
      <span class="micro-stat-value">{longestStreak}</span>
      <span class="micro-stat-unit">连日</span>
    </div>
    <div class="micro-stat">
      <span class="micro-stat-label">平均间隔</span>
      <span class="micro-stat-value">{avgInterval}</span>
      <span class="micro-stat-unit">天 / 篇</span>
    </div>
    <div class="micro-stat">
      <span class="micro-stat-label">活跃天</span>
      <span class="micro-stat-value">{activeDays}</span>
      <span class="micro-stat-unit">/ {totalDays}</span>
    </div>
  </section>

  <div class="mock-placeholder font-sans">
    ↓ 现有 filter + year/month 列表 + stats sidebar（保持原样）
  </div>
</BaseLayout>

<style>
  .archive-header {
    margin-bottom: var(--space-5);
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--rule-light);
  }
  .archive-subtitle { color: var(--ink-muted); }

  /* ── Heatmap ── */
  .heatmap-section {
    margin-bottom: var(--space-5);
    padding: var(--space-4) 0;
    border-bottom: 1px solid var(--rule-faint);
  }
  .heatmap-label {
    font-size: var(--font-label);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--ink-ghost);
    margin-bottom: var(--space-3);
  }
  .heatmap-wrap {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-2);
    align-items: start;
  }
  .heatmap-dow {
    display: grid;
    grid-template-rows: repeat(7, 1fr);
    gap: 3px;
    padding-top: 18px; /* offset for month-label row */
    font-size: var(--font-xs);
    color: var(--ink-ghost);
    text-align: right;
    padding-right: 4px;
  }
  .heatmap-dow span { line-height: 1; height: 12px; }
  .heatmap-content {
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 0;
    overflow-x: auto;
  }
  .heatmap-months {
    display: grid;
    gap: 3px;
    font-size: var(--font-xs);
    color: var(--ink-ghost);
    height: 14px;
  }
  .heatmap-month-label {
    grid-row: 1;
    white-space: nowrap;
  }
  .heatmap-grid {
    display: grid;
    grid-template-rows: repeat(7, 12px);
    gap: 3px;
  }
  .heatmap-cell {
    display: inline-block;
    width: 12px;
    height: 12px;
    border-radius: 2px;
    background: var(--rule-faint);
    cursor: pointer;
    transition: outline-color var(--duration-fast);
    outline: 1px solid transparent;
  }
  .heatmap-cell:hover { outline-color: var(--ink); }
  .heatmap-cell-empty { background: transparent; pointer-events: none; }
  .heatmap-cell-l0 { background: var(--rule-light); }
  .heatmap-cell-l1 { background: color-mix(in oklab, var(--accent) 35%, var(--bg-subtle)); }
  .heatmap-cell-l2 { background: color-mix(in oklab, var(--accent) 65%, var(--bg-subtle)); }
  .heatmap-cell-l3 { background: var(--accent); }

  .heatmap-legend {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-top: var(--space-3);
    padding-left: calc(var(--space-2) + 20px);
    font-size: var(--font-xs);
    color: var(--ink-ghost);
  }
  .heatmap-legend-text { margin: 0 4px; }

  /* ── 微指标（复用 archive-a） ── */
  .micro-stats {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-5);
    padding: var(--space-3) 0 var(--space-5);
    border-bottom: 1px solid var(--rule-light);
    margin-bottom: var(--space-5);
  }
  .micro-stat { display: inline-flex; align-items: baseline; gap: 4px; color: var(--ink-muted); }
  .micro-stat-label { color: var(--ink-ghost); text-transform: uppercase; letter-spacing: 0.06em; font-size: var(--font-label); }
  .micro-stat-value { font-weight: 700; color: var(--ink); font-size: var(--font-body); font-variant-numeric: tabular-nums; margin-left: 4px; }
  .micro-stat-unit { color: var(--ink-ghost); font-size: var(--font-caption); }

  .mock-placeholder {
    padding: var(--space-6) var(--space-4);
    text-align: center;
    color: var(--ink-ghost);
    border: 1px dashed var(--rule);
    border-radius: var(--radius-md);
  }
</style>
